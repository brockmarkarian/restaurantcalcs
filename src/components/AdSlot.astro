---
// AdSlot, Google AdSense container w/ design-system styling.
// Pre-approval: uses data-adtest="on" + placeholder slot ID. After approval,
// replace data-ad-slot per variant with real slot IDs from AdSense dashboard.

interface Props {
  variant: 'leaderboard' | 'in-content' | 'sidebar' | 'sticky';
  slot?: string; // AdSense slot ID, defaults to placeholder
  label?: string;
}

const ADSENSE_CLIENT = 'ca-pub-6332696231897305';
const { variant, slot = '0000000000', label = 'Advertisement' } = Astro.props;
---

<aside class={`ad-slot ad-slot--${variant}`} data-variant={variant}>
  <span class="ad-slot__label">{label}</span>
  <div class="ad-slot__inner">
    <ins class="adsbygoogle"
         style="display:block"
         data-ad-client={ADSENSE_CLIENT}
         data-ad-slot={slot}
         data-ad-format="auto"
         data-full-width-responsive="true"
         data-adtest="on"></ins>
    <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  </div>
</aside>

<style>
  .ad-slot {
    position: relative;
    width: 100%;
    margin: var(--space-12) 0;
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-cream);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .ad-slot__label {
    display: block;
    padding: 6px 12px;
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-muted);
    background: rgba(122, 117, 105, 0.06);
    border-bottom: 1px dashed var(--color-border);
  }

  .ad-slot__inner {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-6);
  }

  .ad-slot__placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    color: var(--color-muted);
    text-align: center;
  }

  .ad-slot__icon {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    color: var(--color-border);
  }

  .ad-slot__size {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-body);
  }

  .ad-slot__hint {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  /* Variants */
  .ad-slot--leaderboard .ad-slot__inner { min-height: 90px; }
  .ad-slot--in-content .ad-slot__inner { min-height: 280px; }
  .ad-slot--sidebar { max-width: 300px; }
  .ad-slot--sidebar .ad-slot__inner { min-height: 600px; }
  .ad-slot--sticky { max-width: 300px; }
  .ad-slot--sticky .ad-slot__inner { min-height: 250px; }
</style>
