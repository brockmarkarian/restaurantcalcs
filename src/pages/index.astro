  .viz-tp__bar > span { display: block; height: 100%; background: var(--color-saffron-cta); border-radius: 999px; }

  /* menu-pricing: flow */
  .viz-mp { display: flex; flex-direction: column; gap: 4px; align-items: flex-start; }
  .viz-mp__step { display: flex; justify-content: space-between; align-items: baseline; width: 100%; font-family: var(--font-body); font-size: 0.75rem; color: var(--color-body); }
