---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const calcs = [
  { slug: 'food-cost', title: 'Food Cost Percentage', desc: 'Compare food cost to revenue to spot menu margin issues.', time: '2 min', tag: 'Most used', viz: 'food-cost' },
  { slug: 'recipe-cost', title: 'Recipe & Plate Cost', desc: 'Build plate cost from ingredient quantities and prices.', time: '5 min', tag: null, viz: 'recipe-cost' },
  { slug: 'labor-cost', title: 'Labor Cost Percentage', desc: 'Track labor as a share of revenue across shifts.', time: '2 min', tag: null, viz: 'labor-cost' },
  { slug: 'tip-pool', title: 'Tip Pool & Tip Out', desc: 'Split tips fairly across roles by hours or points.', time: '3 min', tag: 'Popular', viz: 'tip-pool' },
  { slug: 'menu-pricing', title: 'Menu Pricing', desc: 'Reverse-engineer menu price from cost and target margin.', time: '2 min', tag: null, viz: 'menu-pricing' },
  { slug: 'liquor-pour-cost', title: 'Liquor Pour Cost', desc: 'Calculate pour cost % and benchmark against industry.', time: '3 min', tag: null, viz: 'liquor-pour-cost' },
  { slug: 'break-even', title: 'Break-Even Revenue', desc: 'Find revenue needed to cover fixed and variable costs.', time: '5 min', tag: null, viz: 'break-even' },
  { slug: 'inventory-variance', title: 'Inventory Variance', desc: 'Spot theft, waste, or counting errors in food inventory.', time: '4 min', tag: null, viz: 'inventory-variance' },
  { slug: 'prime-cost', title: 'Prime Cost', desc: 'Food + beverage + labor as % of revenue. The single number every operator should track weekly.', time: '2 min', tag: null, viz: 'prime-cost' },
  { slug: 'keg-cost', title: 'Draft Beer / Keg Cost', desc: 'Pour cost, cost per pour, profit per keg. Fixes the leakiest line item in any bar.', time: '2 min', tag: 'New', viz: 'keg-cost' },
  { slug: 'no-show-deposit', title: 'No-Show & Deposit', desc: 'Cost of empty reserved seats. Suggested deposit, break-even no-show rate, annual recovery.', time: '3 min', tag: 'New', viz: 'no-show' },
  { slug: 'menu-engineering', title: 'Menu Engineering', desc: 'Star / Plowhorse / Puzzle / Dog matrix. Classify items by margin and popularity.', time: '5 min', tag: null, viz: 'menu-eng' },
  { slug: 'delivery-profit', title: 'Delivery True-Profit', desc: 'DoorDash, UberEats, GrubHub commission stack vs your real cost. Net per platform order.', time: '4 min', tag: 'New', viz: 'delivery' },
  { slug: 'catering-pricing', title: 'Catering Pricing', desc: 'Per-head price + service charge + suggested gratuity. Operator margin protected.', time: '5 min', tag: 'New', viz: 'catering' },
  { slug: 'turnover-cost', title: 'Employee Turnover Cost', desc: 'Annual cost of replacement hires. Industry runs 75-130% turnover.', time: '3 min', tag: 'New', viz: 'turnover' },
  { slug: 'fountain-cost', title: 'Fountain Drink / BIB Cost', desc: 'BIB yield + ice + free refills + cup cost. Real pour cost on soda.', time: '3 min', tag: 'New', viz: 'fountain' },
];

const nowHome = new Date();
const recentPosts = (await getCollection('blog', ({ data }) => !data.draft && data.pubDate <= nowHome))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const fmtDate = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

const faq = [
  {
    q: 'Are these calculators really free? What\'s the catch?',
    a: 'Free, no signup, no email gate, no upsell. The site runs on display advertising, you scroll past an ad placeholder. Every calculator runs in your browser; nothing is sent to a server. Close the tab and your inputs disappear.',
  },
  {
    q: 'Who built RestaurantCalcs and why should I trust the math?',
    a: 'Built by Brock Markarian, a 5-year bartender-to-GM at Cosmos Taverna in California. Every formula was audited against authoritative industry sources, <a href="https://pos.toasttab.com/blog/on-the-line/how-to-calculate-food-cost-percentage" target="_blank" rel="noopener">Toast</a>, Restaurant365, MarginEdge, the <a href="https://restaurant.org/" target="_blank" rel="noopener">National Restaurant Association</a>, the <a href="https://www.dol.gov/agencies/whd/fact-sheets/15-tipped-employees-flsa" target="_blank" rel="noopener">Department of Labor</a>, BinWise, BevSpot, the Culinary Institute of America. Sources are cited inline on each calculator page.',
  },
  {
    q: 'Why these calculators specifically? What\'s missing?',
    a: 'These are the metrics every indie restaurant runs every week: food cost %, recipe cost, labor cost % (with shift-by-shift mode), tip pool distribution, menu pricing, liquor pour cost, draft beer / keg cost, break-even revenue, inventory variance, prime cost, no-show deposit math, and menu engineering. They cover the full prime cost equation, the bar program, and the menu-strategy side. Catering pricing and schedule optimizer are next.',
  },
  {
    q: 'Can I use these for my restaurant\'s actual books?',
    a: 'Use them for sanity checks, weekly tracking, and quick decisions. They are educational tools, not a replacement for accounting software, payroll providers, or a labor attorney. The disclaimer on every page is real. Consult qualified professionals before making business decisions.',
  },
  {
    q: 'How accurate are the industry benchmark thresholds?',
    a: 'Benchmarks (e.g. food cost 28–32% healthy for full-service, labor cost 25–35% by concept type, liquor pour cost 18–24% on spirits) are pulled from the most recent published industry sources. They\'re directional, not absolute. Your local market, vendor mix, and concept type all shift the right target for you.',
  },
  {
    q: 'Why does the tip pool calculator have legal warnings?',
    a: 'Because tip-pool violations carry six-figure FLSA penalties and the rules change. Federal law prohibits managers and supervisors from receiving pooled tips (FLSA §3(m)(2)(B), 2018). Tip-credit states restrict the pool to FOH only. The 2021 DOL final rule and the August 2024 Fifth Circuit vacatur of the 80/20/30 rule also matter. We surface the rules inline so operators can run the math without accidentally building an illegal policy.',
  },
];

const homepageSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': 'https://restaurantcalcs.com/#webpage',
    url: 'https://restaurantcalcs.com/',
    name: 'RestaurantCalcs, Restaurant math, done right.',
    description: 'Free calculators for restaurant ops math. Built by a 5-year GM. Math shown on every result.',
    isPartOf: { '@id': 'https://restaurantcalcs.com/#website' },
    primaryImageOfPage: { '@type': 'ImageObject', url: 'https://restaurantcalcs.com/og/index.png' },
    inLanguage: 'en-US',
    author: { '@id': 'https://restaurantcalcs.com/#founder' },
    publisher: { '@id': 'https://restaurantcalcs.com/#organization' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'RestaurantCalcs, All calculators',
    description: 'Free calculators for everyday restaurant operations math.',
    numberOfItems: calcs.length,
    itemListElement: calcs.map((c, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `https://restaurantcalcs.com/calculators/${c.slug}/`,
      name: c.title,
      description: c.desc,
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faq.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    '@id': 'https://restaurantcalcs.com/#suite',
    name: 'RestaurantCalcs',
    description: 'Suite of free web-based calculators for restaurant operations: food cost, recipe cost, labor (with shift schedule mode), tip pool, menu pricing, liquor pour cost, draft beer / keg cost, break-even, inventory variance, prime cost, no-show deposit, and menu engineering.',
    applicationCategory: 'BusinessApplication',
    applicationSubCategory: 'Restaurant Management',
    operatingSystem: 'Web',
    browserRequirements: 'Requires JavaScript',
    url: 'https://restaurantcalcs.com/',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    creator: { '@id': 'https://restaurantcalcs.com/#organization' },
    author: { '@id': 'https://restaurantcalcs.com/#founder' },
    isAccessibleForFree: true,
  },
];
---

<Layout schema={homepageSchema}>
  <section class="hero">
    <div class="container hero__container">
      <div class="hero__copy">
        <p class="t-micro hero__eyebrow t-micro--saffron">100% free · no signup · no upsells</p>
        <h1 class="hero__headline">
          <span class="hero__line">Restaurant math,</span>
          <span class="hero__line"><em class="hero__em">done right.</em></span>
        </h1>
        <p class="hero__subhead">
          16 free calculators for everyday restaurant math. No accounts. No paywalls. The formula shown underneath every result so you can trust it &mdash; and teach it.
        </p>
        <div class="hero__ctas">
          <a href="/calculators/food-cost/" class="btn btn-primary btn-large">
            Open free food cost calc
            <span class="btn__arrow" aria-hidden="true">→</span>
          </a>
          <a href="#calculators" class="btn btn-secondary btn-large">Browse all free tools</a>
        </div>
        <div class="hero__trust">
          <div class="hero__trust-dots">
            <span class="hero__trust-dot"></span>
            <span class="hero__trust-dot"></span>
            <span class="hero__trust-dot"></span>
          </div>
          <p class="t-caption">Built by an operator. <strong>No email required, ever.</strong></p>
        </div>
      </div>

      <div class="hero__viz" data-parallax>
        <div class="stack" data-stack>
          <!-- Background card 3 -->
          <article class="stack-card stack-card--c3" aria-hidden="true">
            <div class="stack-card__head">
              <span class="t-micro">Tip pool · Friday</span>
            </div>
            <div class="stack-card__split">
              <div class="split-row"><span>Server A</span><span class="num">$184.20</span></div>
              <div class="split-row"><span>Server B</span><span class="num">$201.50</span></div>
              <div class="split-row"><span>Bar</span><span class="num">$98.40</span></div>
              <div class="split-row"><span>Bussers</span><span class="num">$62.10</span></div>
            </div>
          </article>

          <!-- Background card 2 -->
          <article class="stack-card stack-card--c2" aria-hidden="true">
            <div class="stack-card__head">
              <span class="t-micro">Recipe cost · Carbonara</span>
            </div>
            <div class="stack-card__rows">
              <div class="recipe-row"><span>Guanciale 80g</span><span class="num">$3.40</span></div>
              <div class="recipe-row"><span>Pecorino 30g</span><span class="num">$1.85</span></div>
              <div class="recipe-row"><span>Eggs (2)</span><span class="num">$0.80</span></div>
              <div class="recipe-row"><span>Bucatini 100g</span><span class="num">$0.62</span></div>
              <div class="recipe-row recipe-row--total"><span>Plate cost</span><span class="num">$6.67</span></div>
            </div>
          </article>

          <!-- Foreground card, live result -->
          <article class="stack-card stack-card--c1">
            <div class="stack-card__head">
              <span class="t-micro stack-card__label">Food cost percentage</span>
              <span class="status-pill" data-status="healthy">
                <span class="status-pill__dot"></span>Healthy
              </span>
            </div>
            <div class="stack-card__result" aria-live="polite" aria-atomic="true">
              <span class="result-num" data-counter="28.4">0.0</span>
              <span class="result-num__pct" aria-hidden="true">%</span>
              <span class="visually-hidden">percent food cost</span>
            </div>
            <div class="stack-card__benchmark">
              <span class="t-caption">Industry benchmark</span>
              <span class="t-caption num">28–32%</span>
            </div>
            <div class="stack-card__bar">
              <div class="bar-track">
                <div class="bar-zone bar-zone--good"></div>
                <div class="bar-zone bar-zone--warn"></div>
                <div class="bar-zone bar-zone--bad"></div>
                <div class="bar-marker" data-bar-marker style="left: 28.4%"></div>
              </div>
              <div class="bar-labels">
                <span class="t-caption num">0</span>
                <span class="t-caption num">50%</span>
              </div>
            </div>
          </article>

          <!-- Floating glyphs in 3D space -->
          <span class="glyph glyph--pct" aria-hidden="true">%</span>
          <span class="glyph glyph--dollar" aria-hidden="true">$</span>
          <span class="glyph glyph--coin" aria-hidden="true"></span>
        </div>
      </div>
    </div>
  </section>

  <section class="strip">
    <div class="container">
      <div class="strip__inner">
        <span class="t-micro">Built for the line, not the boardroom</span>
        <span class="strip__divider" aria-hidden="true"></span>
        <span class="strip__brand">Free forever</span>
        <span class="strip__dot" aria-hidden="true">·</span>
        <span class="strip__brand">No signup</span>
        <span class="strip__dot" aria-hidden="true">·</span>
        <span class="strip__brand">Mobile-friendly</span>
      </div>
    </div>
  </section>

  <section class="tools" id="calculators">
    <div class="container">
      <div class="tools__header">
        <p class="t-micro t-micro--saffron">Twelve calculators</p>
        <h2 class="tools__headline">
          Every number a kitchen runs.
          <em class="tools__em">Nothing it doesn't.</em>
        </h2>
        <p class="t-body-large tools__subhead">
          Pick a tool. Plug the numbers in. The math is shown underneath every result so you can trust it, and teach it to your sous in thirty seconds.
        </p>
      </div>

      <div class="tools__grid">
        {calcs.map((c, i) => (
          <a href={`/calculators/${c.slug}/`} class="tool-card">
            {c.tag && (
              <div class="tool-card__top">
                <span class="tool-card__tag">{c.tag}</span>
              </div>
            )}

            <h3 class="tool-card__title">{c.title}</h3>

            <div class={`tool-viz tool-viz--${c.viz}`} aria-hidden="true">
              {c.viz === 'food-cost' && (
                <div class="viz-fc">
                  <div class="viz-fc__num"><span class="viz-fc__big">28.4</span><span class="viz-fc__pct">%</span></div>
                  <div class="viz-fc__bar">
                    <span class="viz-fc__zone viz-fc__zone--good"></span>
                    <span class="viz-fc__zone viz-fc__zone--watch"></span>
                    <span class="viz-fc__zone viz-fc__zone--bad"></span>
                    <span class="viz-fc__marker"></span>
                  </div>
                  <div class="viz-fc__label"><span>0%</span><span>Healthy 28–32%</span><span>50%</span></div>
                </div>
              )}
              {c.viz === 'recipe-cost' && (
                <div class="viz-rc">
                  <div class="viz-rc__row"><span>Guanciale</span><span class="num">$3.36</span></div>
                  <div class="viz-rc__row"><span>Pecorino</span><span class="num">$1.85</span></div>
                  <div class="viz-rc__row"><span>Eggs (2)</span><span class="num">$0.80</span></div>
                  <div class="viz-rc__row"><span>Bucatini</span><span class="num">$0.63</span></div>
                  <div class="viz-rc__total"><span>Plate cost</span><span class="num">$1.66</span></div>
                </div>
              )}
              {c.viz === 'labor-cost' && (
                <div class="viz-lc">
                  <div class="viz-lc__num"><span class="viz-lc__big">30.0</span><span class="viz-lc__pct">%</span></div>
                  <div class="viz-lc__splh"><span class="t-micro">SPLH</span><span class="num">$66.67/hr</span></div>
                  <div class="viz-lc__bar"><span class="viz-lc__fill"></span></div>
                </div>
              )}
              {c.viz === 'tip-pool' && (
                <div class="viz-tp">
                  <div class="viz-tp__row"><span>Server A</span><span class="viz-tp__bar"><span style="width:90%"></span></span><span class="num">$184</span></div>
                  <div class="viz-tp__row"><span>Server B</span><span class="viz-tp__bar"><span style="width:78%"></span></span><span class="num">$202</span></div>
                  <div class="viz-tp__row"><span>Bartender</span><span class="viz-tp__bar"><span style="width:48%"></span></span><span class="num">$98</span></div>
                  <div class="viz-tp__row"><span>Busser</span><span class="viz-tp__bar"><span style="width:30%"></span></span><span class="num">$62</span></div>
                </div>
              )}
              {c.viz === 'menu-pricing' && (
                <div class="viz-mp">
                  <div class="viz-mp__step"><span class="t-caption">Plate cost</span><span class="num viz-mp__cost">$4.50</span></div>
                  <div class="viz-mp__divide">÷ 30%</div>
                  <div class="viz-mp__step viz-mp__step--final"><span class="t-caption">Menu price</span><span class="num viz-mp__price">$14.95</span></div>
                </div>
              )}
              {c.viz === 'liquor-pour-cost' && (
                <div class="viz-lp">
                  <div class="viz-lp__bottle">
                    <span class="viz-lp__cap"></span>
                    <span class="viz-lp__neck"></span>
                    <span class="viz-lp__body"><span class="viz-lp__label">750ml</span></span>
                  </div>
                  <div class="viz-lp__stat">
                    <div><span class="t-caption">1.5oz pour</span><span class="num">$1.40</span></div>
                    <div><span class="t-caption">Pour cost</span><span class="num viz-lp__pct">11.7%</span></div>
                  </div>
                </div>
              )}
              {c.viz === 'break-even' && (
                <div class="viz-be">
                  <div class="viz-be__num"><span class="viz-be__big">110</span><span class="viz-be__unit">covers/day</span></div>
                  <div class="viz-be__bar">
                    <span class="viz-be__fill" style="width:62%"></span>
                    <span class="viz-be__marker" style="left:62%"></span>
                  </div>
                  <div class="viz-be__label"><span>$0</span><span>BE $100k/mo</span><span>$160k</span></div>
                </div>
              )}
              {c.viz === 'inventory-variance' && (
                <div class="viz-iv">
                  <div class="viz-iv__row viz-iv__row--theory"><span>Theoretical</span><span class="num">$28,000</span></div>
                  <div class="viz-iv__row viz-iv__row--actual"><span>Actual</span><span class="num">$30,000</span></div>
                  <div class="viz-iv__variance"><span>Variance</span><span class="num viz-iv__vbig">+$2,000 / 7.1%</span></div>
                </div>
              )}
              {c.viz === 'prime-cost' && (
                <div class="viz-pc">
                  <div class="viz-pc__num"><span class="viz-pc__big">60.0</span><span class="viz-pc__pct">%</span></div>
                  <div class="viz-pc__split">
                    <div class="viz-pc__row"><span>Food + bev</span><span class="num">30%</span></div>
                    <div class="viz-pc__row"><span>Labor</span><span class="num">30%</span></div>
                  </div>
                  <div class="viz-pc__bar"><span class="viz-pc__fill" style="width:60%"></span></div>
                </div>
              )}
              {c.viz === 'keg-cost' && (
                <div class="viz-kc">
                  <div class="viz-kc__num"><span class="viz-kc__big">22.0</span><span class="viz-kc__pct">%</span></div>
                  <div class="viz-kc__split">
                    <div class="viz-kc__row"><span>Cost / pour</span><span class="num">$1.54</span></div>
                    <div class="viz-kc__row"><span>Pours / keg</span><span class="num">117</span></div>
                  </div>
                  <div class="viz-kc__bar"><span class="viz-kc__fill" style="width:44%"></span></div>
                </div>
              )}
              {c.viz === 'no-show' && (
                <div class="viz-ns">
                  <div class="viz-ns__num"><span class="viz-ns__pct" aria-hidden="true">$</span><span class="viz-ns__big">3,225</span></div>
                  <div class="viz-ns__split">
                    <div class="viz-ns__row"><span>Lost / month</span><span class="num">8% rate</span></div>
                    <div class="viz-ns__row"><span>Deposit recovery</span><span class="num">$2,303</span></div>
                  </div>
                  <div class="viz-ns__bar"><span class="viz-ns__fill" style="width:71%"></span></div>
                </div>
              )}
              {c.viz === 'menu-eng' && (
                <div class="viz-me">
                  <div class="viz-me__matrix">
                    <span class="viz-me__quad viz-me__quad--puz">Puz</span>
                    <span class="viz-me__quad viz-me__quad--star">Star</span>
                    <span class="viz-me__quad viz-me__quad--dog">Dog</span>
                    <span class="viz-me__quad viz-me__quad--plow">Plow</span>
                    <span class="viz-me__dot" style="left:78%; top:22%"></span>
                    <span class="viz-me__dot" style="left:64%; top:36%"></span>
                    <span class="viz-me__dot viz-me__dot--plow" style="left:72%; top:78%"></span>
                    <span class="viz-me__dot viz-me__dot--puz" style="left:24%; top:30%"></span>
                    <span class="viz-me__dot viz-me__dot--dog" style="left:18%; top:80%"></span>
                  </div>
                </div>
              )}
              {c.viz === 'delivery' && (
                <div class="viz-dl">
                  <div class="viz-dl__num"><span class="viz-dl__pct" aria-hidden="true">$</span><span class="viz-dl__big">-0.62</span></div>
                  <div class="viz-dl__split">
                    <div class="viz-dl__row"><span>Subtotal</span><span class="num">$32.00</span></div>
                    <div class="viz-dl__row"><span>Platform take</span><span class="num">−32.9%</span></div>
                  </div>
                  <div class="viz-dl__bar"><span class="viz-dl__fill viz-dl__fill--bad" style="width:48%"></span></div>
                </div>
              )}
              {c.viz === 'catering' && (
                <div class="viz-ct">
                  <div class="viz-ct__num"><span class="viz-ct__pct" aria-hidden="true">$</span><span class="viz-ct__big">48.62</span><span class="viz-ct__suffix">/head</span></div>
                  <div class="viz-ct__split">
                    <div class="viz-ct__row"><span>Operator margin</span><span class="num">25.0%</span></div>
                    <div class="viz-ct__row"><span>50 guests</span><span class="num">$2,364</span></div>
                  </div>
                  <div class="viz-ct__bar"><span class="viz-ct__fill" style="width:62%"></span></div>
                </div>
              )}
              {c.viz === 'turnover' && (
                <div class="viz-tc">
                  <div class="viz-tc__num"><span class="viz-tc__pct" aria-hidden="true">$</span><span class="viz-tc__big">114K</span></div>
                  <div class="viz-tc__split">
                    <div class="viz-tc__row"><span>75% turnover</span><span class="num">25 staff</span></div>
                    <div class="viz-tc__row"><span>per hire</span><span class="num">$5,500</span></div>
                  </div>
                  <div class="viz-tc__bar"><span class="viz-tc__fill viz-tc__fill--watch" style="width:55%"></span></div>
                </div>
              )}
              {c.viz === 'fountain' && (
                <div class="viz-fn">
                  <div class="viz-fn__num"><span class="viz-fn__big">16.1</span><span class="viz-fn__pct">%</span></div>
                  <div class="viz-fn__split">
                    <div class="viz-fn__row"><span>Pours / BIB</span><span class="num">342</span></div>
                    <div class="viz-fn__row"><span>Profit / BIB</span><span class="num">$715</span></div>
                  </div>
                  <div class="viz-fn__bar"><span class="viz-fn__fill" style="width:54%"></span></div>
                </div>
              )}
            </div>

            <p class="tool-card__desc">{c.desc}</p>
            <div class="tool-card__footer">
              <span class="t-micro tool-card__time"><strong class="tool-card__free">Free</strong> · {c.time}</span>
              <span class="tool-card__arrow" aria-hidden="true">→</span>
