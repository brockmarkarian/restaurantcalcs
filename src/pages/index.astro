  /* ============================
     TOOL CARD MINI VIZ, recessed LCD screen
     ============================ */
  .tool-viz {
    background:
      radial-gradient(ellipse at center, #2a2620 0%, #1a1814 100%);
    border: 1px solid #0a0907;
    border-radius: 8px;
    box-shadow:
      inset 0 2px 4px rgba(0, 0, 0, 0.6),
      inset 0 0 30px rgba(200, 117, 0, 0.06),
      inset 0 -1px 0 rgba(255, 255, 255, 0.03),
      0 1px 0 rgba(255, 255, 255, 0.5);
    padding: var(--space-4);
    margin: var(--space-3) 0 var(--space-5);
    min-height: 92px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-2);
    transition: var(--transition-fast);
    position: relative;
    overflow: hidden;
  }
  .tool-viz::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(0deg, rgba(255, 200, 100, 0.025) 0, rgba(255, 200, 100, 0.025) 1px, transparent 1px, transparent 3px);
    pointer-events: none;
  }
  .tool-card:hover .tool-viz {
    box-shadow:
      inset 0 2px 4px rgba(0, 0, 0, 0.6),
      inset 0 0 40px rgba(200, 117, 0, 0.12),
      inset 0 -1px 0 rgba(255, 255, 255, 0.03),
      0 1px 0 rgba(255, 255, 255, 0.5);
  }
  .tool-viz .num { font-family: var(--font-mono); font-variant-numeric: tabular-nums; font-feature-settings: "tnum"; }
  /* LCD-amber palette overrides for viz interiors */
  .tool-viz, .tool-viz * { color: #f5b94a !important; }
  .tool-viz .num strong { color: #fcd87a !important; }

  /* food-cost: percentage + benchmark bar */
  .viz-fc__num { display: flex; align-items: baseline; gap: 2px; color: var(--color-saffron-text); }
  .viz-fc__big { font-family: var(--font-mono); font-variant-numeric: tabular-nums; font-size: 1.875rem; font-weight: 500; line-height: 1; letter-spacing: -0.02em; }
  .viz-fc__pct { font-family: var(--font-mono); font-size: 1.125rem; font-weight: 500; }
  .viz-fc__bar { position: relative; height: 6px; background: var(--color-cream); border-radius: 999px; overflow: hidden; }
  .viz-fc__zone { position: absolute; top: 0; bottom: 0; }
  .viz-fc__zone--good { left: 56%; width: 8%; background: rgba(74, 88, 38, 0.45); }
  .viz-fc__zone--watch { left: 64%; width: 8%; background: rgba(200, 117, 0, 0.40); }
  .viz-fc__zone--bad { left: 72%; width: 28%; background: rgba(192, 57, 43, 0.30); }
  .viz-fc__marker { position: absolute; left: 56.8%; top: -2px; bottom: -2px; width: 3px; background: var(--color-saffron-cta); border-radius: 2px; }
  .viz-fc__label { display: flex; justify-content: space-between; font-family: var(--font-body); font-size: 0.6875rem; color: var(--color-muted); }

  /* recipe-cost: ingredient stack */
  .viz-rc { display: flex; flex-direction: column; gap: 4px; }
  .viz-rc__row, .viz-rc__total { display: flex; justify-content: space-between; font-family: var(--font-body); font-size: 0.75rem; color: var(--color-body); }
  .viz-rc__row .num { color: var(--color-heading); font-size: 0.75rem; }
  .viz-rc__total { padding-top: 4px; margin-top: 2px; border-top: 1px solid var(--color-border); font-weight: 600; color: var(--color-heading); }
  .viz-rc__total .num { color: var(--color-saffron-text); font-size: 0.9375rem; }

  /* labor-cost: % + SPLH + bar */
  .viz-lc { display: flex; flex-direction: column; gap: 6px; }
  .viz-lc__num { display: flex; align-items: baseline; gap: 2px; color: var(--color-saffron-text); }
  .viz-lc__big { font-family: var(--font-mono); font-variant-numeric: tabular-nums; font-size: 1.75rem; font-weight: 500; line-height: 1; letter-spacing: -0.02em; }
  .viz-lc__pct { font-family: var(--font-mono); font-size: 1rem; font-weight: 500; }
  .viz-lc__splh { display: flex; justify-content: space-between; align-items: baseline; font-size: 0.75rem; color: var(--color-body); }
  .viz-lc__splh .num { color: var(--color-heading); font-weight: 500; }
  .viz-lc__bar { height: 4px; background: var(--color-cream); border-radius: 999px; overflow: hidden; }
  .viz-lc__fill { display: block; width: 60%; height: 100%; background: linear-gradient(90deg, rgba(200, 117, 0, 0.7), var(--color-saffron-cta)); border-radius: 999px; }

  /* tip-pool: split bars */
  .viz-tp { display: flex; flex-direction: column; gap: 6px; }
  .viz-tp__row { display: grid; grid-template-columns: 60px 1fr 44px; align-items: center; gap: 8px; font-family: var(--font-body); font-size: 0.6875rem; color: var(--color-body); }
  .viz-tp__row .num { font-size: 0.6875rem; color: var(--color-saffron-text); font-weight: 600; text-align: right; }
