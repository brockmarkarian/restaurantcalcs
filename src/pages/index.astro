    transition: transform 220ms var(--ease-out), box-shadow 220ms var(--ease-out), border-color 220ms var(--ease-out);
    color: inherit;
    min-height: 260px;
    position: relative;
    cursor: pointer;
  }
  .tool-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-saffron);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.85),
      inset 0 -2px 0 rgba(150, 130, 95, 0.18),
      0 4px 8px rgba(60, 50, 40, 0.10),
      0 20px 36px rgba(60, 50, 40, 0.14),
      0 40px 80px -16px rgba(200, 117, 0, 0.30);
  }
  .tool-card:active {
    transform: translateY(-1px);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.85),
      inset 0 -2px 0 rgba(150, 130, 95, 0.18),
      0 2px 4px rgba(60, 50, 40, 0.08),
      0 8px 16px rgba(60, 50, 40, 0.10);
  }
  .tool-card::before {
    content: '';
    position: absolute;
    top: 14px;
    right: 14px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, var(--color-saffron), var(--color-saffron-text));
    box-shadow: 0 0 6px var(--alpha-saffron-glow-strong), inset 0 -1px 1px rgba(0, 0, 0, 0.3);
    z-index: 2;
  }

  @media (max-width: 1024px) {
    .tools__grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 800px) {
    .tools__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 540px) {
    .tools__grid { grid-template-columns: 1fr; gap: var(--space-3); }
  }

  .tool-card:hover {
    border-color: var(--color-saffron);
    box-shadow: var(--shadow-lift);
    transform: translateY(-3px);
  }

  .tool-card__top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-3);
    padding-right: 18px;
