  .viz-lp__body { position: relative; flex: 1; width: 26px; background: linear-gradient(180deg, transparent 18%, rgba(200, 117, 0, 0.38) 18%, rgba(200, 117, 0, 0.55) 100%); border: 1.5px solid var(--color-saffron-text); border-top: none; border-radius: 0 0 4px 4px; }
  .viz-lp__label { position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%) rotate(-90deg); font-family: var(--font-mono); font-size: 0.5625rem; color: var(--color-white); letter-spacing: 0.05em; }
  .viz-lp__stat { display: flex; flex-direction: column; gap: 4px; }
