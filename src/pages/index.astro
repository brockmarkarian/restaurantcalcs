  .viz-lp__stat .num { color: var(--color-heading); font-weight: 500; font-size: 0.875rem; }
  .viz-lp__pct { color: var(--color-saffron-text) !important; }

  /* break-even: covers + bar */
  .viz-be { display: flex; flex-direction: column; gap: 6px; }
  .viz-be__num { display: flex; align-items: baseline; gap: 6px; }
  .viz-be__big { font-family: var(--font-mono); font-variant-numeric: tabular-nums; font-size: 1.75rem; font-weight: 500; color: var(--color-saffron-text); line-height: 1; letter-spacing: -0.02em; }
  .viz-be__unit { font-family: var(--font-body); font-size: 0.75rem; color: var(--color-body); }
  .viz-be__bar { position: relative; height: 6px; background: var(--color-cream); border-radius: 999px; overflow: visible; }
  .viz-be__fill { display: block; height: 100%; background: rgba(74, 88, 38, 0.4); border-radius: 999px; }
  .viz-be__marker { position: absolute; top: -3px; bottom: -3px; width: 3px; background: var(--color-saffron-cta); border-radius: 2px; }
  .viz-be__label { display: flex; justify-content: space-between; font-family: var(--font-body); font-size: 0.6875rem; color: var(--color-muted); }

  /* inventory-variance: theory vs actual */
  .viz-iv { display: flex; flex-direction: column; gap: 4px; }
  .viz-iv__row { display: flex; justify-content: space-between; align-items: baseline; font-family: var(--font-body); font-size: 0.75rem; color: var(--color-body); }
