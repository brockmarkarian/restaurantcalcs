---
import Layout from '../layouts/Layout.astro';

const title = 'Contact RestaurantCalcs — Calculator Feedback & Press Inquiries';
const description = 'Email RestaurantCalcs for calculator suggestions, formula corrections, press inquiries, partnerships, or operator feedback. Real replies within 1-2 days.';

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    '@id': 'https://restaurantcalcs.com/contact/#webpage',
    url: 'https://restaurantcalcs.com/contact/',
    name: title,
    description,
    isPartOf: { '@id': 'https://restaurantcalcs.com/#website' },
    inLanguage: 'en-US',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://restaurantcalcs.com/' },
      { '@type': 'ListItem', position: 2, name: 'Contact', item: 'https://restaurantcalcs.com/contact/' },
    ],
  },
];
---

<Layout {title} {description} {schema}>
  <article class="contact-page">
    <header class="contact-page__header">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <span>Contact</span>
      </nav>
      <p class="t-micro t-micro--saffron">Contact</p>
      <h1 class="contact-page__title">Get in touch.</h1>
      <p class="contact-page__lede">
        Questions, feedback, calculator requests, formula corrections, partnership inquiries — email is the fastest way to reach us.
      </p>
    </header>

    <section class="contact-page__body">
      <div class="contact-card">
        <h2>Email</h2>
        <p>
          <a href="mailto:hello@restaurantcalcs.com" class="contact-email">hello@restaurantcalcs.com</a>
        </p>
        <p class="t-caption">We aim to reply within 1–2 business days.</p>
      </div>

      <h2>What to email about</h2>
      <ul>
        <li><strong>Calculator suggestions.</strong> Tell us what restaurant math you wish was free + simple. We're adding calculators based on operator demand.</li>
        <li><strong>Formula corrections.</strong> If a formula or benchmark looks wrong, send the source. We audit every calc against authoritative industry references like the <a href="https://restaurant.org/research-and-media/research/economists-notebook/" target="_blank" rel="noopener nofollow">National Restaurant Association</a> and the <a href="https://www.dol.gov/agencies/whd/flsa/tips" target="_blank" rel="noopener nofollow">U.S. Department of Labor</a>, and update when corrections are warranted.</li>
        <li><strong>Bug reports.</strong> Wrong number, layout break, or broken link — describe the page, browser, and what you saw.</li>
        <li><strong>Press / partnership.</strong> Editorial features, integrations, content collaboration.</li>
        <li><strong>General feedback.</strong> What's working, what's not, what's missing.</li>
      </ul>

      <h2>What we don't do</h2>
      <ul>
        <li>Custom calculator builds for individual operators</li>
        <li>Restaurant consulting or operations advisory</li>
        <li>POS integrations (use <a href="https://pos.toasttab.com/" target="_blank" rel="noopener nofollow">Toast</a> or <a href="https://www.restaurant365.com/" target="_blank" rel="noopener nofollow">Restaurant365</a> for that)</li>
        <li>Reply to sales pitches for SEO services, link-building, AI content tools, or marketing agencies</li>
      </ul>
    </section>
  </article>
</Layout>

<style>
  .contact-page { max-width: 760px; margin: 0 auto; padding: var(--space-12) var(--space-6) var(--space-24); }
  .breadcrumb { display: flex; align-items: center; gap: var(--space-2); font-family: var(--font-body); font-size: 0.8125rem; color: var(--color-muted); margin-bottom: var(--space-8); }
  .breadcrumb a { color: var(--color-muted); transition: color var(--transition-fast); }
  .breadcrumb a:hover { color: var(--color-saffron-text); }
  .contact-page__header { margin-bottom: var(--space-10); }
  .contact-page__title { font-family: var(--font-display); font-variation-settings: "opsz" 96, "wdth" 95; font-size: clamp(2.5rem, 5vw + 0.5rem, 4rem); font-weight: 500; line-height: 1.05; letter-spacing: -0.02em; color: var(--color-heading); margin: var(--space-4) 0 var(--space-5); }
  .contact-page__lede { font-family: var(--font-body); font-size: 1.125rem; line-height: 1.55; color: var(--color-body); max-width: 60ch; }

  .contact-card { padding: var(--space-6) var(--space-7); background: var(--color-saffron-light); border: 1px solid var(--color-saffron); border-radius: var(--radius-lg); margin-bottom: var(--space-12); }
  .contact-card h2 { font-family: var(--font-display); font-variation-settings: "opsz" 36, "wdth" 100; font-size: 1.25rem; font-weight: 500; color: var(--color-heading); margin-bottom: var(--space-3); }
  .contact-card p { margin-bottom: var(--space-2); font-family: var(--font-body); font-size: 1rem; }
  .contact-email { font-family: var(--font-mono); font-size: 1.25rem; font-weight: 500; color: var(--color-saffron-text); text-decoration: underline; text-underline-offset: 4px; }
  .contact-email:hover { color: var(--color-saffron-hover); }

  .contact-page__body h2 { font-family: var(--font-display); font-variation-settings: "opsz" 36, "wdth" 100; font-size: 1.5rem; font-weight: 500; color: var(--color-heading); margin-top: var(--space-10); margin-bottom: var(--space-4); }
  .contact-page__body h2:first-of-type { margin-top: 0; }
  .contact-page__body ul { list-style: none; padding: 0; margin: 0 0 var(--space-5) 0; display: flex; flex-direction: column; gap: var(--space-3); }
  .contact-page__body li { font-family: var(--font-body); font-size: 1rem; line-height: 1.55; color: var(--color-body); padding-left: var(--space-5); position: relative; }
  .contact-page__body li::before { content: '·'; position: absolute; left: 6px; color: var(--color-saffron); font-weight: 700; font-size: 1.5rem; line-height: 1; }
  .contact-page__body strong { color: var(--color-heading); font-weight: 600; }
</style>
