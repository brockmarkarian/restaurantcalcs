---
import Layout from '../../layouts/Layout.astro';

const title = 'Fountain Drink / BIB Cost Calculator, Free | RestaurantCalcs';
const description = 'Free fountain drink and BIB (bag-in-box) cost calculator. Pour cost % accounting for ice fill, cup, CO2, and free refills. Industry healthy 8–15%. Math shown.';

const faq = [
  {
    q: 'How do you calculate fountain drink cost?',
    a: 'Multiply syrup volume by (1 + mix ratio) to get finished beverage. Subtract ice fill from pour size to get effective beverage per cup. BIB price ÷ finished oz × effective pour = syrup cost. Add cup, lid, straw, and CO2. If you offer free refills, multiply by your refill multiplier (industry default 1.4 per BinWise).',
  },
  {
    q: 'What is a BIB and how much does it yield?',
    a: 'A BIB is a bag-in-box of soda syrup. Standard is 5 gallons (640 oz) of concentrated syrup. At a 5:1 mix ratio that is 3,840 oz of finished drink, or about 342 sixteen-ounce pours after a 30% ice fill (Coca-Cola Foodservice). Branded cola BIBs run $80–95. Store-brand or proprietary syrups can run $35–50 for the same volume.',
  },
  {
    q: 'What is the mix ratio for fountain syrup?',
    a: 'Industry standard is 5:1 (five parts carbonated water to one part syrup). Diet drinks and sparkling waters often run 4:1. Some specialty syrups go 6:1. The mix ratio determines how much finished drink you get from a BIB, so a wrong ratio setting on the dispenser quietly costs or gives away product on every pour.',
  },
  {
    q: 'How does ice affect fountain drink cost?',
    a: 'Ice displaces beverage. A 16 oz cup with 30% ice fill holds 11.2 oz of liquid, not 16. That sounds like good news for cost. It is, until the customer comes back for a free refill on a cup that holds 11.2 oz of soda not 16. Ice fill is the input most operators forget to adjust when they bump cup size.',
  },
  {
    q: 'Should I offer free refills?',
    a: 'Depends on the concept. Family casual? Often yes, it is a competitive expectation. The industry rule of thumb is 1.4 pours per visit when refills are free (BinWise). That is 40% more cost on every drink. The fix is rarely cutting refills entirely. It is pricing the menu like the math actually is. A one-refill cap drops the multiplier closer to 1.1 and recovers most of it.',
  },
  {
    q: 'What is a healthy fountain drink pour cost?',
    a: '8–15% on small to medium drinks (Toast, BinWise). Drops to 4–8% on large 32 oz pours because cup and CO2 cost stay flat while menu price scales up. Free refills add 35–50% to whatever number you started with. If you are running over 22% on fountain, something is wrong with cup cost, mix ratio, or you are running a 24 oz mega at $1.99.',
  },
  {
    q: 'How much does the cup cost on a fountain drink?',
    a: 'Roughly $0.08 to $0.30 depending on size and material. A 16 oz kraft paper cup with lid and straw is around $0.18. A 24 oz compostable PLA cup with biodegradable lid and paper straw can run $0.30+. Cup cost is often a higher line item than the syrup itself on small drinks. Switching to compostable without re-pricing the menu can move pour cost 4 points overnight.',
  },
  {
    q: "What's the difference between branded and store-brand BIBs?",
    a: 'Branded (Coke, Pepsi) BIBs run $80–95 for 5 gallons. Store-brand or proprietary equivalents run $35–50. Same yield, similar pour size. Customer satisfaction in blind taste tests on a 30% ice 16 oz pour is basically a coin flip on most colas. The contract obligation is usually the bigger constraint than the taste delta.',
  },
  {
    q: 'Should fountain drinks be a profit center or loss leader?',
    a: 'Profit center, almost always. Fountain has the highest margin of anything on the menu when you model it correctly (NRA). A $3.49 fountain at 12% pour cost has the same dollar profit as a $14 entree at 32% food cost. The trap is treating the fountain as a "throw-in" to support food sales. The math says it should be the highest-margin item on the ticket.',
  },
  {
    q: 'Does this calculator save my data?',
    a: 'No. Nothing is stored, transmitted, or tracked. Math runs in your browser and disappears the moment you close the tab. No signup, no email, no account.',
  },
];

const benchmarks = [
  { name: '12 oz small', low: 4, high: 7 },
  { name: '16 oz medium', low: 6, high: 10 },
  { name: '20 oz large', low: 8, high: 12 },
  { name: '24 oz extra-large', low: 10, high: 14 },
  { name: '32 oz mega', low: 13, high: 18 },
];

const scenarios = [
  {
    title: 'The "free refills" margin killer',
    setup: 'Family casual concept, 24 oz pour, free refills standard. Owner had been quoting $0.12 cost per drink to staff during onboarding for two years. Used that number to build menu pricing.',
    diagnosis: 'Real cost: $0.31 per customer. Branded BIB at $90, 5:1 mix, 30% ice fill, $0.21 compostable cup, and a 1.4× refill multiplier (BinWise). The operator was modeling a single pour and ignoring the refill behavior. Across 180 fountain drinks per day that is $34/day extra cost, roughly $12K/year of margin he thought he had.',
    fix: 'Switched to a one-refill-cap policy. Refill multiplier dropped from 1.4 to 1.1. Staff trained to ask once, not pour twice. Menu held at $3.49.',
    outcome: 'Pour cost dropped from 18% to 13% on the 24 oz. Recovered roughly $9K/year on the cap alone. No customer pushback worth tracking. The "all you can drink" framing was costing more than it was loyalty-building.',
  },
  {
    title: 'The branded vs store-brand swap',
    setup: '12-tap fountain at a fast-casual concept. Running branded cola BIBs at $90 per unit. Pour cost on the 16 oz cola line running 8%, healthy on paper but cup costs were creeping up.',
    diagnosis: 'Switched the cola line to a store-brand equivalent at $40 per BIB. Same mix ratio, same yield (Coca-Cola Foodservice yield reference applies regardless of label). Pour cost dropped from 8% to 4% on the cola tap. Other taps unchanged.',
    fix: 'Ran a four-week blind comparison with regulars before committing. Two voted branded preferred, three voted store-brand preferred, the rest could not tell. No menu price change.',
    outcome: 'About $14K/year saved on a single drink line. The contract had a 90-day exit clause nobody had read. The fountain was the highest-margin item on the menu before the swap. After the swap, it was not even close.',
  },
  {
    title: 'The cup cost ambush',
    setup: 'Operator switched all cups to compostable PLA after a sustainability push. Small cup went from $0.08 kraft paper to $0.21 compostable. Same menu price. Same pour size.',
    diagnosis: 'Pour cost % on the small fountain jumped 4 points overnight. Owner spent six weeks blaming the BIB distributor for a cost increase. Distributor invoices had not changed. The cups had. Cup cost on a small drink is often a bigger line than the syrup.',
    fix: 'Reverted small cups to kraft paper at $0.08. Kept compostable on the flagship 24 oz where the cup is a visible brand signal and a higher menu price absorbs the cost.',
    outcome: 'Small cup pour cost back to 6%. The flagship 24 oz absorbed the compostable premium without breaking the band. Sustainability story preserved on the cup the customer photographs. The cup the customer drinks coffee out of at 7am went back to being cheap.',
  },
];

const relatedCalcs = [
  { slug: 'liquor-pour-cost', title: 'Liquor Pour Cost', desc: 'Companion calc for spirits and cocktails.' },
  { slug: 'keg-cost', title: 'Draft Beer / Keg Cost', desc: 'Draft beer pour cost and keg yield.' },
  { slug: 'menu-pricing', title: 'Menu Pricing', desc: 'Uses pour cost output to set drink prices.' },
];

const schema = [
  { '@context': 'https://schema.org', '@type': 'WebPage', '@id': 'https://restaurantcalcs.com/calculators/fountain-cost/#webpage', url: 'https://restaurantcalcs.com/calculators/fountain-cost/', name: title, description, isPartOf: { '@id': 'https://restaurantcalcs.com/#website' }, breadcrumb: { '@id': 'https://restaurantcalcs.com/calculators/fountain-cost/#breadcrumb' }, inLanguage: 'en-US' },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', '@id': 'https://restaurantcalcs.com/calculators/fountain-cost/#breadcrumb', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://restaurantcalcs.com/' },
    { '@type': 'ListItem', position: 2, name: 'Calculators', item: 'https://restaurantcalcs.com/calculators/' },
    { '@type': 'ListItem', position: 3, name: 'Fountain Drink / BIB Cost', item: 'https://restaurantcalcs.com/calculators/fountain-cost/' },
  ] },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    '@id': 'https://restaurantcalcs.com/calculators/fountain-cost/#tool',
    name: 'Fountain Drink / BIB Cost Calculator',
    description: 'Free web-based fountain drink BIB cost calculator. Pour cost % accounting for mix ratio, ice fill, cup cost, CO2, and free-refill multiplier.',
    applicationCategory: 'BusinessApplication',
    applicationSubCategory: 'Restaurant Management',
    operatingSystem: 'Web',
    browserRequirements: 'Requires JavaScript',
    url: 'https://restaurantcalcs.com/calculators/fountain-cost/',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    creator: { '@id': 'https://restaurantcalcs.com/#organization' },
    author: { '@id': 'https://restaurantcalcs.com/#founder' },
    isAccessibleForFree: true,
  },
  { '@context': 'https://schema.org', '@type': 'HowTo', name: 'How to calculate fountain drink pour cost', totalTime: 'PT2M', supply: [
    { '@type': 'HowToSupply', name: 'BIB syrup volume in ounces (5 gal = 640 oz)' },
    { '@type': 'HowToSupply', name: 'BIB purchase price (in dollars)' },
    { '@type': 'HowToSupply', name: 'Mix ratio (water:syrup, default 5:1)' },
    { '@type': 'HowToSupply', name: 'Pour size in ounces (16 oz typical)' },
    { '@type': 'HowToSupply', name: 'Ice fill percentage (30% typical)' },
    { '@type': 'HowToSupply', name: 'Cup, lid, straw cost (in dollars)' },
    { '@type': 'HowToSupply', name: 'CO2 cost per pour (in dollars)' },
    { '@type': 'HowToSupply', name: 'Menu price per drink (in dollars)' },
    { '@type': 'HowToSupply', name: 'Free-refill multiplier (default 1.4)' },
  ], step: [
    { '@type': 'HowToStep', position: 1, name: 'Calculate finished beverage volume', text: 'Multiply syrup volume by (1 + mix ratio). 640 oz × 6 = 3,840 oz at 5:1.' },
    { '@type': 'HowToStep', position: 2, name: 'Calculate effective pour size', text: 'Pour size × (1 − ice fill %). 16 oz × 0.70 = 11.2 oz of beverage in a 16 oz cup at 30% ice.' },
    { '@type': 'HowToStep', position: 3, name: 'Calculate syrup cost per pour', text: 'BIB price ÷ finished oz × effective pour. $90 ÷ 3,840 × 11.2 = $0.26 of syrup.' },
    { '@type': 'HowToStep', position: 4, name: 'Add cup and CO2', text: 'Add cup/lid/straw cost and CO2 per pour. Single-pour total cost.' },
    { '@type': 'HowToStep', position: 5, name: 'Apply refill multiplier', text: 'Multiply by 1.4 if refills are free. That is the real cost per customer.' },
    { '@type': 'HowToStep', position: 6, name: 'Calculate pour cost percentage', text: 'Total cost per customer ÷ menu price × 100 = pour cost %.' },
  ] },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
];
---

<Layout {title} {description} {schema}>
  <article class="calc-page">
    <header class="calc-page__header">
      <nav class="breadcrumb" aria-label="Breadcrumb"><a href="/">Home</a><span aria-hidden="true">/</span><a href="/calculators/">Calculators</a><span aria-hidden="true">/</span><span>Fountain Drink Cost</span></nav>
      <p class="t-micro t-micro--saffron calc-page__eyebrow">Fountain drink calculator · <strong>100% free · no signup</strong></p>
      <h1 class="calc-page__title">Fountain Drink / BIB Cost Calculator</h1>
      <p class="calc-page__intro">
        Real cost per fountain drink, accounting for mix ratio, ice fill, cup, CO2, and free refills. Healthy pour cost is <strong>8–15%</strong> on small drinks, dropping to <strong>4–8%</strong> on large (Toast, BinWise). Most operators undercount this number by 2–4 points because they ignore the refill multiplier.
      </p>
    </header>

    <section class="calc-grid">
      <form class="calc-form" data-form>
        <div class="form-intro">
          <p class="form-intro__what"><strong>What this does:</strong> Calculates real cost per fountain drink, including ice displacement, cup, CO2, and free refills. Returns pour cost % vs industry benchmarks plus per-BIB profit.</p>
          <button type="button" class="form-intro__example" data-load-example>Try with example numbers</button>
        </div>

        <div class="form-row">
          <label class="form-row__label" for="bib-volume">How much syrup is in the box?</label>
          <div class="input-shell">
            <input id="bib-volume" name="bib-volume" type="number" inputmode="decimal" min="0" step="32" placeholder="640" autocomplete="off" required />
            <span class="input-shell__suffix">oz</span>
          </div>
          <p class="form-row__hint">A bag-in-box of soda syrup. The standard 5-gallon box is 640 oz. A 2.5-gallon box is 320 oz, a 3-gallon box is 384 oz.</p>
        </div>

        <div class="form-row">
          <label class="form-row__label" for="bib-price">What did the box cost you?</label>
          <div class="input-shell">
            <span class="input-shell__prefix">$</span>
            <input id="bib-price" name="bib-price" type="number" inputmode="decimal" min="0" step="5" placeholder="90" autocomplete="off" required />
          </div>
          <p class="form-row__hint">What you paid for the box of syrup. Name-brand cola (Coke, Pepsi) usually runs $80 to $95. Store-brand syrup runs $35 to $50.</p>
        </div>

        <div class="form-row">
          <label class="form-row__label" for="mix-ratio">How much water gets mixed with the syrup?</label>
          <select id="mix-ratio" name="mix-ratio">
            <option value="5" selected>5 parts water to 1 part syrup (the usual, most colas)</option>
            <option value="4">4 parts water to 1 part syrup (diet, sparkling, some specialty)</option>
            <option value="6">6 parts water to 1 part syrup (a few specialty syrups)</option>
            <option value="3">3 parts water to 1 part syrup (juice concentrates)</option>
          </select>
          <p class="form-row__hint">This is how much finished drink you get from the syrup. The usual setting (5 to 1) means 1 oz of syrup makes 6 oz of drink: 5 oz water plus 1 oz syrup. The dispenser is set to one of these.</p>
        </div>

        <div class="form-row">
          <label class="form-row__label" for="pour-size">What size cup do you serve?</label>
          <select id="pour-size" name="pour-size">
            <option value="12">12 oz small</option>
            <option value="16" selected>16 oz medium (standard)</option>
            <option value="20">20 oz large</option>
            <option value="24">24 oz extra-large</option>
            <option value="32">32 oz mega</option>
            <option value="custom">Other size</option>
          </select>
          <p class="form-row__hint">The size of the cup, not the amount of soda in it. We take ice out of that next.</p>
        </div>

        <div class="form-row" id="custom-pour-row" style="display:none">
          <label class="form-row__label" for="pour-size-custom">Your cup size (oz)</label>
          <div class="input-shell">
            <input id="pour-size-custom" name="pour-size-custom" type="number" inputmode="decimal" min="1" step="0.5" placeholder="44" autocomplete="off" />
            <span class="input-shell__suffix">oz</span>
          </div>
          <p class="form-row__hint">Enter the cup size in ounces.</p>
        </div>

        <div class="form-row">
          <label class="form-row__label" for="ice-fill">How much of the cup is ice?</label>
          <div class="input-shell">
            <input id="ice-fill" name="ice-fill" type="number" inputmode="decimal" min="0" max="80" step="5" placeholder="30" autocomplete="off" />
            <span class="input-shell__suffix">%</span>
          </div>
          <p class="form-row__hint">Most cups are about 30% ice. Drive-through cups are often 40% or more. Ice takes the place of soda, so a cup with more ice uses less syrup per drink.</p>
        </div>

        <div class="form-row">
          <label class="form-row__label" for="cup-cost">What does the cup, lid, and straw cost?</label>
          <div class="input-shell">
            <span class="input-shell__prefix">$</span>
            <input id="cup-cost" name="cup-cost" type="number" inputmode="decimal" min="0" step="0.01" placeholder="0.18" autocomplete="off" />
          </div>
          <p class="form-row__hint">Add up the cup, lid, and straw for one drink. Usually $0.08 (small paper) to $0.30 (large eco-friendly). On small drinks this often costs more than the soda itself.</p>
        </div>

        <div class="form-row">
          <label class="form-row__label" for="co2-cost">What does the fizz (CO2) cost per drink?</label>
          <div class="input-shell">
            <span class="input-shell__prefix">$</span>
            <input id="co2-cost" name="co2-cost" type="number" inputmode="decimal" min="0" step="0.005" placeholder="0.01" autocomplete="off" />
          </div>
          <p class="form-row__hint">The gas that carbonates the soda. About $0.01 per drink for tank rental plus gas. Bulk systems cost less. If you are not sure, leave the example number.</p>
        </div>

        <div class="form-row">
          <label class="form-row__label" for="menu-price">What do you charge for the drink?</label>
          <div class="input-shell">
            <span class="input-shell__prefix">$</span>
            <input id="menu-price" name="menu-price" type="number" inputmode="decimal" min="0" step="0.10" placeholder="3.49" autocomplete="off" required />
          </div>
          <p class="form-row__hint">The menu price before tax for one drink this size.</p>
        </div>

        <div class="form-row">
          <label class="form-row__label" for="refill-mult">If refills are free, how many drinks does one customer really get?</label>
          <div class="input-shell">
            <input id="refill-mult" name="refill-mult" type="number" inputmode="decimal" min="1" max="3" step="0.1" placeholder="1.4" autocomplete="off" />
            <span class="input-shell__suffix">×</span>
          </div>
          <p class="form-row__hint">When refills are free, the average customer drinks about 1.4 cups, not 1 (BinWise). Use 1.0 for no refills, 1.1 if you cap it at one refill.</p>
        </div>

        <p class="calc-form__live">
          <span class="calc-form__live-dot" aria-hidden="true"></span>
          Updates live as you type. <strong>Nothing is saved or sent</strong>, the math runs in your browser.
        </p>
      </form>

      <aside class="calc-result">
        <div class="calc-result__card" aria-live="polite" aria-atomic="true">
          <div class="calc-result__head">
            <span class="t-micro calc-result__label">What the drink costs you</span>
            <span class="status-pill" data-status="empty">
              <span class="status-pill__dot"></span><span data-status-label>Enter values</span>
            </span>
          </div>

          <div class="calc-result__big">
            <span class="result-num" data-counter>0.0</span>
            <span class="result-num__pct" aria-hidden="true">%</span>
            <span class="visually-hidden">percent fountain pour cost</span>
          </div>

          <div class="calc-result__benchmark">
            <span class="t-caption">Industry healthy range</span>
            <span class="t-caption num" data-bench>5–15%</span>
          </div>

          <div class="calc-result__bar">
            <div class="bar-track">
              <div class="bar-zone bar-zone--lean"></div>
              <div class="bar-zone bar-zone--good"></div>
              <div class="bar-zone bar-zone--watch"></div>
              <div class="bar-zone bar-zone--bad"></div>
              <div class="bar-marker" data-marker style="left: 0%"></div>
            </div>
            <div class="bar-labels">
              <span class="t-caption num">0%</span>
              <span class="t-caption num">15%</span>
              <span class="t-caption num">30%</span>
            </div>
          </div>

          <div class="calc-result__extras">
            <div class="extras-row">
              <span class="extras-row__label">Drinks you can pour from one box</span>
              <span class="extras-row__value num" data-pours></span>
            </div>
            <div class="extras-row">
              <span class="extras-row__label">Customers served from one box</span>
              <span class="extras-row__value num" data-customers></span>
            </div>
            <div class="extras-row">
              <span class="extras-row__label">Cost of one cup of soda (syrup + fizz)</span>
              <span class="extras-row__value num" data-cost-pour></span>
            </div>
            <div class="extras-row">
              <span class="extras-row__label">Cost of the cup, lid, and straw</span>
              <span class="extras-row__value num" data-cup></span>
            </div>
            <div class="extras-row">
              <span class="extras-row__label">What one customer really costs you</span>
              <span class="extras-row__value num" data-total-customer></span>
            </div>
            <div class="extras-row">
              <span class="extras-row__label">Profit per customer</span>
              <span class="extras-row__value num" data-profit-customer></span>
            </div>
            <div class="extras-row">
              <span class="extras-row__label">Profit from one box of syrup</span>
              <span class="extras-row__value num" data-profit-bib></span>
            </div>
          </div>

          <button type="button" class="result-share" data-share-open aria-haspopup="dialog">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><path d="M8.6 13.5l6.8 4M15.4 6.5l-6.8 4"/></svg>
            Share these numbers
          </button>
        </div>

        <details class="show-math" data-math-wrap>
          <summary class="show-math__trigger">
            <span class="show-math__icon" aria-hidden="true">+</span>
            Show your math
          </summary>
          <div class="show-math__body" data-math>
            <p class="t-caption">Enter values above to see the calculation.</p>
          </div>
        </details>
      </aside>
    </section>

    <section class="essay">
      <img src="/illustrations/fountain-cost.webp" alt="Editorial illustration of a stainless soda fountain dispenser on a vintage diner counter, frosted plastic cup with ice and dark cola, condensation on the side, a cardboard bag-in-box reading 'syrup' tucked under the counter." class="operator-story__hero" width="1264" height="848" loading="lazy" />
      <p class="essay__eyebrow t-micro t-micro--saffron">Why this matters</p>
      <h2 class="essay__headline">Fountain is the highest-margin item on the menu. <em>If you actually model it.</em></h2>
      <div class="essay__body">
        <p>
          A 5-gallon BIB of branded cola at $90 yields 3,840 oz of finished drink at a 5:1 mix. At a 16 oz pour with 30% ice, that is roughly 342 fountain drinks per box. Sell them at $3.49 and the BIB generates about $1,193 in revenue. The syrup cost on each pour is about a quarter (Coca-Cola Foodservice yield reference). That is the kind of margin nothing else on the menu touches.
        </p>
        <p>
          Most operators ballpark fountain cost at $0.10–$0.25 and never run the actual stack. They miss the cup. They miss the CO2. They forget that ice fill is in the dispenser cup, not the BIB. And they almost always forget the free-refill multiplier. The industry rule of thumb is 1.4 pours per visit when refills are free (BinWise). On a 24 oz with a $0.21 compostable cup, that turns a "$0.12 drink" into a $0.31 drink. Two-to-four points of margin disappears on every ticket and the operator blames cup costs or the distributor.
        </p>
        <p class="essay__pull">
          Fountain is the operator's blind spot. The line item is small enough nobody flinches at it, and the math compounds quietly underneath until the year-end P&L looks worse than the weekly reports said it would.
        </p>
        <p>
          I ran the bar program at Cosmos Taverna for five years. We did not have a fountain. Sports bar, draft beer was the volume driver. But I have watched friends in fast-casual operate concepts where fountain was the single biggest profit line on the menu, and three of them undercosted it for years. Not because they were lazy. Because the line item was small and the math was non-obvious. Cup, ice, mix ratio, refills. Four variables, all moving, none of them on a normal P&L line.
        </p>
        <p>
          Run the actual stack. Cup cost is the thing that sneaks up on you, small kraft paper at $0.08 versus large compostable at $0.30 is not a small swap. Refill multiplier is the second one. If you offer free refills, you are not selling a 16 oz drink, you are selling a 22 oz drink and pricing it like a 16. The fix is rarely "kill free refills." The fix is pricing the menu like the math actually is. Most fountain pricing was set in 2017 and has not been re-run since cup costs went up in 2022. The number on the calculator does not lie. The discipline of running it once a quarter is the entire game.
        </p>
      </div>
    </section>

    <hr class="rule" aria-hidden="true" />

    <div class="container ad-wrap">
      <aside class="ad-inline">
        <span class="ad-inline__label">Advertisement</span>
        <div class="ad-inline__inner">
          <ins class="adsbygoogle"
               style="display:block"
               data-ad-client="ca-pub-6332696231897305"
               data-ad-slot="0000000000"
               data-ad-format="auto"
               data-full-width-responsive="true"
               data-adtest="on"></ins>
          <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
        </div>
      </aside>
    </div>

    <section class="benchmarks">
      <h2 class="benchmarks__headline">Pour cost benchmarks <em>by drink size</em></h2>
      <p class="t-body-large benchmarks__intro">
        Pour cost % drops as drink size grows because cup and CO2 cost stay roughly flat while menu price scales up. These ranges assume a $3.49 base menu price scaling with size, 30% ice fill, and no free refills. Add 35–50% on top for free refills (1.4× multiplier per BinWise).
      </p>
      <div class="benchmarks__chart">
        {benchmarks.map((b) => (
          <div class="bench-bar">
            <div class="bench-bar__name">{b.name}</div>
            <div class="bench-bar__track">
              <div class="bench-bar__zone" style={`left: ${b.low * 100 / 30}%; width: ${(b.high - b.low) * 100 / 30}%`}></div>
              <div class="bench-bar__tick" style={`left: ${b.low * 100 / 30}%`}></div>
              <div class="bench-bar__tick" style={`left: ${b.high * 100 / 30}%`}></div>
            </div>
            <div class="bench-bar__range num">{b.low}–{b.high}%</div>
          </div>
        ))}
        <div class="bench-axis">
          <div class="bench-axis__track">
            <span class="bench-axis__tick num" style="left: 0%">0%</span>
            <span class="bench-axis__tick num" style="left: 25%">7.5%</span>
            <span class="bench-axis__tick num" style="left: 50%">15%</span>
            <span class="bench-axis__tick num" style="left: 75%">22.5%</span>
            <span class="bench-axis__tick num" style="left: 100%">30%</span>
          </div>
        </div>
      </div>
    </section>

    <hr class="rule" aria-hidden="true" />

    <section class="scenarios">
      <p class="t-micro t-micro--saffron">Real scenarios</p>
      <h2 class="scenarios__headline">Three operators, three different fountain leaks</h2>
      <p class="t-body-large scenarios__intro">
        Same calculator, three different blind spots. The fix depends on which input you got wrong.
      </p>
      <div class="scenarios__grid">
        {scenarios.map((s, i) => (
          <article class="scenario-card">
            <span class="scenario-card__num num">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="scenario-card__title">{s.title}</h3>
            <p class="scenario-card__setup">{s.setup}</p>
            <div class="scenario-card__row"><span class="scenario-card__label">Diagnosis</span><p class="scenario-card__text">{s.diagnosis}</p></div>
            <div class="scenario-card__row"><span class="scenario-card__label">Fix</span><p class="scenario-card__text">{s.fix}</p></div>
            <div class="scenario-card__row scenario-card__row--outcome"><span class="scenario-card__label">Outcome</span><p class="scenario-card__text"><strong>{s.outcome}</strong></p></div>
          </article>
        ))}
      </div>
    </section>

    <hr class="rule" aria-hidden="true" />

    <section class="calc-faq">
      <p class="t-micro t-micro--saffron">FAQ</p>
      <h2 class="calc-faq__headline">Common questions</h2>
      {faq.map((f, i) => (
        <details class="calc-faq__item">
          <summary class="calc-faq__q">
            <span class="calc-faq__num">{String(i + 1).padStart(2, '0')}</span>
            <span class="calc-faq__qtext">{f.q}</span>
            <span class="calc-faq__plus" aria-hidden="true">+</span>
          </summary>
          <p class="calc-faq__a">{f.a}</p>
        </details>
      ))}
    </section>

    <section class="cited-sources">
      <p class="t-micro t-micro--saffron">Cited sources</p>
      <ul>
        <li><a href="https://restaurant.org/research-and-media/research/economists-notebook/" target="_blank" rel="noopener">National Restaurant Association, Beverage Profitability Trends</a></li>
        <li><a href="https://www.coca-colacompany.com/brands/foodservice" target="_blank" rel="noopener">Coca-Cola Foodservice, BIB Yield Calculations</a></li>
        <li><a href="https://home.binwise.com/blog/pour-cost" target="_blank" rel="noopener">BinWise, Beverage Cost Management</a></li>
        <li><a href="https://pos.toasttab.com/blog/on-the-line/bar-profitability" target="_blank" rel="noopener">Toast, Bar &amp; Beverage Profitability Guide</a></li>
      </ul>
    </section>

    <section class="related">
      <h2 class="related__headline">Related calculators</h2>
      <div class="related__grid">
        {relatedCalcs.map((c, i) => (
          <a href={`/calculators/${c.slug}/`} class="related-card">
            <div class="related-card__top">
              <span class="related-card__num num">{String(i + 1).padStart(2, '0')}</span>
              <span class="t-micro"><strong style="color:var(--color-saffron-text)">Free</strong> · 2 min</span>
            </div>
            <h3 class="related-card__title">{c.title}</h3>
            <p class="t-body related-card__desc">{c.desc}</p>
            <span class="related-card__arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </section>
  </article>
</Layout>

<script>
  const form = document.querySelector('[data-form]') as HTMLFormElement | null;
  const counter = document.querySelector('[data-counter]') as HTMLElement | null;
  const marker = document.querySelector('[data-marker]') as HTMLElement | null;
  const statusPill = document.querySelector('.status-pill') as HTMLElement | null;
  const statusLabel = document.querySelector('[data-status-label]') as HTMLElement | null;
  const benchEl = document.querySelector('[data-bench]') as HTMLElement | null;
  const poursEl = document.querySelector('[data-pours]') as HTMLElement | null;
  const customersEl = document.querySelector('[data-customers]') as HTMLElement | null;
  const costPourEl = document.querySelector('[data-cost-pour]') as HTMLElement | null;
  const cupEl = document.querySelector('[data-cup]') as HTMLElement | null;
  const totalCustomerEl = document.querySelector('[data-total-customer]') as HTMLElement | null;
  const profitCustomerEl = document.querySelector('[data-profit-customer]') as HTMLElement | null;
  const profitBibEl = document.querySelector('[data-profit-bib]') as HTMLElement | null;
  const mathBody = document.querySelector('[data-math]') as HTMLElement | null;
  const mathWrap = document.querySelector('[data-math-wrap]') as HTMLDetailsElement | null;
  const pourSizeSel = document.querySelector('#pour-size') as HTMLSelectElement | null;
  const customPourRow = document.querySelector('#custom-pour-row') as HTMLElement | null;

  if (form && counter && marker && statusPill && statusLabel && mathBody) {
    let lastValue = 0;
    let calcDebounce: number | null = null;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const BENCH = { low: 5, high: 15 };

    function fmtUSD(n: number) { return '$' + Math.round(n).toLocaleString('en-US'); }
    function fmtUSDFull(n: number) { return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }); }
    function fmtUSDCents(n: number) { return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 3, maximumFractionDigits: 3 }); }

    function animateCounter(el: HTMLElement, from: number, to: number, duration = 800) {
      if (reduced) { el.textContent = to.toFixed(1); return; }
      const start = performance.now();
      const ease = (t: number) => 1 - Math.pow(1 - t, 3);
      function frame(now: number) {
        const t = Math.min((now - start) / duration, 1);
        const v = from + (to - from) * ease(t);
        el.textContent = v.toFixed(1);
        if (t < 1) requestAnimationFrame(frame);
        else { el.classList.add('result-num--pulse'); setTimeout(() => el.classList.remove('result-num--pulse'), 320); }
      }
      requestAnimationFrame(frame);
    }

    function statusFor(pct: number) {
      if (pct < 5) return { key: 'lean', label: 'Lean' };
      if (pct <= 15) return { key: 'healthy', label: 'Healthy' };
      if (pct <= 22) return { key: 'watch', label: 'Watch' };
      return { key: 'critical', label: 'Critical' };
    }

    function getPourSize(): number {
      const sel = pourSizeSel?.value || '16';
      if (sel === 'custom') {
        const c = parseFloat((document.querySelector('#pour-size-custom') as HTMLInputElement)?.value || '0');
        return c > 0 ? c : 0;
      }
      return parseFloat(sel) || 0;
    }

    function reset() {
      statusPill!.dataset.status = 'empty';
      statusLabel!.textContent = 'Enter values';
      marker!.style.left = '0%';
      animateCounter(counter!, lastValue, 0, 400);
      lastValue = 0;
      mathBody!.innerHTML = '<p class="t-caption">Enter values above to see the calculation.</p>';
      [poursEl, customersEl, costPourEl, cupEl, totalCustomerEl, profitCustomerEl, profitBibEl].forEach(e => { if (e) e.textContent = ', '; });
    }

    function calc() {
      const data = new FormData(form!);
      const bibVolume = parseFloat(String(data.get('bib-volume') || '0')) || 0;
      const bibPrice = parseFloat(String(data.get('bib-price') || '0')) || 0;
      const mixRatio = parseFloat(String(data.get('mix-ratio') || '5')) || 5;
      const pourSize = getPourSize();
      const iceRaw = parseFloat(String(data.get('ice-fill') || '30'));
      const ice = isNaN(iceRaw) ? 30 : iceRaw;
      const cupCost = parseFloat(String(data.get('cup-cost') || '0')) || 0;
      const co2Cost = parseFloat(String(data.get('co2-cost') || '0')) || 0;
      const menuPrice = parseFloat(String(data.get('menu-price') || '0')) || 0;
      const refillRaw = parseFloat(String(data.get('refill-mult') || '1.4'));
      const refillMult = isNaN(refillRaw) || refillRaw < 1 ? 1.4 : refillRaw;

      if (bibVolume <= 0 || bibPrice <= 0 || pourSize <= 0 || menuPrice <= 0) { reset(); return; }

      const finishedBevOz = bibVolume * (1 + mixRatio);
      const effectivePour = pourSize * (1 - ice / 100);
      const syrupCostPour = (bibPrice / finishedBevOz) * effectivePour;
      const singlePourCost = syrupCostPour + co2Cost;
      const totalPerCustomer = singlePourCost * refillMult + cupCost;
      const poursPerBIB = effectivePour > 0 ? Math.floor(finishedBevOz / effectivePour) : 0;
      const customersPerBIB = refillMult > 0 ? Math.floor(poursPerBIB / refillMult) : 0;
      const pourCostPct = (totalPerCustomer / menuPrice) * 100;
      const profitPerCustomer = menuPrice - totalPerCustomer;
      const profitPerBIB = customersPerBIB * profitPerCustomer;

      if (benchEl) benchEl.textContent = `${BENCH.low}–${BENCH.high}%`;

      // Bar scale: 0–30% range, multiply pct by (100/30) for marker
      const clamped = Math.min(100, Math.max(0, pourCostPct * (100 / 30)));
      animateCounter(counter!, lastValue, pourCostPct, 800);
      lastValue = pourCostPct;
      const s = statusFor(pourCostPct);
      statusPill!.dataset.status = s.key;
      statusLabel!.textContent = s.label;
      marker!.style.left = `${clamped}%`;

      if (poursEl) poursEl.textContent = poursPerBIB.toLocaleString('en-US');
      if (customersEl) customersEl.textContent = customersPerBIB.toLocaleString('en-US');
      if (costPourEl) costPourEl.textContent = fmtUSDCents(singlePourCost);
      if (cupEl) cupEl.textContent = fmtUSDFull(cupCost);
      if (totalCustomerEl) totalCustomerEl.textContent = fmtUSDFull(totalPerCustomer);
      if (profitCustomerEl) profitCustomerEl.textContent = fmtUSDFull(profitPerCustomer);
      if (profitBibEl) profitBibEl.textContent = fmtUSD(profitPerBIB);

      let note = '';
      if (s.label === 'Healthy') note = `In the healthy 5% to 15% range for soda. You make about ${fmtUSD(profitPerBIB)} in profit from each box of syrup. Soda is usually the highest-profit item on the menu when you run the numbers like this.`;
      if (s.label === 'Lean') note = `Lower than most soda costs. Either you have room to drop the price and bring in more people, or one of your numbers (cup cost, free-refill count) is set too low. Check the cup invoice and how many refills people really take before celebrating.`;
      if (s.label === 'Watch') note = `Above 15%. Usually it is free refills and cup cost stacking up. Capping refills at one drops the average from 1.4 drinks to about 1.1 and recovers most of the gap. Switching from name-brand to store-brand syrup is the next lever.`;
      if (s.label === 'Critical') note = `Above 22%. Something is off. Either the price is set for a smaller cup, the cup got a lot more expensive (switched to eco-friendly?), or people are taking closer to 2 drinks each instead of 1.4. Check the cup invoice first.`;

      const pourSizeStr = pourSize % 1 === 0 ? pourSize.toString() : pourSize.toFixed(1);

      mathBody!.innerHTML = `
        <table class="math-table" role="presentation">
          <tr><td>Syrup in the box</td><td class="num">${bibVolume.toLocaleString('en-US')} oz</td></tr>
          <tr><td>× (1 + ${mixRatio} parts water)</td><td class="num">× ${(1 + mixRatio).toFixed(1)}</td></tr>
          <tr class="math-table__step"><td>= Total finished drink from the box</td><td class="num">${finishedBevOz.toLocaleString('en-US', { maximumFractionDigits: 0 })} oz</td></tr>
          <tr><td>Cup size</td><td class="num">${pourSizeStr} oz</td></tr>
          <tr><td>× (cup minus ${ice}% ice)</td><td class="num">× ${(1 - ice / 100).toFixed(2)}</td></tr>
          <tr class="math-table__step"><td>= Soda in one cup</td><td class="num">${effectivePour.toLocaleString('en-US', { maximumFractionDigits: 1 })} oz</td></tr>
          <tr><td>Box price ÷ total finished drink × soda per cup</td><td class="num">${fmtUSDCents(syrupCostPour)}</td></tr>
          <tr><td>+ Fizz (CO2) per cup</td><td class="num">${fmtUSDCents(co2Cost)}</td></tr>
          <tr class="math-table__step"><td>= Cost of one cup of soda</td><td class="num">${fmtUSDCents(singlePourCost)}</td></tr>
          <tr><td>× drinks per customer (free refills)</td><td class="num">× ${refillMult.toFixed(1)}</td></tr>
          <tr><td>+ Cup, lid, and straw</td><td class="num">${fmtUSDFull(cupCost)}</td></tr>
          <tr class="math-table__step"><td>= What one customer costs you</td><td class="num"><strong>${fmtUSDFull(totalPerCustomer)}</strong></td></tr>
          <tr><td>÷ Menu price</td><td class="num">${fmtUSDFull(menuPrice)}</td></tr>
          <tr class="math-table__final"><td>Cost as a share of the price (pour cost %)</td><td class="num"><strong>${pourCostPct.toFixed(1)}%</strong></td></tr>
        </table>
        ${note ? `<p class="t-caption math-note">${note}</p>` : ''}
      `;

      if (mathWrap && !mathWrap.open) mathWrap.open = true;
    }

    function debouncedCalc() {
      if (calcDebounce !== null) clearTimeout(calcDebounce);
      calcDebounce = window.setTimeout(calc, 250);
    }

    function togglePourCustom() {
      if (!pourSizeSel || !customPourRow) return;
      customPourRow.style.display = pourSizeSel.value === 'custom' ? '' : 'none';
    }

    pourSizeSel?.addEventListener('change', () => { togglePourCustom(); debouncedCalc(); });
    form.addEventListener('input', debouncedCalc);
    form.addEventListener('change', debouncedCalc);
    form.addEventListener('submit', (e) => { e.preventDefault(); if (calcDebounce !== null) clearTimeout(calcDebounce); calc(); });

    function loadExample() {
      (document.querySelector('#bib-volume') as HTMLInputElement).value = '640';
      (document.querySelector('#bib-price') as HTMLInputElement).value = '90';
      (document.querySelector('#mix-ratio') as HTMLSelectElement).value = '5';
      (document.querySelector('#pour-size') as HTMLSelectElement).value = '16';
      (document.querySelector('#ice-fill') as HTMLInputElement).value = '30';
      (document.querySelector('#cup-cost') as HTMLInputElement).value = '0.18';
      (document.querySelector('#co2-cost') as HTMLInputElement).value = '0.01';
      (document.querySelector('#menu-price') as HTMLInputElement).value = '3.49';
      (document.querySelector('#refill-mult') as HTMLInputElement).value = '1.4';
      togglePourCustom();
      calc();
    }
    const loadExBtn = document.querySelector('[data-load-example]');
    if (loadExBtn) loadExBtn.addEventListener('click', loadExample);
    togglePourCustom();
    loadExample();
  }
</script>

<style>
  .calc-page { padding: var(--space-12) var(--space-6) var(--space-24); max-width: 1180px; margin: 0 auto; }
  .breadcrumb { display: flex; align-items: center; gap: var(--space-2); font-family: var(--font-body); font-size: 0.8125rem; color: var(--color-muted); margin-bottom: var(--space-8); }
