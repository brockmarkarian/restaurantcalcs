---
import Layout from '../../layouts/Layout.astro';

const title = 'Menu Pricing Calculator, Free | RestaurantCalcs';
const description = 'Menu price from plate cost + target food cost %. Charm rounding, contribution margin %, optional prime cost output. Built for indie operators.';

const faq = [
  {
    q: 'How do you price a menu item?',
    a: 'The standard formula: Menu Price = Item Cost ÷ Target Food Cost %. If a plate costs $5 to produce and you target a 30% food cost, the menu price should be $5 ÷ 0.30 = $16.67. Round up to a price point ($16.95 or $17.00). This is the reverse of food cost percentage, instead of measuring after the fact, you set the price before the fact.',
  },
  {
    q: 'What target food cost percentage should I use?',
    a: 'Concept-dependent: full-service casual 28–32%, fine dining 30–35%, fast casual 30–34%, pizza 22–28%, quick service 25–30%. High-cost proteins typically run higher (35–38%), starches and salads lower (22–28%). Most operators set a category target and price each item to land within ±3pp of it.',
  },
  {
    q: 'What is a pricing factor / multiplier?',
    a: 'Pricing factor is just 1 ÷ target food cost %. A 3.0x factor = 33% target. 4.0x factor = 25% target. 3.33x factor = 30% target. Operators using factors find it intuitive: "this plate cost $4, multiply by 3.33, charge $13.32, round to $12.95 or $13.95." Same math, different framing.',
  },
  {
    q: 'Should I price by gross profit or food cost?',
    a: 'Most operators price by food cost % because that\'s what their P&L tracks and what suppliers benchmark. But some price by gross profit dollars per item, especially in fine dining where a 35% food cost item making $24 profit is better than a 25% food cost item making $11 profit. Use gross profit dollars for high-volume comparison, food cost % for category targets.',
  },
  {
    q: 'How do I price an item with high food cost?',
    a: 'Three options: (1) raise the price to hit your target % (risk: priced above market), (2) accept higher food cost % on this item if gross profit dollars are strong (typical for steaks, lobster), (3) re-engineer the recipe, smaller portion, cheaper protein cut, additional starch. The wrong move is to price below cost target without consciously choosing why.',
  },
  {
    q: 'Should taxes and tip be included?',
    a: 'No. Menu price is before tax and tip, those are pass-through. Calculate menu price using item cost only. The customer pays tax on top of menu price; tips are separate revenue (and labor cost). Including either inflates your perceived price without adding margin.',
  },
  {
    q: 'How often should I reprice the menu?',
    a: 'Run a full repricing exercise every 6 months at minimum, more often during inflation. Many operators do quarterly reviews on the top 20 highest-volume items (the ones moving most cost dollars). One-off price changes are easier to justify, surprise full menu repricings make customers notice.',
  },
  {
    q: 'What is psychological pricing?',
    a: 'Pricing items at $X.95 or $X.99 instead of round numbers, based on research that left-digit numbers anchor perception. $14.95 reads "fourteen-something" not "fifteen." Most casual concepts use .95 endings. Fine dining often uses round numbers ($24, $36) because precision pricing reads down-market. Pick a convention and apply consistently.',
  },
  {
    q: 'Does this calculator save my data?',
    a: 'No. Nothing is stored, transmitted, or tracked. The calculation runs entirely in your browser and disappears the moment you close the tab. No signup, no email, no account.',
  },
];

const schema = [
  { '@context': 'https://schema.org', '@type': 'WebPage', '@id': 'https://restaurantcalcs.com/calculators/menu-pricing/#webpage', url: 'https://restaurantcalcs.com/calculators/menu-pricing/', name: title, description, isPartOf: { '@id': 'https://restaurantcalcs.com/#website' }, breadcrumb: { '@id': 'https://restaurantcalcs.com/calculators/menu-pricing/#breadcrumb' }, inLanguage: 'en-US' },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', '@id': 'https://restaurantcalcs.com/calculators/menu-pricing/#breadcrumb', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://restaurantcalcs.com/' },
    { '@type': 'ListItem', position: 2, name: 'Calculators', item: 'https://restaurantcalcs.com/' },
    { '@type': 'ListItem', position: 3, name: 'Menu Pricing', item: 'https://restaurantcalcs.com/calculators/menu-pricing/' },
  ] },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    '@id': 'https://restaurantcalcs.com/calculators/menu-pricing/#tool',
    name: 'Menu Pricing Calculator',
    description: 'Free web-based menu pricing calculator. Reverse-engineer menu price from plate cost + target food cost %. Charm rounding, contribution margin %, prime cost output (with optional labor %).',
    applicationCategory: 'BusinessApplication',
    applicationSubCategory: 'Restaurant Management',
    operatingSystem: 'Web',
    browserRequirements: 'Requires JavaScript',
    url: 'https://restaurantcalcs.com/calculators/menu-pricing/',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    creator: { '@id': 'https://restaurantcalcs.com/#organization' },
    author: { '@id': 'https://restaurantcalcs.com/#founder' },
    isAccessibleForFree: true,
  },
  { '@context': 'https://schema.org', '@type': 'HowTo', name: 'How to price a menu item', description: 'Calculate suggested menu price from item cost and target food cost percentage.', totalTime: 'PT2M', supply: [
    { '@type': 'HowToSupply', name: 'Item plate cost (in dollars)' },
    { '@type': 'HowToSupply', name: 'Target food cost percentage' },
  ], step: [
    { '@type': 'HowToStep', position: 1, name: 'Calculate plate cost', text: 'Sum all ingredient costs for the portion size you sell.' },
    { '@type': 'HowToStep', position: 2, name: 'Divide by target percentage', text: 'Menu Price = Item Cost ÷ (Target Food Cost % ÷ 100). Example: $5 cost ÷ 0.30 = $16.67.' },
    { '@type': 'HowToStep', position: 3, name: 'Round to a price point', text: 'Round up to a clean price ($16.95 or $17.00). Use a consistent rounding convention across the menu.' },
  ] },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
];

const benchmarks = [
  { name: 'Fine dining', low: 30, high: 35 },
  { name: 'Casual dining', low: 28, high: 32 },
  { name: 'Fast casual', low: 30, high: 34 },
  { name: 'Quick service', low: 25, high: 30 },
  { name: 'Pizza', low: 22, high: 28 },
  { name: 'Coffee / cafe', low: 15, high: 25 },
];

const scenarios = [
  {
    title: 'The under-priced burger',
    setup: 'Casual dining concept, signature burger priced at $14. Cost $5.50 to plate. Food cost 39%, eating margin every plate.',
    diagnosis: 'Menu price set 4 years ago. Beef cost up 28% since. Cheese up 22%. Brioche bun up 18%. Same price, much higher cost.',
    fix: 'Repriced to $16.95 (28% food cost). Tested with promo. No measurable drop in covers.',
    outcome: 'Margin per burger: $11.45 vs prior $8.50. At 1,800 burgers/month: $5,300/month margin recovery.',
  },
  {
    title: 'The over-priced salad',
    setup: 'New chef-driven concept opened with $18 salads to match the rest of the menu. Cost $3.20 to plate. Food cost 18%.',
    diagnosis: 'Salads way under-priced for the value perception, but actually over-priced for the market, they were sitting on the menu without selling.',
    fix: 'Cut to $14.95. Boosted portion 15%. Repositioned as "lunch entree."',
    outcome: 'Salad volume up 220% in 8 weeks. Lower price + bigger portion = same gross profit dollars at 4x volume.',
  },
  {
    title: 'The high-cost steak',
    setup: 'Steakhouse, ribeye priced at $42. Cost $15 to plate. Food cost 36%, above 30% target.',
    diagnosis: 'Steak prices will always run higher than category target, that\'s normal. Real question: gross profit dollars vs alternatives. Ribeye made $27 profit per plate vs salmon at $19 profit. Gross dollars beat category alignment.',
    fix: 'Kept the price. Documented decision. Ran category-weighted target instead of flat target.',
    outcome: 'Steak food cost % stayed 36% but ribeye became #2 highest-margin item in dollars. Lesson: % isn\'t everything.',
  },
];

const relatedCalcs = [
  { slug: 'recipe-cost', title: 'Recipe & Plate Cost', desc: 'Build plate cost from ingredients.' },
  { slug: 'menu-engineering', title: 'Menu Engineering', desc: 'Star / Plowhorse / Puzzle / Dog matrix.' },
  { slug: 'liquor-pour-cost', title: 'Liquor Pour Cost', desc: 'Beverage pricing & pour cost.' },
];
---

<Layout {title} {description} {schema}>
  <article class="calc-page">
    <header class="calc-page__header">
      <nav class="breadcrumb" aria-label="Breadcrumb"><a href="/">Home</a><span aria-hidden="true">/</span><span>Menu Pricing Calculator</span></nav>
      <p class="t-micro t-micro--saffron calc-page__eyebrow">Menu pricing calculator · <strong>100% free · no signup</strong></p>
      <h1 class="calc-page__title">Menu Pricing Calculator</h1>
      <p class="calc-page__intro">
        Reverse-engineer menu price from item cost and target food cost percentage. Get the price you should charge before you build the menu, not after you discover the margin’s gone.
      </p>
    </header>

    <section class="calc-grid">
      <form class="calc-form" data-form>
        <div class="form-intro">
          <p class="form-intro__what"><strong>What this does:</strong> Reverse-engineers menu price from item cost and target food cost percentage. $5 plate ÷ 30% target = $16.67 menu price (round to $16.95 or $17).</p>
          <button type="button" class="form-intro__example" data-load-example>Try with example numbers</button>
        </div>

        <div class="form-row">
          <label class="form-row__label" for="cost">Item cost (per plate)</label>
          <div class="input-shell">
            <span class="input-shell__prefix">$</span>
            <input id="cost" name="cost" type="number" inputmode="decimal" min="0" step="0.01" placeholder="5.50" autocomplete="off" required />
          </div>
          <p class="form-row__hint">Total ingredient cost for one served portion.</p>
        </div>

        <div class="form-row">
          <label class="form-row__label" for="target">Target food cost %</label>
          <div class="input-shell">
            <input id="target" name="target" type="number" inputmode="decimal" min="1" max="100" step="0.5" placeholder="30" autocomplete="off" required />
            <span class="input-shell__suffix">%</span>
          </div>
          <p class="form-row__hint">Concept benchmark: casual 28–32%, fine dining 30–35%, QSR 25–30%, pizza 22–28%.</p>
        </div>

        <div class="form-row">
          <label class="form-row__label" for="labor">Labor cost % (optional, for prime cost)</label>
          <div class="input-shell">
            <input id="labor" name="labor" type="number" inputmode="decimal" min="0" max="100" step="0.5" placeholder="30" autocomplete="off" />
            <span class="input-shell__suffix">%</span>
          </div>
          <p class="form-row__hint">Adds prime cost output (food cost % + labor cost %). NRA target: 55–60%. Above 65% signals trouble.</p>
        </div>

        <div class="form-row">
          <label class="form-row__label" for="rounding">Round to nearest</label>
          <select id="rounding" name="rounding">
            <option value="0.05">.95 endings (charm pricing)</option>
            <option value="0.99">.99 endings (QSR / value)</option>
            <option value="0.50">.50 / .00 endings</option>
            <option value="1" selected>Whole dollar</option>
            <option value="0">No rounding</option>
          </select>
        </div>

        <button type="submit" class="btn btn-primary btn-large calc-form__submit">
          Calculate menu price
          <span class="btn__arrow" aria-hidden="true">→</span>
        </button>

        <p class="calc-form__privacy t-caption"><strong>Nothing is saved or sent.</strong> All math runs in your browser.</p>
      </form>

      <aside class="calc-result">
        <div class="calc-result__card" aria-live="polite" aria-atomic="true">
          <div class="calc-result__head">
            <span class="t-micro calc-result__label">Suggested menu price</span>
          </div>

          <div class="calc-result__big calc-result__big--money">
            <span class="result-num__pct" aria-hidden="true">$</span>
            <span class="result-num" data-counter>0.00</span>
          </div>

          <div class="calc-result__benchmark">
            <span class="t-caption">Pricing factor</span>
            <span class="t-caption num" data-factor></span>
          </div>

          <div class="calc-result__extras">
            <div class="extras-row">
              <span class="extras-row__label">Gross profit per plate</span>
              <span class="extras-row__value num" data-profit>$0.00</span>
            </div>
            <div class="extras-row">
              <span class="extras-row__label">Contribution margin %</span>
              <span class="extras-row__value num" data-cm-pct></span>
            </div>
            <div class="extras-row" data-prime-row hidden>
              <span class="extras-row__label">Prime cost % (food + labor)</span>
              <span class="extras-row__value num" data-prime></span>
            </div>
            <div class="extras-row" data-rounded-row hidden>
              <span class="extras-row__label">Rounded price</span>
              <span class="extras-row__value num" data-rounded></span>
            </div>
          </div>
        </div>

        <details class="show-math" data-math-wrap>
          <summary class="show-math__trigger">
            <span class="show-math__icon" aria-hidden="true">+</span>
            Show your math
          </summary>
          <div class="show-math__body" data-math>
            <p class="t-caption">Enter values above to see the calculation.</p>
          </div>
        </details>
      </aside>
    </section>

    <section class="essay">
      <img src="/illustrations/menu-pricing.webp" alt="Editorial illustration of a leather-bound restaurant menu open on a table with a fountain pen marking prices in margins, alongside a vintage calculator and folded napkin." class="operator-story__hero" width="1264" height="848" loading="lazy" />
      <p class="essay__eyebrow t-micro t-micro--saffron">Why this matters</p>
      <h2 class="essay__headline">Pricing is the only lever that <em>doesn't cost you money</em>.</h2>
      <div class="essay__body">
        <p>
          Cutting cost takes vendor renegotiation, recipe re-engineering, or staff conversations. Each costs you something, time, supplier relationship, or service quality. Pricing costs nothing to change. You print a new menu Tuesday.
        </p>
        <p>
          Yet pricing is the lever most operators move last. They negotiate vendors first, audit portions second, cut prep hours third, and only after all that gets uncomfortable do they raise prices. By then they've left a year of margin on the table.
        </p>
        <p class="essay__pull">
          The reason: pricing feels like a gamble. Cost-side moves feel safe (you know the saving). Price moves feel risky (will customers leave?). Most don't. Most don't notice. Most price increases under 8% have zero measurable impact on covers.
        </p>
        <p>
          Run pricing the way you run cost: as a discipline. Reprice quarterly on the top 20 movers. Catch up to inflation in real time, not at the next "menu refresh" 18 months later when you have to raise everything 22% at once.
        </p>
      </div>
    </section>

    <hr class="rule" aria-hidden="true" />

    <section class="benchmarks">
      <h2 class="benchmarks__headline">Target food cost <em>by concept</em></h2>
      <p class="t-body-large benchmarks__intro">
        Use these as starting targets. Adjust per-item: high-cost proteins typically run 5pp above category target, starches and salads 5pp below. The category target is the average, not the rule.
      </p>
      <div class="benchmarks__chart">
        {benchmarks.map((b) => (
          <div class="bench-bar">
            <div class="bench-bar__name">{b.name}</div>
            <div class="bench-bar__track">
              <div class="bench-bar__zone" style={`left: ${b.low * 2}%; width: ${(b.high - b.low) * 2}%`}></div>
              <div class="bench-bar__tick" style={`left: ${b.low * 2}%`}></div>
              <div class="bench-bar__tick" style={`left: ${b.high * 2}%`}></div>
            </div>
            <div class="bench-bar__range num">{b.low}–{b.high}%</div>
          </div>
        ))}
        <div class="bench-axis">
          <div class="bench-axis__track">
            <span class="bench-axis__tick num" style="left: 0%">0%</span>
            <span class="bench-axis__tick num" style="left: 20%">10%</span>
            <span class="bench-axis__tick num" style="left: 40%">20%</span>
            <span class="bench-axis__tick num" style="left: 60%">30%</span>
            <span class="bench-axis__tick num" style="left: 80%">40%</span>
            <span class="bench-axis__tick num" style="left: 100%">50%</span>
          </div>
        </div>
      </div>
    </section>

    <div class="container ad-wrap">
      <aside class="ad-inline">
        <span class="ad-inline__label">Advertisement</span>
        <div class="ad-inline__inner">
          <ins class="adsbygoogle"
               style="display:block"
               data-ad-client="ca-pub-6332696231897305"
               data-ad-slot="0000000000"
               data-ad-format="auto"
               data-full-width-responsive="true"
               data-adtest="on"></ins>
          <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
        </div>
      </aside>
    </div>

    <section class="scenarios">
      <p class="t-micro t-micro--saffron">Real scenarios</p>
      <h2 class="scenarios__headline">Three pricing decisions, three different outcomes</h2>
      <p class="t-body-large scenarios__intro">
        Same calculator, different judgment. The math gives you a number, the call is yours.
      </p>
      <div class="scenarios__grid">
        {scenarios.map((s, i) => (
          <article class="scenario-card">
            <span class="scenario-card__num num">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="scenario-card__title">{s.title}</h3>
            <p class="scenario-card__setup">{s.setup}</p>
            <div class="scenario-card__row"><span class="scenario-card__label">Diagnosis</span><p class="scenario-card__text">{s.diagnosis}</p></div>
            <div class="scenario-card__row"><span class="scenario-card__label">Fix</span><p class="scenario-card__text">{s.fix}</p></div>
            <div class="scenario-card__row scenario-card__row--outcome"><span class="scenario-card__label">Outcome</span><p class="scenario-card__text"><strong>{s.outcome}</strong></p></div>
          </article>
        ))}
      </div>
    </section>

    <hr class="rule" aria-hidden="true" />

    <section class="calc-faq">
      <p class="t-micro t-micro--saffron">FAQ</p>
      <h2 class="calc-faq__headline">Common questions</h2>
      {faq.map((f, i) => (
        <details class="calc-faq__item">
          <summary class="calc-faq__q">
            <span class="calc-faq__num">{String(i + 1).padStart(2, '0')}</span>
            <span class="calc-faq__qtext">{f.q}</span>
            <span class="calc-faq__plus" aria-hidden="true">+</span>
          </summary>
          <p class="calc-faq__a">{f.a}</p>
        </details>
      ))}
    </section>

    <section class="cited-sources">
      <p class="t-micro t-micro--saffron">Cited sources</p>
      <ul>
        <li><a href="https://pos.toasttab.com/blog/on-the-line/menu-pricing-strategies" target="_blank" rel="noopener">Toast, Menu Pricing Strategies</a></li>
        <li><a href="https://www.restaurant365.com/blog/menu-engineering/" target="_blank" rel="noopener">Restaurant365, Menu Engineering & Pricing</a></li>
        <li><a href="https://restaurant.org/" target="_blank" rel="noopener">National Restaurant Association, Industry Pricing Research</a></li>
      </ul>
    </section>

    <section class="related">
      <h2 class="related__headline">Related calculators</h2>
      <div class="related__grid">
        {relatedCalcs.map((c, i) => (
          <a href={`/calculators/${c.slug}/`} class="related-card">
            <div class="related-card__top">
              <span class="related-card__num num">{String(i + 1).padStart(2, '0')}</span>
              <span class="t-micro"><strong style="color:var(--color-saffron-text)">Free</strong> · 2 min</span>
            </div>
            <h3 class="related-card__title">{c.title}</h3>
            <p class="t-body related-card__desc">{c.desc}</p>
            <span class="related-card__arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </section>
  </article>
</Layout>

<script>
  const form = document.querySelector('[data-form]') as HTMLFormElement | null;
  const counter = document.querySelector('[data-counter]') as HTMLElement | null;
  const factorEl = document.querySelector('[data-factor]') as HTMLElement | null;
  const profitEl = document.querySelector('[data-profit]') as HTMLElement | null;
  const cmPctEl = document.querySelector('[data-cm-pct]') as HTMLElement | null;
  const primeRow = document.querySelector('[data-prime-row]') as HTMLElement | null;
  const primeEl = document.querySelector('[data-prime]') as HTMLElement | null;
  const roundedRow = document.querySelector('[data-rounded-row]') as HTMLElement | null;
  const roundedEl = document.querySelector('[data-rounded]') as HTMLElement | null;
  const mathBody = document.querySelector('[data-math]') as HTMLElement | null;
  const mathWrap = document.querySelector('[data-math-wrap]') as HTMLDetailsElement | null;

  if (form && counter && mathBody) {
    let lastValue = 0;
    let calcDebounce: number | null = null;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function fmtUSD(n: number): string { return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }); }

    function animateCounter(el: HTMLElement, from: number, to: number, duration = 800, decimals = 2) {
      if (reduced) { el.textContent = to.toFixed(decimals); return; }
      const start = performance.now();
      const ease = (t: number) => 1 - Math.pow(1 - t, 3);
      function frame(now: number) {
        const t = Math.min((now - start) / duration, 1);
        const value = from + (to - from) * ease(t);
        el.textContent = value.toFixed(decimals);
        if (t < 1) requestAnimationFrame(frame);
        else { el.classList.add('result-num--pulse'); setTimeout(() => el.classList.remove('result-num--pulse'), 320); }
      }
      requestAnimationFrame(frame);
    }

    function roundPrice(price: number, mode: string): number {
      if (mode === '0') return price;
      // Charm pricing: round to NEAREST .95 ending (not always up).
      // $15.00 → $14.95 (closer than $15.95), $15.50 → $15.95, $14.30 → $13.95.
      if (mode === '0.05') return Math.round(price - 0.95) + 0.95;
      // .99 endings (QSR): round to NEAREST .99 ending.
      if (mode === '0.99') return Math.round(price - 0.99) + 0.99;
      if (mode === '0.50') {
        const dollars = Math.floor(price);
        const cents = price - dollars;
        if (cents === 0) return dollars;
        if (cents <= 0.50) return dollars + 0.50;
        return dollars + 1;
      }
      if (mode === '1') return Math.round(price);
      return price;
    }

    function calc() {
      const data = new FormData(form!);
      const cost = parseFloat(String(data.get('cost') || '0')) || 0;
      const target = parseFloat(String(data.get('target') || '0')) || 0;
      const laborPct = parseFloat(String(data.get('labor') || '0')) || 0;
      const rounding = String(data.get('rounding') || '1');

      if (cost <= 0 || target <= 0 || target >= 100) {
        animateCounter(counter!, lastValue, 0, 400, 2);
        lastValue = 0;
        if (factorEl) factorEl.textContent = ', ';
        if (profitEl) profitEl.textContent = '$0.00';
        if (cmPctEl) cmPctEl.textContent = ', ';
        if (roundedRow) roundedRow.hidden = true;
        mathBody!.innerHTML = '<p class="t-caption">Enter values above to see the calculation.</p>';
        return;
      }

      const targetDecimal = target / 100;
      const rawPrice = cost / targetDecimal;
      const factor = 1 / targetDecimal;
      const profit = rawPrice - cost;
      const rounded = roundPrice(rawPrice, rounding);
      const roundedProfit = rounded - cost;
      const finalPrice = rounding === '0' ? rawPrice : rounded;
      const finalProfit = rounding === '0' ? profit : roundedProfit;
      const actualPct = (cost / rounded) * 100;
      const cmPct = finalPrice > 0 ? (finalProfit / finalPrice) * 100 : 0;

      animateCounter(counter!, lastValue, finalPrice, 800, 2);
      lastValue = finalPrice;

      if (factorEl) factorEl.textContent = `${factor.toFixed(2)}x`;
      if (profitEl) profitEl.textContent = fmtUSD(finalProfit);
      if (cmPctEl) cmPctEl.textContent = `${cmPct.toFixed(1)}%`;

      // Prime cost: actual food cost % (cost ÷ final price) + labor cost %
      const actualFoodPct = finalPrice > 0 ? (cost / finalPrice) * 100 : 0;
      const primePct = laborPct > 0 ? actualFoodPct + laborPct : 0;
      if (laborPct > 0 && primeRow && primeEl) {
        primeRow.hidden = false;
        const primeCls = primePct > 65 ? 'is-bad' : primePct > 60 ? 'is-watch' : 'is-good';
        primeEl.textContent = `${primePct.toFixed(1)}% (target 55–60%)`;
        primeEl.className = `extras-row__value num ${primeCls}`;
      } else if (primeRow) {
        primeRow.hidden = true;
      }

      if (rounding !== '0' && roundedRow && roundedEl) {
        roundedRow.hidden = false;
        roundedEl.textContent = `${fmtUSD(rounded)} (${actualPct.toFixed(1)}% food cost)`;
      } else if (roundedRow) {
        roundedRow.hidden = true;
      }

      mathBody!.innerHTML = `
        <table class="math-table" role="presentation">
          <tr><td>Item cost</td><td class="num">${fmtUSD(cost)}</td></tr>
          <tr><td>Target food cost</td><td class="num">${target.toFixed(1)}%</td></tr>
          <tr class="math-table__step"><td>Cost ÷ (Target ÷ 100)</td><td class="num">${fmtUSD(rawPrice)}</td></tr>
          ${rounding !== '0' ? `<tr class="math-table__step"><td>Rounded</td><td class="num">${fmtUSD(rounded)}</td></tr>` : ''}
          <tr class="math-table__final"><td>Suggested menu price</td><td class="num"><strong>${fmtUSD(rounding === '0' ? rawPrice : rounded)}</strong></td></tr>
        </table>
        <p class="t-caption math-note">
          Pricing factor: ${factor.toFixed(2)}x · Contribution margin: ${cmPct.toFixed(1)}% (${fmtUSD(finalProfit)}/plate).
          ${rounding !== '0' ? ` Rounded price reflects ${actualPct.toFixed(1)}% actual food cost.` : ''}
        </p>
      `;

      if (mathWrap && !mathWrap.open) mathWrap.open = true;
    }

    function debouncedCalc() {
      if (calcDebounce !== null) clearTimeout(calcDebounce);
      calcDebounce = window.setTimeout(calc, 250);
    }

    form.addEventListener('input', debouncedCalc);
    form.addEventListener('change', debouncedCalc);
    form.addEventListener('submit', (e) => { e.preventDefault(); if (calcDebounce !== null) clearTimeout(calcDebounce); calc(); });

    function loadExample() {
      (document.querySelector('#cost') as HTMLInputElement).value = '5';
      (document.querySelector('#target') as HTMLInputElement).value = '30';
      (document.querySelector('#rounding') as HTMLSelectElement).value = '1';
      calc();
    }
    const loadExBtn = document.querySelector('[data-load-example]');
    if (loadExBtn) loadExBtn.addEventListener('click', loadExample);
    loadExample();
  }
</script>

