  .status-pill__dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
  .status-pill[data-status="healthy"] { background: rgba(74, 88, 38, 0.12); color: #4a5826; }
  .status-pill[data-status="lean"] { background: rgba(74, 88, 38, 0.10); color: #4a5826; }
