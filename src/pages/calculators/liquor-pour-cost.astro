---
import Layout from '../../layouts/Layout.astro';

const title = 'Liquor Pour Cost Calculator, Free | RestaurantCalcs';
const description = 'Pour cost calculator with aggregate + per-drink modes. Bottle math, spillage, suggested price, healthy benchmarks per category. Built by a former bar manager.';

const faq = [
  {
    q: 'What is a good liquor pour cost percentage?',
    a: 'Liquor (spirits) typically targets 18–24% pour cost. Beer runs 25–30%. Wine runs 28–35%. A combined beverage program usually lands at 20–25%. Cocktail-heavy bars can hit 16–20% on liquor through tight portion control. Anything sustained above 30% on liquor signals over-pouring, theft, comping, or under-pricing.',
  },
  {
    q: 'How do you calculate pour cost?',
    a: 'Pour Cost % = (Beverage Cost ÷ Beverage Revenue) × 100. Beverage cost is what you paid suppliers for the period. Beverage revenue is what you sold for the same period. The discipline is matching periods cleanly, don\'t mix this week\'s revenue with last month\'s purchases.',
  },
  {
    q: 'Should I track liquor, beer, and wine separately?',
    a: 'Yes. Combined pour cost hides which category is leaking margin. Most operators track three separate %s plus a blended number. Wine programs especially benefit because by-the-glass and bottle pricing have different cost structures.',
  },
  {
    q: 'Why is my pour cost too high?',
    a: 'Ranked by frequency: (1) free pours, bartenders not using jiggers or measured spouts, (2) comping comp comping, too many "manager comps" or shift drinks not tracked, (3) outdated cocktail recipes, costs went up, prices didn\'t, (4) theft, common in high-volume bars without inventory discipline, (5) breakage and spillage uncounted, (6) inventory miscount on month-end.',
  },
  {
    q: 'How do I lower pour cost without losing customers?',
    a: 'Switch to measured pour spouts or jiggers (immediate 2–4pp drop typical). Reprice cocktails to match current liquor cost (most menus haven\'t kept up with inflation). Eliminate comp shift drinks or cap them. Audit your most-poured bottles, that\'s usually where the leak is.',
  },
  {
    q: 'How often should I run pour cost?',
    a: 'Weekly. Liquor cost moves faster than food cost because volume per item is lower and over-pour is easy to hide. Best operators run a daily inventory variance on the top 5 spirits.',
  },
  {
    q: 'What is a "perfect pour" vs "actual pour" report?',
    a: 'Perfect pour is your theoretical cost based on recipes and POS-tracked drinks sold. Actual pour is real inventory consumed. The variance flags over-pouring, comping, and theft. Variance >5% is investigation territory. Variance >10% means immediate audit.',
  },
  {
    q: 'Should comp drinks be included?',
    a: 'In your cost number, yes (you paid for the liquor). In your revenue, no (you didn\'t collect on it). That asymmetry is what makes excessive comping crush pour cost. A 4-ounce $9 cocktail that gets comped costs you the liquor PLUS the lost margin. Track comps separately as a percentage of total pours.',
  },
  {
    q: 'Does this calculator save my data?',
    a: 'No. Nothing is stored, transmitted, or tracked. The calculation runs entirely in your browser and disappears the moment you close the tab. No signup, no email, no account.',
  },
];

const schema = [
  { '@context': 'https://schema.org', '@type': 'WebPage', '@id': 'https://restaurantcalcs.com/calculators/liquor-pour-cost/#webpage', url: 'https://restaurantcalcs.com/calculators/liquor-pour-cost/', name: title, description, isPartOf: { '@id': 'https://restaurantcalcs.com/#website' }, breadcrumb: { '@id': 'https://restaurantcalcs.com/calculators/liquor-pour-cost/#breadcrumb' }, inLanguage: 'en-US' },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', '@id': 'https://restaurantcalcs.com/calculators/liquor-pour-cost/#breadcrumb', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://restaurantcalcs.com/' },
    { '@type': 'ListItem', position: 2, name: 'Calculators', item: 'https://restaurantcalcs.com/' },
    { '@type': 'ListItem', position: 3, name: 'Liquor Pour Cost', item: 'https://restaurantcalcs.com/calculators/liquor-pour-cost/' },
  ] },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    '@id': 'https://restaurantcalcs.com/calculators/liquor-pour-cost/#tool',
    name: 'Liquor Pour Cost Calculator',
    description: 'Free web-based pour cost calculator. Aggregate mode (cost ÷ revenue) or per-drink builder (bottle cost + size + pour size + spillage → cost per drink + suggested price).',
    applicationCategory: 'BusinessApplication',
    applicationSubCategory: 'Bar Management',
    operatingSystem: 'Web',
    browserRequirements: 'Requires JavaScript',
    url: 'https://restaurantcalcs.com/calculators/liquor-pour-cost/',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    creator: { '@id': 'https://restaurantcalcs.com/#organization' },
    author: { '@id': 'https://restaurantcalcs.com/#founder' },
    isAccessibleForFree: true,
  },
  { '@context': 'https://schema.org', '@type': 'HowTo', name: 'How to calculate liquor pour cost', description: 'Step-by-step calculation of pour cost percentage by beverage category.', totalTime: 'PT3M', supply: [
    { '@type': 'HowToSupply', name: 'Beverage cost for the period' },
    { '@type': 'HowToSupply', name: 'Beverage revenue for the period' },
  ], step: [
    { '@type': 'HowToStep', position: 1, name: 'Pull beverage cost', text: 'Sum all alcohol invoices paid during the period for the category being measured (liquor, beer, or wine).' },
    { '@type': 'HowToStep', position: 2, name: 'Pull beverage revenue', text: 'Sum sales revenue for the same category and same period.' },
    { '@type': 'HowToStep', position: 3, name: 'Divide and multiply', text: 'Pour Cost % = (Cost ÷ Revenue) × 100. Compare to category benchmark: liquor 18–24%, beer 25–30%, wine 28–35%.' },
  ] },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
];

const benchmarks = [
  { name: 'Liquor / spirits', low: 18, high: 24 },
  { name: 'Beer (draft)', low: 18, high: 24 },
  { name: 'Beer (bottled)', low: 25, high: 30 },
  { name: 'Wine (by glass)', low: 28, high: 32 },
  { name: 'Wine (by bottle)', low: 30, high: 40 },
  { name: 'Combined beverage program', low: 20, high: 25 },
];

const scenarios = [
  {
    title: 'The 32% liquor program',
    setup: 'Cocktail bar, liquor pour cost stuck at 32% for 6 months. Owner blamed inflation.',
    diagnosis: 'Free-pouring on the well, bartenders not using measured spouts. Audit found average pour 1.7oz vs spec 1.5oz. That 13% over-pour at scale = 4pp pour cost.',
    fix: 'Installed measured pour spouts on all wells, retrained bartenders, set weekly variance check on top 10 bottles.',
    outcome: 'Down to 21% in 4 weeks. $3,800/month margin recovered. Guest complaints zero, they couldn\'t tell.',
  },
  {
    title: 'The 18% beer program (suspicious)',
    setup: 'Sports bar, beer at 18%, looked great. Owner noticed kegs running out faster than POS sales suggested.',
    diagnosis: 'Theft. Bartender comping pints to friends, ringing them as voids. Variance vs theoretical was 11pp (real pour cost was 29%).',
    fix: 'POS lockdown on voids, inventory audit per shift, terminated bartender, replaced 2 measured-pour kegs.',
    outcome: 'Real pour cost 24%. Caught $1,200/month theft. Sets variance baseline for new hires.',
  },
  {
    title: 'The 38% wine program',
    setup: 'Italian concept, wine pour cost at 38%, well above 32% target. Wine list was strong, sommelier was certified.',
    diagnosis: 'By-the-glass pricing not updated in 18 months. Wholesale costs up 22% across two distributors. Menu prices unchanged. By-the-bottle was fine, by-the-glass was the leak.',
    fix: 'Repriced 8 BTG selections by $2–4. Added 3 new accessible BTG options at lower cost. Capped pours at 5oz with measured glass.',
    outcome: 'Wine pour cost 31% within 60 days. Guest complaints minimal. Sommelier kept the job.',
  },
];

const relatedCalcs = [
  { slug: 'keg-cost', title: 'Draft Beer / Keg Cost', desc: 'Companion calc for the bar program.' },
  { slug: 'menu-pricing', title: 'Menu Pricing', desc: 'Set drink prices from cost + target margin.' },
  { slug: 'inventory-variance', title: 'Inventory Variance', desc: 'Spot theft, waste, and over-pouring.' },
];
---

<Layout {title} {description} {schema}>
  <article class="calc-page">
    <header class="calc-page__header">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <span>Liquor Pour Cost Calculator</span>
      </nav>
      <p class="t-micro t-micro--saffron calc-page__eyebrow">Liquor pour cost calculator · <strong>100% free · no signup</strong></p>
      <h1 class="calc-page__title">Liquor Pour Cost Calculator</h1>
      <p class="calc-page__intro">
        Pour cost is the percent of a drink's sale price that goes to the booze itself. Bar margin slips faster than food, a heavy hand on the bottle, drink after drink, quietly eats your profit. This tool figures pour cost by category, <strong>liquor, beer, wine, or all of them combined</strong>, and tells you whether each one is in a healthy range.
      </p>
    </header>

    <section class="calc-grid">
      <form class="calc-form" data-form data-mode="aggregate">
        <div class="form-intro">
          <p class="form-intro__what"><strong>What this does:</strong> Two ways to check it. <strong>Whole bar</strong> compares what you paid for drinks to what you sold over a stretch of time, so you get the percent for a whole category. <strong>One drink</strong> works out what a single pour costs you from the bottle price and pour size, then tells you the percent and suggests a menu price.</p>
          <button type="button" class="form-intro__example" data-load-example>Try with example numbers</button>
        </div>

        <div class="mode-tabs" role="tablist" aria-label="Calculator mode">
          <button type="button" role="tab" class="mode-tab" data-mode-tab="aggregate" aria-selected="true">Whole bar (over time)</button>
          <button type="button" role="tab" class="mode-tab" data-mode-tab="perdrink" aria-selected="false">One drink (bottle to pour)</button>
        </div>

        <div data-panel-aggregate>
        <div class="form-row">
          <label class="form-row__label" for="category">Which drinks are you checking?</label>
          <select id="category" name="category">
            <option value="liquor" selected>Liquor / spirits (healthy 18–24%)</option>
            <option value="beer-draft">Beer, draft (healthy 18–24%)</option>
            <option value="beer-bottle">Beer, bottled (healthy 25–30%)</option>
            <option value="wine-glass">Wine by the glass (healthy 28–32%)</option>
            <option value="wine-bottle">Wine by the bottle (healthy 30–40%)</option>
            <option value="blended">All drinks combined (healthy 20–25%)</option>
          </select>
          <p class="form-row__hint">Picks the healthy range and the good/watch/over colors for this kind of drink.</p>
        </div>

        <div class="form-row">
          <label class="form-row__label" for="cost">What the drinks cost you</label>
          <div class="input-shell">
            <span class="input-shell__prefix">$</span>
            <input id="cost" name="cost" type="number" inputmode="decimal" min="0" step="0.01" placeholder="2200" autocomplete="off" required />
          </div>
          <p class="form-row__hint">Add up the invoices you paid for these drinks over the stretch of time you are checking.</p>
        </div>

        <div class="form-row">
          <label class="form-row__label" for="revenue">What you sold them for</label>
          <div class="input-shell">
            <span class="input-shell__prefix">$</span>
            <input id="revenue" name="revenue" type="number" inputmode="decimal" min="0" step="0.01" placeholder="11000" autocomplete="off" required />
          </div>
          <p class="form-row__hint">Sales of these same drinks over the same stretch of time. Pull it from your POS.</p>
        </div>

        <details class="optional-fields">
          <summary class="optional-fields__trigger">
            <span class="optional-fields__icon" aria-hidden="true">+</span>
            Compare to your goal and your recipe cost (optional)
          </summary>
          <div class="optional-fields__body">
            <div class="form-row">
              <label class="form-row__label" for="target">Your goal pour cost %</label>
              <div class="input-shell">
                <input id="target" name="target" type="number" inputmode="decimal" min="0" max="100" step="0.1" placeholder="22" autocomplete="off" />
                <span class="input-shell__suffix">%</span>
              </div>
              <p class="form-row__hint">The number you are aiming for. We show how far off you are, in dollars.</p>
            </div>

            <div class="form-row">
              <label class="form-row__label" for="theoretical">Recipe pour cost % (what it should be)</label>
              <div class="input-shell">
                <input id="theoretical" name="theoretical" type="number" inputmode="decimal" min="0" max="100" step="0.1" placeholder="20" autocomplete="off" />
                <span class="input-shell__suffix">%</span>
              </div>
              <p class="form-row__hint">What your pour cost would be if every drink was made exactly to recipe. The gap between this and your real number is usually over-pouring, comps, or theft.</p>
            </div>
          </div>
        </details>

        <div class="form-row">
          <label class="form-row__label" for="period">Period (for reference)</label>
          <select id="period" name="period">
            <option value="week">Weekly</option>
            <option value="month" selected>Monthly</option>
            <option value="quarter">Quarterly</option>
          </select>
        </div>
        </div>

        <div data-panel-perdrink hidden>
          <div class="form-row">
            <label class="form-row__label" for="drink-name">Drink name (optional)</label>
            <input id="drink-name" name="drink-name" type="text" class="text-input" placeholder="Vodka soda, Margarita, etc." autocomplete="off" />
          </div>

          <div class="form-row">
            <label class="form-row__label" for="bottle-cost">What the bottle cost you</label>
            <div class="input-shell">
              <span class="input-shell__prefix">$</span>
              <input id="bottle-cost" name="bottle-cost" type="number" inputmode="decimal" min="0" step="0.01" placeholder="22.50" autocomplete="off" />
            </div>
            <p class="form-row__hint">The price on your invoice from the distributor, before any tax or tip.</p>
          </div>

          <div class="form-row">
            <label class="form-row__label" for="bottle-size">Bottle size</label>
            <select id="bottle-size" name="bottle-size">
              <option value="750">750ml (standard fifth, 25.36 fl oz)</option>
              <option value="1000">1L (33.81 fl oz)</option>
              <option value="1750">1.75L (handle, 59.17 fl oz)</option>
              <option value="375">375ml (half bottle, 12.68 fl oz)</option>
              <option value="custom">Custom (ml)</option>
            </select>
          </div>

          <div class="form-row" data-custom-size-row hidden>
            <label class="form-row__label" for="bottle-size-custom">Your bottle size (ml)</label>
            <div class="input-shell">
              <input id="bottle-size-custom" name="bottle-size-custom" type="number" inputmode="decimal" min="0" step="1" placeholder="700" autocomplete="off" />
              <span class="input-shell__suffix">ml</span>
            </div>
          </div>

          <div class="form-row">
            <label class="form-row__label" for="pour-size">How much goes in one drink</label>
            <div class="input-shell">
              <input id="pour-size" name="pour-size" type="number" inputmode="decimal" min="0" step="0.05" placeholder="1.5" value="1.5" autocomplete="off" />
              <span class="input-shell__suffix">fl oz</span>
            </div>
            <p class="form-row__hint">A standard cocktail pour is 1.5 oz. A shot is 1 oz. A heavy pour is 2 oz. A glass of wine is 5 oz, so type 5.</p>
          </div>

          <div class="form-row">
            <label class="form-row__label" for="spillage">Waste and spills</label>
            <div class="input-shell">
              <input id="spillage" name="spillage" type="number" inputmode="decimal" min="0" max="30" step="0.5" placeholder="5" value="5" autocomplete="off" />
              <span class="input-shell__suffix">%</span>
            </div>
            <p class="form-row__hint">A little gets lost to over-pours, spills, and broken bottles. 5% is the usual guess. We trim that much off each bottle.</p>
          </div>

          <div class="form-row">
            <label class="form-row__label" for="drink-price">What you charge for this drink</label>
            <div class="input-shell">
              <span class="input-shell__prefix">$</span>
              <input id="drink-price" name="drink-price" type="number" inputmode="decimal" min="0" step="0.25" placeholder="12" autocomplete="off" />
            </div>
            <p class="form-row__hint">The menu price guests pay. Leave it blank and we just show what the pour costs you.</p>
          </div>

          <details class="optional-fields">
            <summary class="optional-fields__trigger">
              <span class="optional-fields__icon" aria-hidden="true">+</span>
              Get a suggested price for your goal (optional)
            </summary>
            <div class="optional-fields__body">
              <div class="form-row">
                <label class="form-row__label" for="target-pd">Your goal pour cost %</label>
                <div class="input-shell">
                  <input id="target-pd" name="target-pd" type="number" inputmode="decimal" min="0" max="100" step="0.5" placeholder="22" autocomplete="off" />
                  <span class="input-shell__suffix">%</span>
                </div>
                <p class="form-row__hint">The number you want to hit. We tell you the menu price that gets you there.</p>
              </div>
            </div>
          </details>
        </div>

        <p class="calc-form__live">
          <span class="calc-form__live-dot" aria-hidden="true"></span>
          Updates live as you type. <strong>Nothing is saved or sent</strong>, the math runs in your browser.
        </p>
      </form>

      <aside class="calc-result">
        <div class="calc-result__card" aria-live="polite" aria-atomic="true">
          <div class="calc-result__head">
            <span class="t-micro calc-result__label" data-result-label>Liquor pour cost</span>
            <span class="status-pill" data-status="empty">
              <span class="status-pill__dot"></span><span data-status-label>Enter values</span>
            </span>
          </div>

          <div class="calc-result__big">
            <span class="result-num" data-counter>0.0</span>
            <span class="result-num__pct" aria-hidden="true">%</span>
            <span class="visually-hidden">percent pour cost</span>
          </div>

          <div class="calc-result__benchmark">
            <span class="t-caption">Healthy range</span>
            <span class="t-caption num" data-benchmark>18–24%</span>
          </div>

          <div class="calc-result__bar">
            <div class="bar-track">
              <div class="bar-zone bar-zone--lean" data-zone-lean></div>
              <div class="bar-zone bar-zone--good" data-zone-good></div>
              <div class="bar-zone bar-zone--watch" data-zone-watch></div>
              <div class="bar-zone bar-zone--bad" data-zone-bad></div>
              <div class="bar-marker" data-marker style="left: 0%"></div>
            </div>
            <div class="bar-labels">
              <span class="t-caption num">0%</span>
              <span class="t-caption num">25%</span>
              <span class="t-caption num">50%</span>
            </div>
          </div>

          <div class="calc-result__extras" data-extras hidden>
            <div class="extras-row" data-target-row hidden>
              <span class="extras-row__label">Vs. your goal</span>
              <span class="extras-row__value num" data-target-variance></span>
            </div>
            <div class="extras-row" data-target-money-row hidden>
              <span class="extras-row__label">What hitting your goal saves</span>
              <span class="extras-row__value num" data-target-money></span>
            </div>
            <div class="extras-row" data-theoretical-row hidden>
              <span class="extras-row__label">Vs. recipe cost</span>
              <span class="extras-row__value num" data-theoretical-variance></span>
            </div>
          </div>

          <button type="button" class="result-share" data-share-open aria-haspopup="dialog">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><path d="M8.6 13.5l6.8 4M15.4 6.5l-6.8 4"/></svg>
            Share these numbers
          </button>
        </div>

        <details class="show-math" data-math-wrap>
          <summary class="show-math__trigger">
            <span class="show-math__icon" aria-hidden="true">+</span>
            Show your math
          </summary>
          <div class="show-math__body" data-math>
            <p class="t-caption">Enter values above to see the calculation.</p>
          </div>
        </details>
      </aside>
    </section>

    <section class="essay">
      <p class="essay__eyebrow t-micro t-micro--saffron">Why this matters</p>
      <h2 class="essay__headline">Liquor cost is <em>velocity-driven</em>.</h2>
      <div class="essay__body">
        <p>
          Food cost moves on inventory cycles, weeks, sometimes months. Liquor cost moves on pours, in real time. Every drink poured is a small inventory transaction. A 0.2-oz over-pour times 800 cocktails a week is 160 ounces of liquor walking out the door uncharged.
        </p>
        <p>
          The math is unforgiving. A bottle of well vodka costs ~$15 wholesale. At 1.5oz spec, that's ~$0.59 per pour. At 1.7oz actual, it's $0.67. Eight cents, eight hundred times = $64/week, $3,300/year per bartender. Most bars have three.
        </p>
        <p class="essay__pull">
          The operators who control liquor cost don't run smarter calculators. They use measured pour spouts, jiggers on every well, and weekly variance checks on the top 10 bottles. Those three habits beat any software stack.
        </p>
        <p>
          Track each category separately. A blended pour cost number hides which category is leaking. Wine and beer behave differently from spirits, different supplier dynamics, different markup conventions, different theft profiles.
        </p>
      </div>
    </section>

    <hr class="rule" aria-hidden="true" />

    <!-- Operator story: Cosmos bar + nightclub -->
    <section class="operator-story">
      <img src="/illustrations/liquor-pour-cost.webp" alt="Editorial illustration of a bartender's hand pouring spirits from a bottle into a measuring jigger over a rocks glass under low golden bar light." class="operator-story__hero" width="1264" height="848" loading="lazy" />
      <p class="essay__eyebrow t-micro t-micro--saffron">From behind the bar</p>
      <h2 class="essay__headline">Five years on the bar taught me <em>where the money actually leaks</em>.</h2>
      <div class="essay__body">
        <p>
          I started at Cosmos as a bartender and worked my way up to GM. I ran the bar and the nightclub for five years solid. In that time I've watched every kind of pour cost leak you can imagine, and most of them aren't theft, they're habits nobody flagged.
        </p>
        <p>
          The biggest one was free pours on the well. New bartenders don't trust jiggers. They eyeball it because that's what they saw on YouTube. Two ounces becomes two-and-a-half before anyone notices. Multiply by three hundred drinks on a Saturday night and you've quietly given away more product than a comp tab would have flagged. Nobody's stealing. Nobody's malicious. It just bleeds.
        </p>
        <p>
          The second one was buyback culture. Regulars walked in, the bartender bought their first round, the second round was on the house "for being cool." On a slow Tuesday it built loyalty. On a busy Saturday it cost real money, and nobody was tracking it as a cost line, just as goodwill.
        </p>
        <p class="essay__pull">
          The bartender who pours by feel, the bartender who buys back too generously, the bartender skimming a bottle a week, to the pour cost percentage, they look identical. The number tells you something is wrong. It doesn't tell you which kind of wrong.
        </p>
        <p>
          The third one was the one I had to learn the hard way: when the owner's not engaged in the bar program, the bar program drifts. I was running variance reports myself for three of those five years because nobody else was. The math is simple. The discipline of doing the math weekly, counting the bottles, comparing to POS, finding the gap, is the entire game.
        </p>
        <p>
          That's what this calculator is for. Per-drink mode tells you what each pour <em>should</em> cost. Aggregate mode tells you whether your program is in the healthy band. The gap between those two numbers is where the leaks live. Find them every week, fix them in the same week, and you stay open. Skip a quarter and you're suddenly down four points and don't know why.
        </p>
        <div class="operator-byline">
          <span class="operator-byline__dash">Signed</span>
          <span class="operator-byline__name">Brock Markarian</span>
          <span class="operator-byline__role">Founder · 5 yrs at Cosmos Taverna (Bartender → GM)</span>
        </div>
      </div>
    </section>

    <hr class="rule" aria-hidden="true" />

    <section class="benchmarks">
      <h2 class="benchmarks__headline">Benchmarks <em>by beverage category</em></h2>
      <p class="t-body-large benchmarks__intro">
        Each beverage category has its own healthy range. Spirits are tightest (high markup, small pours). Wine is loosest (premium product, smaller markup convention). Track separately.
      </p>
      <div class="benchmarks__chart">
        {benchmarks.map((b) => (
          <div class="bench-bar">
            <div class="bench-bar__name">{b.name}</div>
            <div class="bench-bar__track">
              <div class="bench-bar__zone" style={`left: ${b.low * 2}%; width: ${(b.high - b.low) * 2}%`}></div>
              <div class="bench-bar__tick" style={`left: ${b.low * 2}%`}></div>
              <div class="bench-bar__tick" style={`left: ${b.high * 2}%`}></div>
            </div>
            <div class="bench-bar__range num">{b.low}–{b.high}%</div>
          </div>
        ))}
        <div class="bench-axis">
          <div class="bench-axis__track">
            <span class="bench-axis__tick num" style="left: 0%">0%</span>
            <span class="bench-axis__tick num" style="left: 20%">10%</span>
            <span class="bench-axis__tick num" style="left: 40%">20%</span>
            <span class="bench-axis__tick num" style="left: 60%">30%</span>
            <span class="bench-axis__tick num" style="left: 80%">40%</span>
            <span class="bench-axis__tick num" style="left: 100%">50%</span>
          </div>
        </div>
      </div>
    </section>

    <div class="container ad-wrap">
      <aside class="ad-inline">
        <span class="ad-inline__label">Advertisement</span>
        <div class="ad-inline__inner">
          <ins class="adsbygoogle"
               style="display:block"
               data-ad-client="ca-pub-6332696231897305"
               data-ad-slot="0000000000"
               data-ad-format="auto"
               data-full-width-responsive="true"
               data-adtest="on"></ins>
          <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
        </div>
      </aside>
    </div>

    <section class="scenarios">
      <p class="t-micro t-micro--saffron">Real scenarios</p>
      <h2 class="scenarios__headline">Three programs, three different leaks</h2>
      <p class="t-body-large scenarios__intro">
        High pour cost is a symptom. The cause is usually one of three things, or a combination.
      </p>
      <div class="scenarios__grid">
        {scenarios.map((s, i) => (
          <article class="scenario-card">
            <span class="scenario-card__num num">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="scenario-card__title">{s.title}</h3>
            <p class="scenario-card__setup">{s.setup}</p>
            <div class="scenario-card__row">
              <span class="scenario-card__label">Diagnosis</span>
              <p class="scenario-card__text">{s.diagnosis}</p>
            </div>
            <div class="scenario-card__row">
              <span class="scenario-card__label">Fix</span>
              <p class="scenario-card__text">{s.fix}</p>
            </div>
            <div class="scenario-card__row scenario-card__row--outcome">
              <span class="scenario-card__label">Outcome</span>
              <p class="scenario-card__text"><strong>{s.outcome}</strong></p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <hr class="rule" aria-hidden="true" />

    <section class="calc-faq">
      <p class="t-micro t-micro--saffron">FAQ</p>
      <h2 class="calc-faq__headline">Common questions</h2>
      {faq.map((f, i) => (
        <details class="calc-faq__item">
          <summary class="calc-faq__q">
            <span class="calc-faq__num">{String(i + 1).padStart(2, '0')}</span>
            <span class="calc-faq__qtext">{f.q}</span>
            <span class="calc-faq__plus" aria-hidden="true">+</span>
          </summary>
          <p class="calc-faq__a">{f.a}</p>
        </details>
      ))}
    </section>

    <section class="cited-sources">
      <p class="t-micro t-micro--saffron">Cited sources</p>
      <ul>
        <li><a href="https://pos.toasttab.com/blog/on-the-line/how-to-calculate-pour-cost" target="_blank" rel="noopener">Toast, How to Calculate Pour Cost</a></li>
        <li><a href="https://home.binwise.com/blog/pour-cost" target="_blank" rel="noopener">BinWise, Pour Cost Guide</a></li>
        <li><a href="https://bevspot.com/" target="_blank" rel="noopener">BevSpot, Bar Inventory & Pour Cost Benchmarks</a></li>
        <li><a href="https://www.usbg.org/" target="_blank" rel="noopener">USBG, United States Bartenders' Guild Standards</a></li>
      </ul>
    </section>

    <section class="related">
      <h2 class="related__headline">Related calculators</h2>
      <div class="related__grid">
        {relatedCalcs.map((c, i) => (
          <a href={`/calculators/${c.slug}/`} class="related-card">
            <div class="related-card__top">
              <span class="related-card__num num">{String(i + 1).padStart(2, '0')}</span>
              <span class="t-micro"><strong style="color:var(--color-saffron-text)">Free</strong> · 2 min</span>
            </div>
            <h3 class="related-card__title">{c.title}</h3>
            <p class="t-body related-card__desc">{c.desc}</p>
            <span class="related-card__arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </section>
  </article>
</Layout>

<script>
  // Category-specific thresholds + benchmarks
  const CATEGORIES: Record<string, { label: string; low: number; high: number; barZones: { lean: number; good: number; watch: number } }> = {
    liquor:        { label: 'Liquor / spirits', low: 18, high: 24, barZones: { lean: 36, good: 12, watch: 8 } },
    'beer-draft':  { label: 'Draft beer',       low: 18, high: 24, barZones: { lean: 36, good: 12, watch: 8 } },
    'beer-bottle': { label: 'Bottled beer',     low: 25, high: 30, barZones: { lean: 50, good: 10, watch: 8 } },
    'wine-glass':  { label: 'Wine by glass',    low: 28, high: 32, barZones: { lean: 56, good: 8,  watch: 8 } },
    'wine-bottle': { label: 'Wine by bottle',   low: 30, high: 40, barZones: { lean: 60, good: 20, watch: 8 } },
    blended:       { label: 'Blended program',  low: 20, high: 25, barZones: { lean: 40, good: 10, watch: 8 } },
  };

  const form = document.querySelector('[data-form]') as HTMLFormElement | null;
  const counter = document.querySelector('[data-counter]') as HTMLElement | null;
  const marker = document.querySelector('[data-marker]') as HTMLElement | null;
  const statusPill = document.querySelector('.status-pill') as HTMLElement | null;
  const statusLabel = document.querySelector('[data-status-label]') as HTMLElement | null;
  const resultLabel = document.querySelector('[data-result-label]') as HTMLElement | null;
  const benchmarkEl = document.querySelector('[data-benchmark]') as HTMLElement | null;
  const mathBody = document.querySelector('[data-math]') as HTMLElement | null;
  const mathWrap = document.querySelector('[data-math-wrap]') as HTMLDetailsElement | null;
  const extras = document.querySelector('[data-extras]') as HTMLElement | null;
  const targetRow = document.querySelector('[data-target-row]') as HTMLElement | null;
  const targetVarEl = document.querySelector('[data-target-variance]') as HTMLElement | null;
  const targetMoneyRow = document.querySelector('[data-target-money-row]') as HTMLElement | null;
  const targetMoneyEl = document.querySelector('[data-target-money]') as HTMLElement | null;
  const theoreticalRow = document.querySelector('[data-theoretical-row]') as HTMLElement | null;
  const theoreticalVarEl = document.querySelector('[data-theoretical-variance]') as HTMLElement | null;
  const zoneLean = document.querySelector('[data-zone-lean]') as HTMLElement | null;
  const zoneGood = document.querySelector('[data-zone-good]') as HTMLElement | null;
  const zoneWatch = document.querySelector('[data-zone-watch]') as HTMLElement | null;
  const zoneBad = document.querySelector('[data-zone-bad]') as HTMLElement | null;

  if (form && counter && marker && statusPill && statusLabel && mathBody) {
    let lastValue = 0;
    let calcDebounce: number | null = null;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function fmtUSD(n: number): string {
      const sign = n < 0 ? '-' : '';
      const abs = Math.abs(n);
      return sign + '$' + abs.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    function fmtSignedUSD(n: number): string {
      const sign = n < 0 ? '−' : '+';
      const abs = Math.abs(n);
      return sign + '$' + abs.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    function animateCounter(el: HTMLElement, from: number, to: number, duration = 800, decimals = 1) {
      if (reduced) { el.textContent = to.toFixed(decimals); return; }
      const start = performance.now();
      const ease = (t: number) => 1 - Math.pow(1 - t, 3);
      function frame(now: number) {
        const t = Math.min((now - start) / duration, 1);
        const value = from + (to - from) * ease(t);
        el.textContent = value.toFixed(decimals);
        if (t < 1) requestAnimationFrame(frame);
        else { el.classList.add('result-num--pulse'); setTimeout(() => el.classList.remove('result-num--pulse'), 320); }
      }
      requestAnimationFrame(frame);
    }

    function statusFor(pct: number, cat: typeof CATEGORIES[string]): { key: string; label: string } {
      const watchHigh = cat.high + 4;
      if (pct < cat.low) return { key: 'lean', label: 'Lean' };
      if (pct <= cat.high) return { key: 'healthy', label: 'Healthy' };
      if (pct <= watchHigh) return { key: 'watch', label: 'Watch' };
      return { key: 'critical', label: 'Critical' };
    }

    function updateCategory() {
      const data = new FormData(form!);
      const catKey = String(data.get('category') || 'liquor');
      const cat = CATEGORIES[catKey] || CATEGORIES.liquor;

      if (resultLabel) resultLabel.textContent = `${cat.label} pour cost`;
      if (benchmarkEl) benchmarkEl.textContent = `${cat.low}–${cat.high}%`;

      // Update bar zones (each unit on the 0-50 scale = 2% of bar width)
      const lowPct = cat.low * 2;
      const highPct = cat.high * 2;
      const watchHighPct = (cat.high + 4) * 2;

      if (zoneLean) { zoneLean.style.left = '0%'; zoneLean.style.width = `${lowPct}%`; }
      if (zoneGood) { zoneGood.style.left = `${lowPct}%`; zoneGood.style.width = `${highPct - lowPct}%`; }
      if (zoneWatch) { zoneWatch.style.left = `${highPct}%`; zoneWatch.style.width = `${watchHighPct - highPct}%`; }
      if (zoneBad) { zoneBad.style.left = `${watchHighPct}%`; zoneBad.style.width = `${100 - watchHighPct}%`; }
    }

    function reset() {
      statusPill!.dataset.status = 'empty';
      statusLabel!.textContent = 'Enter values';
      marker!.style.left = '0%';
      animateCounter(counter!, lastValue, 0, 400, 1);
      lastValue = 0;
      mathBody!.innerHTML = '<p class="t-caption">Enter values above to see the calculation.</p>';
      if (extras) extras.hidden = true;
    }

    const ML_TO_OZ = 0.0338140227;

    function calcPerDrink() {
      const data = new FormData(form!);
      const bottleCost = parseFloat(String(data.get('bottle-cost') || '0')) || 0;
      const sizeKey = String(data.get('bottle-size') || '750');
      const customMl = parseFloat(String(data.get('bottle-size-custom') || '0')) || 0;
      const bottleMl = sizeKey === 'custom' ? customMl : parseFloat(sizeKey);
      const pourSize = parseFloat(String(data.get('pour-size') || '0')) || 0;
      const spillage = parseFloat(String(data.get('spillage') || '5')) || 0;
      const drinkPrice = parseFloat(String(data.get('drink-price') || '0')) || 0;
      const targetPdRaw = parseFloat(String(data.get('target-pd') || ''));
      const targetPd = isNaN(targetPdRaw) ? null : targetPdRaw;
      const catKey = String(data.get('category') || 'liquor');
      const cat = CATEGORIES[catKey] || CATEGORIES.liquor;
      const drinkName = String(data.get('drink-name') || '').trim() || 'this drink';

      if (bottleCost <= 0 || bottleMl <= 0 || pourSize <= 0) { reset(); return; }

      const bottleOz = bottleMl * ML_TO_OZ;
      const usableOz = bottleOz * (1 - Math.min(30, Math.max(0, spillage)) / 100);
      const poursPerBottle = usableOz / pourSize;
      const costPerOz = bottleCost / usableOz;
      const costPerPour = costPerOz * pourSize;
      const pourPct = drinkPrice > 0 ? (costPerPour / drinkPrice) * 100 : 0;
      const profitPerDrink = drinkPrice > 0 ? drinkPrice - costPerPour : 0;
      const suggestedPrice = targetPd && targetPd > 0 ? costPerPour / (targetPd / 100) : 0;

      // Big number: pour cost % if price entered, else cost per pour ($)
      if (drinkPrice > 0) {
        animateCounter(counter!, lastValue, pourPct, 800, 1);
        lastValue = pourPct;
        if (resultLabel) resultLabel.textContent = `Pour cost for ${drinkName}`;
        const pctSuffix = document.querySelector('.result-num__pct');
        if (pctSuffix) pctSuffix.textContent = '%';
        const clamped = Math.min(50, Math.max(0, pourPct));
        marker!.style.left = `${(clamped / 50) * 100}%`;
        const s = statusFor(pourPct, cat);
        statusPill!.dataset.status = s.key;
        statusLabel!.textContent = s.label;
      } else {
        animateCounter(counter!, lastValue, costPerPour, 800, 2);
        lastValue = costPerPour;
        if (resultLabel) resultLabel.textContent = `What ${drinkName} costs you`;
        const pctSuffix = document.querySelector('.result-num__pct');
        if (pctSuffix) pctSuffix.textContent = '';
        marker!.style.left = '0%';
        statusPill!.dataset.status = 'empty';
        statusLabel!.textContent = 'Add a price';
      }

      // Hide aggregate extras, show per-drink extras
      if (extras) extras.hidden = false;
      if (targetRow) targetRow.hidden = true;
      if (targetMoneyRow) targetMoneyRow.hidden = true;
      if (theoreticalRow) theoreticalRow.hidden = true;

      const note = drinkPrice > 0
        ? `A healthy ${cat.label.toLowerCase()} pour runs ${cat.low}–${cat.high}%. You keep ${fmtUSD(profitPerDrink)} on each one.${suggestedPrice > 0 ? ` To hit your ${targetPd}% goal, charge ${fmtUSD(suggestedPrice)}.` : ''}`
        : `Add what you charge to see the pour cost percent and what you keep per drink.${suggestedPrice > 0 ? ` To hit your ${targetPd}% goal, charge ${fmtUSD(suggestedPrice)}.` : ''}`;

      mathBody!.innerHTML = `
        <table class="math-table" role="presentation">
          <tr><td>What the bottle cost</td><td class="num">${fmtUSD(bottleCost)}</td></tr>
          <tr><td>Bottle size</td><td class="num">${bottleMl}ml (${bottleOz.toFixed(2)} fl oz)</td></tr>
          <tr class="math-table__step"><td>− Waste and spills ${spillage}%</td><td class="num">${usableOz.toFixed(2)} oz you can pour</td></tr>
          <tr class="math-table__step"><td>Cost ÷ oz you can pour</td><td class="num">${fmtUSD(costPerOz)}/oz</td></tr>
          <tr class="math-table__step"><td>× ${pourSize} oz per drink</td><td class="num">${fmtUSD(costPerPour)} per drink</td></tr>
          <tr class="math-table__step"><td>Drinks you get per bottle</td><td class="num">${poursPerBottle.toFixed(1)}</td></tr>
          ${drinkPrice > 0 ? `<tr class="math-table__step"><td>Cost ÷ ${fmtUSD(drinkPrice)} menu price</td><td class="num">${pourPct.toFixed(2)}%</td></tr>` : ''}
          ${drinkPrice > 0 ? `<tr class="math-table__final"><td>Pour cost</td><td class="num"><strong>${pourPct.toFixed(1)}%</strong></td></tr>` : `<tr class="math-table__final"><td>What one drink costs you</td><td class="num"><strong>${fmtUSD(costPerPour)}</strong></td></tr>`}
          ${drinkPrice > 0 ? `<tr class="math-table__step"><td>What you keep per drink</td><td class="num">${fmtUSD(profitPerDrink)}</td></tr>` : ''}
          ${suggestedPrice > 0 ? `<tr class="math-table__step"><td>Price to hit your ${targetPd}% goal</td><td class="num">${fmtUSD(suggestedPrice)}</td></tr>` : ''}
        </table>
        <p class="t-caption math-note">${note}</p>
      `;

      if (mathWrap && !mathWrap.open) mathWrap.open = true;
    }

    function calc() {
      const mode = form!.getAttribute('data-mode') || 'aggregate';
      if (mode === 'perdrink') { calcPerDrink(); return; }

      const data = new FormData(form!);
      const cost = parseFloat(String(data.get('cost') || '0')) || 0;
      const revenue = parseFloat(String(data.get('revenue') || '0')) || 0;
      const catKey = String(data.get('category') || 'liquor');
      const cat = CATEGORIES[catKey] || CATEGORIES.liquor;

      // restore aggregate result label
      const pctSuffix = document.querySelector('.result-num__pct');
      if (pctSuffix) pctSuffix.textContent = '%';
      if (resultLabel) resultLabel.textContent = `${cat.label} pour cost`;

      if (cost <= 0 || revenue <= 0) { reset(); return; }

      const pct = (cost / revenue) * 100;
      const clamped = Math.min(50, Math.max(0, pct));
      const markerPos = (clamped / 50) * 100;

      animateCounter(counter!, lastValue, pct, 800, 1);
      lastValue = pct;

      const s = statusFor(pct, cat);
      statusPill!.dataset.status = s.key;
      statusLabel!.textContent = s.label;
      marker!.style.left = `${markerPos}%`;

      // Optional target / theoretical
      const targetRaw = parseFloat(String(data.get('target') || ''));
      const target = isNaN(targetRaw) ? null : targetRaw;
      const theoreticalRaw = parseFloat(String(data.get('theoretical') || ''));
      const theoretical = isNaN(theoreticalRaw) ? null : theoreticalRaw;

      const showExtras = target !== null || theoretical !== null;
      if (extras) extras.hidden = !showExtras;

      if (target !== null && targetRow && targetVarEl && targetMoneyRow && targetMoneyEl) {
        const diff = pct - target;
        targetRow.hidden = false;
        targetVarEl.textContent = `${diff >= 0 ? '+' : '−'}${Math.abs(diff).toFixed(2)}pp`;
        targetVarEl.className = `extras-row__value num ${diff > 0.5 ? 'is-bad' : diff < -0.5 ? 'is-lean' : 'is-good'}`;
        targetMoneyRow.hidden = false;
        const targetCost = revenue * (target / 100);
        const moneyDiff = cost - targetCost;
        targetMoneyEl.textContent = moneyDiff >= 0 ? `${fmtSignedUSD(moneyDiff)} over goal` : `${fmtSignedUSD(moneyDiff)} under goal`;
        targetMoneyEl.className = `extras-row__value num ${moneyDiff > 0 ? 'is-bad' : 'is-good'}`;
      } else if (targetRow && targetMoneyRow) {
        targetRow.hidden = true;
        targetMoneyRow.hidden = true;
      }

      if (theoretical !== null && theoreticalRow && theoreticalVarEl) {
        const tDiff = pct - theoretical;
        theoreticalRow.hidden = false;
        theoreticalVarEl.textContent = `${tDiff >= 0 ? '+' : '−'}${Math.abs(tDiff).toFixed(2)} points off`;
        theoreticalVarEl.className = `extras-row__value num ${Math.abs(tDiff) > 5 ? 'is-bad' : Math.abs(tDiff) > 2 ? 'is-watch' : 'is-good'}`;
      } else if (theoreticalRow) {
        theoreticalRow.hidden = true;
      }

      let note = '';
      if (s.label === 'Healthy') note = `Your ${cat.label.toLowerCase()} is in a healthy range. Keep checking it weekly, focus on your 10 best-selling bottles.`;
      if (s.label === 'Lean') note = `Lower than usual, double-check your numbers. It can mean pours are too light, which guests notice, or that your cost is undercounted.`;
      if (s.label === 'Watch') note = `A little high. Usual causes: heavy free pours on the well, too many comped drinks, or menu prices that never kept up with cost.`;
      if (s.label === 'Critical') note = `Higher than healthy. Things to check: are bartenders using measured pour spouts? Are comps rung up in the POS? Count your top 5 bottles against what the POS says you sold.`;

      mathBody!.innerHTML = `
        <table class="math-table" role="presentation">
          <tr><td>What the drinks cost you</td><td class="num">${fmtUSD(cost)}</td></tr>
          <tr><td>What you sold them for</td><td class="num">${fmtUSD(revenue)}</td></tr>
          <tr class="math-table__step"><td>Cost ÷ sales</td><td class="num">${(cost / revenue).toFixed(4)}</td></tr>
          <tr class="math-table__step"><td>× 100</td><td class="num">${pct.toFixed(2)}%</td></tr>
          <tr class="math-table__final"><td>${cat.label} pour cost</td><td class="num"><strong>${pct.toFixed(1)}%</strong></td></tr>
        </table>
        ${note ? `<p class="t-caption math-note">${note}</p>` : ''}
      `;

      if (mathWrap && !mathWrap.open) mathWrap.open = true;
    }

    function debouncedCalc() {
      if (calcDebounce !== null) clearTimeout(calcDebounce);
      calcDebounce = window.setTimeout(calc, 250);
    }

    form.addEventListener('input', () => { updateCategory(); toggleCustomSize(); debouncedCalc(); });
    form.addEventListener('change', () => { updateCategory(); toggleCustomSize(); debouncedCalc(); });
    form.addEventListener('submit', (e) => { e.preventDefault(); if (calcDebounce !== null) clearTimeout(calcDebounce); calc(); });

    function toggleCustomSize() {
      const sizeSel = document.querySelector('#bottle-size') as HTMLSelectElement | null;
      const customRow = document.querySelector('[data-custom-size-row]') as HTMLElement | null;
      if (sizeSel && customRow) customRow.hidden = sizeSel.value !== 'custom';
    }

    function setMode(mode: string) {
      form!.setAttribute('data-mode', mode);
      const aggPanel = document.querySelector('[data-panel-aggregate]') as HTMLElement | null;
      const pdPanel = document.querySelector('[data-panel-perdrink]') as HTMLElement | null;
      if (aggPanel) aggPanel.hidden = mode !== 'aggregate';
      if (pdPanel) pdPanel.hidden = mode !== 'perdrink';
      document.querySelectorAll('[data-mode-tab]').forEach((el) => {
        const t = el as HTMLButtonElement;
        const active = t.dataset.modeTab === mode;
        t.setAttribute('aria-selected', active ? 'true' : 'false');
        t.classList.toggle('mode-tab--active', active);
      });
      // Reset counter + result card to match new mode
      const pctSuffix = document.querySelector('.result-num__pct') as HTMLElement | null;
      if (mode === 'aggregate' && pctSuffix) pctSuffix.textContent = '%';
      calc();
    }

    document.querySelectorAll('[data-mode-tab]').forEach((el) => {
      el.addEventListener('click', () => {
        const m = (el as HTMLButtonElement).dataset.modeTab || 'aggregate';
        setMode(m);
      });
    });

    setMode('aggregate');
    updateCategory();
    toggleCustomSize();

    function loadExample() {
      const mode = form!.getAttribute('data-mode') || 'aggregate';
      if (mode === 'perdrink') {
        (document.querySelector('#drink-name') as HTMLInputElement).value = 'Vodka soda';
        (document.querySelector('#bottle-cost') as HTMLInputElement).value = '22.50';
        (document.querySelector('#bottle-size') as HTMLSelectElement).value = '750';
        (document.querySelector('#pour-size') as HTMLInputElement).value = '1.5';
        (document.querySelector('#spillage') as HTMLInputElement).value = '5';
        (document.querySelector('#drink-price') as HTMLInputElement).value = '12';
        (document.querySelector('#target-pd') as HTMLInputElement).value = '20';
      } else {
        (document.querySelector('#category') as HTMLSelectElement).value = 'liquor';
        (document.querySelector('#cost') as HTMLInputElement).value = '2200';
        (document.querySelector('#revenue') as HTMLInputElement).value = '11000';
      }
      updateCategory();
      toggleCustomSize();
      calc();
    }
    const loadExBtn = document.querySelector('[data-load-example]');
    if (loadExBtn) loadExBtn.addEventListener('click', loadExample);
    loadExample();
  }
</script>

<style>
  .calc-page { padding: var(--space-12) var(--space-6) var(--space-24); max-width: 1180px; margin: 0 auto; }
  .breadcrumb { display: flex; align-items: center; gap: var(--space-2); font-family: var(--font-body); font-size: 0.8125rem; color: var(--color-muted); margin-bottom: var(--space-8); }
  .breadcrumb a { color: var(--color-muted); transition: color var(--transition-fast); }
