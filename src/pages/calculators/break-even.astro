---
import Layout from '../../layouts/Layout.astro';

const title = 'Restaurant Break-Even Calculator, Free | RestaurantCalcs';
const description = 'Restaurant break-even calculator. Fixed + variable costs, contribution margin, Margin of Safety + capacity check. Covers per day output.';

const faq = [
  {
    q: 'What is break-even revenue for a restaurant?',
    a: 'Break-even revenue is the amount of sales you need to cover all costs, both fixed (rent, salaries, insurance, utilities) and variable (food cost, variable labor, paper goods). At break-even revenue, profit equals zero. Anything above is profit; anything below is loss.',
  },
  {
    q: 'What is the break-even formula?',
    a: 'Break-Even Revenue = Fixed Costs ÷ (1 − Variable Cost %). If your fixed costs are $40,000/month and variable costs run 60% of revenue, break-even = $40,000 ÷ (1 − 0.60) = $100,000 in monthly revenue.',
  },
  {
    q: 'What counts as a fixed cost?',
    a: 'Fixed costs do not change with sales volume. Rent, manager salaries, insurance, base utilities, internet, accounting, software subscriptions, loan payments, and depreciation. Hourly labor is variable, not fixed, staff scales with hours scheduled.',
  },
  {
    q: 'What counts as a variable cost?',
    a: 'Variable costs change with revenue. Food cost (roughly 28–32% of food sales for full-service), beverage cost (20–25%), hourly labor (15–25% depending on concept), paper goods, payment processing fees (~3%), and marketing tied to sales (delivery commissions). Add these as a percentage of revenue.',
  },
  {
    q: 'How do I calculate break-even covers per day?',
    a: 'Break-Even Covers = Break-Even Revenue ÷ Average Ticket. If you need $100,000/month in revenue and your average ticket is $35, you need 2,857 covers per month, or about 95 covers per day on a 30-day month. Use this to sanity-check whether your concept can support its rent.',
  },
  {
    q: 'My break-even covers seem impossible, what now?',
    a: 'Three levers, in order of speed: (1) raise average ticket through pricing, upsells, or beverage program, (2) cut variable cost % through portion control or vendor renegotiation, (3) cut fixed cost, usually means renegotiating rent or trimming a salaried position. The fastest is almost always raising average ticket; the hardest is cutting fixed cost.',
  },
  {
    q: 'How does break-even change with seasonality?',
    a: 'Break-even is the same every month, but achievable revenue isn\'t. Concepts with strong seasons (beach restaurants, ski-town bars) need to bank profit during peak months to cover off-season losses. Calculate annual break-even rather than monthly, and make sure peak-season margin is high enough to subsidize the slow months.',
  },
  {
    q: 'What is contribution margin?',
    a: 'Contribution margin is the percentage of each dollar of revenue that "contributes" to fixed costs and profit, after variable costs are paid. Formula: 1 − Variable Cost %. If variable costs are 60%, contribution margin is 40%. The higher the contribution margin, the lower the break-even revenue.',
  },
  {
    q: 'Does this calculator save my data?',
    a: 'No. Nothing is stored, transmitted, or tracked. The calculation runs entirely in your browser and disappears the moment you close the tab. No signup, no email, no account.',
  },
];

const schema = [
  { '@context': 'https://schema.org', '@type': 'WebPage', '@id': 'https://restaurantcalcs.com/calculators/break-even/#webpage', url: 'https://restaurantcalcs.com/calculators/break-even/', name: title, description, isPartOf: { '@id': 'https://restaurantcalcs.com/#website' }, breadcrumb: { '@id': 'https://restaurantcalcs.com/calculators/break-even/#breadcrumb' }, inLanguage: 'en-US' },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', '@id': 'https://restaurantcalcs.com/calculators/break-even/#breadcrumb', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://restaurantcalcs.com/' },
    { '@type': 'ListItem', position: 2, name: 'Calculators', item: 'https://restaurantcalcs.com/' },
    { '@type': 'ListItem', position: 3, name: 'Restaurant Break-Even', item: 'https://restaurantcalcs.com/calculators/break-even/' },
  ] },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    '@id': 'https://restaurantcalcs.com/calculators/break-even/#tool',
    name: 'Restaurant Break-Even Calculator',
    description: 'Free web-based break-even calculator. Fixed costs ÷ contribution margin = monthly break-even. Optional Margin of Safety + capacity check (seats × turns).',
    applicationCategory: 'BusinessApplication',
    applicationSubCategory: 'Restaurant Management',
    operatingSystem: 'Web',
    browserRequirements: 'Requires JavaScript',
    url: 'https://restaurantcalcs.com/calculators/break-even/',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    creator: { '@id': 'https://restaurantcalcs.com/#organization' },
    author: { '@id': 'https://restaurantcalcs.com/#founder' },
    isAccessibleForFree: true,
  },
  { '@context': 'https://schema.org', '@type': 'HowTo', name: 'How to calculate restaurant break-even revenue', totalTime: 'PT3M', supply: [
    { '@type': 'HowToSupply', name: 'Total fixed costs (in dollars)' },
    { '@type': 'HowToSupply', name: 'Variable cost percentage' },
    { '@type': 'HowToSupply', name: 'Average ticket (in dollars)' },
  ], step: [
    { '@type': 'HowToStep', position: 1, name: 'Sum fixed costs', text: 'Add rent, salaries, insurance, utilities, software, loan payments, and other costs that don\'t change with sales.' },
    { '@type': 'HowToStep', position: 2, name: 'Estimate variable cost percentage', text: 'Add food cost, beverage cost, hourly labor, paper goods, and processing fees as a single percentage of revenue.' },
    { '@type': 'HowToStep', position: 3, name: 'Calculate contribution margin', text: 'Contribution Margin = 1 − Variable Cost %. This is the share of each dollar that goes to fixed costs and profit.' },
    { '@type': 'HowToStep', position: 4, name: 'Divide fixed costs by contribution margin', text: 'Break-Even Revenue = Fixed Costs ÷ Contribution Margin. Then divide by average ticket for break-even covers.' },
  ] },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
];

const scenarios = [
  {
    title: 'The 110-cover deficit',
    setup: 'New casual concept, 80 seats. Fixed $48K/month, variable 65%. Average ticket $32. Owner thought $120K/month was achievable.',
    diagnosis: 'Break-even = $48K ÷ 0.35 = $137K/month. At $32 average ticket = 4,300 covers/month, ~143/day. Restaurant capacity at 1.5 turns × 80 seats × 30 days = 3,600 covers. Concept could not break even at full capacity.',
    fix: 'Raised average ticket to $42 with stronger beverage program and entree repositioning. New break-even covers: 109/day. Achievable.',
    outcome: 'Break-even hit month 5. Profit by month 7. Lesson: model break-even before signing the lease, not after opening.',
  },
  {
    title: 'The 5-pp cost cut',
    setup: 'Established casual diner, hitting break-even but not profit. Owner debated $30K kitchen renovation to attract more covers.',
    diagnosis: 'Math showed cutting variable cost from 64% to 59% (achievable through portion control + vendor switch) would lower break-even by $24K/month. Renovation was the wrong move, variable cost was the lever.',
    fix: 'Skipped renovation. Implemented weekly food cost variance, switched 2 produce suppliers, retrained on portion scales.',
    outcome: 'Variable cost down to 60% in 8 weeks. $19K/month margin recovery without spending capital. Renovation moved to year 3.',
  },
  {
    title: 'The seasonal banker',
    setup: 'Beach concept, 4 peak months at $250K/month, 8 off-season months at $80K/month. Annual revenue $1.64M. Owner stressed every November.',
    diagnosis: 'Break-even at $130K/month required peak season to over-deliver enough to cover off-season shortfall. Calculated annual break-even $1.56M, they cleared it but barely.',
    fix: 'Raised peak season prices 8% (no measurable resistance). Added off-season catering. Built cash reserve in peak months specifically tagged for off-season.',
    outcome: 'Same business, much lower stress. Break-even cushion grew from 5% to 14% over two years.',
  },
];

const relatedCalcs = [
  { slug: 'prime-cost', title: 'Prime Cost', desc: 'Variable cost driver of break-even.' },
  { slug: 'labor-cost', title: 'Labor Cost Percentage', desc: 'Mix of fixed and variable.' },
  { slug: 'menu-pricing', title: 'Menu Pricing', desc: 'Raise average ticket.' },
];
---

<Layout {title} {description} {schema}>
  <article class="calc-page">
    <header class="calc-page__header">
      <nav class="breadcrumb" aria-label="Breadcrumb"><a href="/">Home</a><span aria-hidden="true">/</span><span>Break-Even Calculator</span></nav>
      <p class="t-micro t-micro--saffron calc-page__eyebrow">Break-even calculator · <strong>100% free · no signup</strong></p>
      <h1 class="calc-page__title">Restaurant Break-Even Calculator</h1>
      <p class="calc-page__intro">
        The number you need to hit before you make a dollar. Fixed costs ÷ contribution margin = break-even revenue. Run this <strong>before</strong> you sign the lease, not after you open and discover the math doesn’t work.
      </p>
    </header>

    <section class="calc-grid">
      <form class="calc-form" data-form>
        <div class="form-intro">
          <p class="form-intro__what"><strong>What this does:</strong> Calculates the revenue you need to cover all costs. Fixed costs (rent, salaries, insurance) ÷ contribution margin (1 − variable %) = break-even. Run before signing a lease.</p>
          <button type="button" class="form-intro__example" data-load-example>Try with example numbers</button>
        </div>

        <div class="form-row">
          <label class="form-row__label" for="fixed">Fixed costs (monthly)</label>
          <div class="input-shell">
            <span class="input-shell__prefix">$</span>
            <input id="fixed" name="fixed" type="number" inputmode="decimal" min="0" step="100" placeholder="40000" autocomplete="off" required />
          </div>
          <p class="form-row__hint">Rent, salaries, insurance, utilities, software, loan payments, everything that doesn’t scale with sales.</p>
        </div>

        <div class="form-row">
          <label class="form-row__label" for="variable">Variable cost %</label>
          <div class="input-shell">
            <input id="variable" name="variable" type="number" inputmode="decimal" min="0" max="99" step="0.5" placeholder="60" autocomplete="off" required />
            <span class="input-shell__suffix">%</span>
          </div>
          <p class="form-row__hint">Food cost + beverage cost + hourly labor + paper + processing fees as % of revenue. Typical full-service: 55–65%.</p>
        </div>

        <div class="form-row">
          <label class="form-row__label" for="avgticket">Average ticket</label>
          <div class="input-shell">
            <span class="input-shell__prefix">$</span>
            <input id="avgticket" name="avgticket" type="number" inputmode="decimal" min="0" step="0.5" placeholder="35" autocomplete="off" />
          </div>
          <p class="form-row__hint">Optional, used to calculate break-even covers and daily target.</p>
        </div>

        <div class="form-row">
          <label class="form-row__label" for="days">Operating days per month</label>
          <select id="days" name="days">
            <option value="22">22 (closed Sundays + Mondays)</option>
            <option value="26" selected>26 (closed Sundays)</option>
            <option value="30">30 (open all month)</option>
            <option value="20">20 (lunch only, M–F)</option>
          </select>
        </div>

        <details class="optional-fields">
          <summary class="optional-fields__trigger">
            <span class="optional-fields__icon" aria-hidden="true">+</span>
            Margin of Safety + capacity check (optional)
          </summary>
          <div class="optional-fields__body">
            <div class="form-row">
              <label class="form-row__label" for="actual-sales">Current monthly sales</label>
              <div class="input-shell">
                <span class="input-shell__prefix">$</span>
                <input id="actual-sales" name="actual-sales" type="number" inputmode="decimal" min="0" step="0.01" placeholder="160000" autocomplete="off" />
              </div>
              <p class="form-row__hint">Returns Margin of Safety: how far above break-even you're operating.</p>
            </div>
            <div class="form-row">
              <label class="form-row__label" for="seats">Seats</label>
              <div class="input-shell">
                <input id="seats" name="seats" type="number" inputmode="decimal" min="0" step="1" placeholder="80" autocomplete="off" />
                <span class="input-shell__suffix">seats</span>
              </div>
            </div>
            <div class="form-row">
              <label class="form-row__label" for="turns">Avg turns per day</label>
              <div class="input-shell">
                <input id="turns" name="turns" type="number" inputmode="decimal" min="0" step="0.1" placeholder="1.5" autocomplete="off" />
                <span class="input-shell__suffix">turns</span>
              </div>
              <p class="form-row__hint">Used to flag if your break-even covers/day exceeds 80% of capacity.</p>
            </div>
          </div>
        </details>

        <button type="submit" class="btn btn-primary btn-large calc-form__submit">
          Calculate break-even
          <span class="btn__arrow" aria-hidden="true">→</span>
        </button>

        <p class="calc-form__privacy t-caption"><strong>Nothing is saved or sent.</strong> All math runs in your browser.</p>
      </form>

      <aside class="calc-result">
        <div class="calc-result__card" aria-live="polite" aria-atomic="true">
          <div class="calc-result__head">
            <span class="t-micro calc-result__label">Break-even revenue / month</span>
          </div>

          <div class="calc-result__big calc-result__big--money">
            <span class="result-num__pct" aria-hidden="true">$</span>
            <span class="result-num" data-counter>0</span>
          </div>

          <div class="calc-result__benchmark">
            <span class="t-caption">Contribution margin</span>
            <span class="t-caption num" data-margin></span>
          </div>

          <div class="calc-result__extras">
            <div class="extras-row">
              <span class="extras-row__label">Break-even covers / month</span>
              <span class="extras-row__value num" data-covers-month></span>
            </div>
            <div class="extras-row">
              <span class="extras-row__label">Break-even covers / day</span>
              <span class="extras-row__value num" data-covers-day></span>
            </div>
            <div class="extras-row">
              <span class="extras-row__label">Daily revenue target</span>
              <span class="extras-row__value num" data-rev-day></span>
            </div>
            <div class="extras-row" data-mos-row hidden>
              <span class="extras-row__label">Margin of Safety</span>
              <span class="extras-row__value num" data-mos></span>
            </div>
            <div class="extras-row" data-capacity-row hidden>
              <span class="extras-row__label">Capacity utilization at BE</span>
              <span class="extras-row__value num" data-capacity></span>
            </div>
          </div>
        </div>

        <details class="show-math" data-math-wrap>
          <summary class="show-math__trigger">
            <span class="show-math__icon" aria-hidden="true">+</span>
            Show your math
          </summary>
          <div class="show-math__body" data-math>
            <p class="t-caption">Enter values above to see the calculation.</p>
          </div>
        </details>
      </aside>
    </section>

    <section class="essay">
      <img src="/illustrations/break-even.webp" alt="Editorial illustration of an accountant's open ledger book with an upward trending hand-drawn line graph in ink, a coffee ring on the page, and a vintage calculator and reading glasses beside it." class="operator-story__hero" width="1264" height="848" loading="lazy" />
      <p class="essay__eyebrow t-micro t-micro--saffron">Why this matters</p>
      <h2 class="essay__headline">Break-even tells you if the <em>concept works at all</em>.</h2>
      <div class="essay__body">
        <p>
          Most restaurants fail because the math never worked from day one. Owner falls in love with a space, signs a lease, builds out, opens, and only afterward calculates that they need 180 covers a day in a 60-seat dining room with 1.2 turns to break even.
        </p>
        <p>
          Break-even is the cheapest insurance in the industry. Five minutes of math in a spreadsheet before signing the lease can save five years of grinding through a concept that was mathematically broken from the start.
        </p>
        <p class="essay__pull">
          Run break-even three ways: realistic (mid-case sales projection), optimistic (top-quartile covers), pessimistic (bottom-quartile covers). If pessimistic break-even isn't survivable, the concept is too fragile to launch.
        </p>
        <p>
          After opening, break-even becomes the floor. Every month above is profit. Every month below means digging into reserves or owner cash. Track actual revenue against break-even weekly, not monthly, small adjustments to staffing or pricing in week 2 are easier than emergency cuts in month 6.
        </p>
      </div>
    </section>

    <hr class="rule" aria-hidden="true" />

    <div class="container ad-wrap">
      <aside class="ad-inline">
        <span class="ad-inline__label">Advertisement</span>
        <div class="ad-inline__inner">
          <ins class="adsbygoogle"
               style="display:block"
               data-ad-client="ca-pub-6332696231897305"
               data-ad-slot="0000000000"
               data-ad-format="auto"
               data-full-width-responsive="true"
               data-adtest="on"></ins>
          <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
        </div>
      </aside>
    </div>

    <hr class="rule" aria-hidden="true" />

    <section class="operator-story">
      <p class="essay__eyebrow t-micro t-micro--saffron">The busiest place I watched close</p>
      <h2 class="essay__headline">Packed every night, <em>and still closing</em>.</h2>
      <div class="essay__body">
        <p>
          There was a spot near us that was always full. Line out the door on weekends, owner proud as could be, telling everyone how busy they were. From the sidewalk it looked like the most successful restaurant on the block.
        </p>
        <p>
          It closed inside a year. The room was full, but the check average was low and the cost structure was heavy, and the place never once cleared its break-even. Busy and profitable are two different numbers, and he was only watching one of them. Then he added a lunch service to chase more volume, and lunch never hit its own break-even either, so it quietly ate the little bit dinner was making.
        </p>
        <p class="essay__pull">
          A full room is not the same as a profitable one. Break-even is the number that tells you the difference.
        </p>
        <p>
          The math would have caught it in an hour. Fixed costs divided by contribution margin gives you the covers you have to do just to keep the lights on, and everything under that line is loss no matter how loud the dining room gets. Run it before you add the daypart, not after. The crowd feels like proof. Break-even is the actual proof.
        </p>
        <div class="operator-byline">
          <span class="operator-byline__dash">Signed</span>
          <span class="operator-byline__name">Brock Markarian</span>
          <span class="operator-byline__role">Founder · 5 yrs at Cosmos Taverna (Bartender → GM)</span>
        </div>
      </div>
    </section>

    <hr class="rule" aria-hidden="true" />

    <section class="scenarios">
      <p class="t-micro t-micro--saffron">Real scenarios</p>
      <h2 class="scenarios__headline">Three concepts, three different break-even stories</h2>
      <p class="t-body-large scenarios__intro">
        Same formula, different fixes. The lever depends on which number is broken.
      </p>
      <div class="scenarios__grid">
        {scenarios.map((s, i) => (
          <article class="scenario-card">
            <span class="scenario-card__num num">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="scenario-card__title">{s.title}</h3>
            <p class="scenario-card__setup">{s.setup}</p>
            <div class="scenario-card__row"><span class="scenario-card__label">Diagnosis</span><p class="scenario-card__text">{s.diagnosis}</p></div>
            <div class="scenario-card__row"><span class="scenario-card__label">Fix</span><p class="scenario-card__text">{s.fix}</p></div>
            <div class="scenario-card__row scenario-card__row--outcome"><span class="scenario-card__label">Outcome</span><p class="scenario-card__text"><strong>{s.outcome}</strong></p></div>
          </article>
        ))}
      </div>
    </section>

    <hr class="rule" aria-hidden="true" />

    <section class="calc-faq">
      <p class="t-micro t-micro--saffron">FAQ</p>
      <h2 class="calc-faq__headline">Common questions</h2>
      {faq.map((f, i) => (
        <details class="calc-faq__item">
          <summary class="calc-faq__q">
            <span class="calc-faq__num">{String(i + 1).padStart(2, '0')}</span>
            <span class="calc-faq__qtext">{f.q}</span>
            <span class="calc-faq__plus" aria-hidden="true">+</span>
          </summary>
          <p class="calc-faq__a">{f.a}</p>
        </details>
      ))}
    </section>

    <section class="cited-sources">
      <p class="t-micro t-micro--saffron">Cited sources</p>
      <ul>
        <li><a href="https://pos.toasttab.com/blog/on-the-line/restaurant-break-even-analysis" target="_blank" rel="noopener">Toast, Restaurant Break-Even Analysis</a></li>
        <li><a href="https://www.sba.gov/business-guide/manage-your-business/manage-your-finances" target="_blank" rel="noopener">SBA, Manage Your Finances</a></li>
        <li><a href="https://restaurant.org/research-and-media/research/economists-notebook/" target="_blank" rel="noopener">National Restaurant Association, Industry Margin Research</a></li>
      </ul>
    </section>

    <section class="related">
      <h2 class="related__headline">Related calculators</h2>
      <div class="related__grid">
        {relatedCalcs.map((c, i) => (
          <a href={`/calculators/${c.slug}/`} class="related-card">
            <div class="related-card__top">
              <span class="related-card__num num">{String(i + 1).padStart(2, '0')}</span>
              <span class="t-micro"><strong style="color:var(--color-saffron-text)">Free</strong> · 2 min</span>
            </div>
            <h3 class="related-card__title">{c.title}</h3>
            <p class="t-body related-card__desc">{c.desc}</p>
            <span class="related-card__arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </section>
  </article>
</Layout>

<script>
  const form = document.querySelector('[data-form]') as HTMLFormElement | null;
  const counter = document.querySelector('[data-counter]') as HTMLElement | null;
  const marginEl = document.querySelector('[data-margin]') as HTMLElement | null;
  const coversMonthEl = document.querySelector('[data-covers-month]') as HTMLElement | null;
  const coversDayEl = document.querySelector('[data-covers-day]') as HTMLElement | null;
  const revDayEl = document.querySelector('[data-rev-day]') as HTMLElement | null;
  const mosRow = document.querySelector('[data-mos-row]') as HTMLElement | null;
  const mosEl = document.querySelector('[data-mos]') as HTMLElement | null;
  const capacityRow = document.querySelector('[data-capacity-row]') as HTMLElement | null;
  const capacityEl = document.querySelector('[data-capacity]') as HTMLElement | null;
  const mathBody = document.querySelector('[data-math]') as HTMLElement | null;
  const mathWrap = document.querySelector('[data-math-wrap]') as HTMLDetailsElement | null;

  if (form && counter && mathBody) {
    let lastValue = 0;
    let calcDebounce: number | null = null;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function fmtUSD(n: number): string { return '$' + Math.round(n).toLocaleString('en-US'); }
    function fmtUSDFull(n: number): string { return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }); }

    function animateCounter(el: HTMLElement, from: number, to: number, duration = 800) {
      if (reduced) { el.textContent = Math.round(to).toLocaleString('en-US'); return; }
      const start = performance.now();
      const ease = (t: number) => 1 - Math.pow(1 - t, 3);
      function frame(now: number) {
        const t = Math.min((now - start) / duration, 1);
        const value = from + (to - from) * ease(t);
        el.textContent = Math.round(value).toLocaleString('en-US');
        if (t < 1) requestAnimationFrame(frame);
        else { el.classList.add('result-num--pulse'); setTimeout(() => el.classList.remove('result-num--pulse'), 320); }
      }
      requestAnimationFrame(frame);
    }

    function calc() {
      const data = new FormData(form!);
      const fixed = parseFloat(String(data.get('fixed') || '0')) || 0;
      const variable = parseFloat(String(data.get('variable') || '0')) || 0;
      const avgticket = parseFloat(String(data.get('avgticket') || '0')) || 0;
      const days = parseFloat(String(data.get('days') || '26')) || 26;

      if (fixed <= 0 || variable <= 0 || variable >= 100) {
        animateCounter(counter!, lastValue, 0, 400);
        lastValue = 0;
        if (marginEl) marginEl.textContent = ', ';
        if (coversMonthEl) coversMonthEl.textContent = ', ';
        if (coversDayEl) coversDayEl.textContent = ', ';
        if (revDayEl) revDayEl.textContent = ', ';
        mathBody!.innerHTML = '<p class="t-caption">Enter values above to see the calculation.</p>';
        return;
      }

      const contributionMargin = 1 - variable / 100;
      const breakEven = fixed / contributionMargin;
      const revPerDay = breakEven / days;
      const coversMonth = avgticket > 0 ? breakEven / avgticket : 0;
      const coversDay = coversMonth / days;

      animateCounter(counter!, lastValue, breakEven, 800);
      lastValue = breakEven;

      if (marginEl) marginEl.textContent = `${(contributionMargin * 100).toFixed(1)}%`;
      if (coversMonthEl) coversMonthEl.textContent = avgticket > 0 ? Math.round(coversMonth).toLocaleString('en-US') : 'add ticket';
      if (coversDayEl) coversDayEl.textContent = avgticket > 0 ? Math.round(coversDay).toLocaleString('en-US') : 'add ticket';
      if (revDayEl) revDayEl.textContent = fmtUSD(revPerDay);

      // Margin of Safety
      const actualSales = parseFloat(String(data.get('actual-sales') || '0')) || 0;
      let mosPct = 0;
      if (actualSales > 0 && breakEven > 0 && mosRow && mosEl) {
        mosRow.hidden = false;
        mosPct = ((actualSales - breakEven) / actualSales) * 100;
        const mosCls = mosPct < 0 ? 'is-bad' : mosPct < 10 ? 'is-watch' : 'is-good';
        mosEl.textContent = `${mosPct >= 0 ? '+' : ''}${mosPct.toFixed(1)}% (${fmtUSD(actualSales - breakEven)})`;
        mosEl.className = `extras-row__value num ${mosCls}`;
      } else if (mosRow) {
        mosRow.hidden = true;
      }

      // Capacity utilization at break-even
      const seats = parseFloat(String(data.get('seats') || '0')) || 0;
      const turns = parseFloat(String(data.get('turns') || '0')) || 0;
      let capacityPct = 0;
      if (seats > 0 && turns > 0 && coversDay > 0 && capacityRow && capacityEl) {
        const dailyCapacity = seats * turns;
        capacityPct = (coversDay / dailyCapacity) * 100;
        capacityRow.hidden = false;
        const capCls = capacityPct > 80 ? 'is-bad' : capacityPct > 60 ? 'is-watch' : 'is-good';
        capacityEl.textContent = `${capacityPct.toFixed(0)}% of ${dailyCapacity.toFixed(0)} covers/day capacity`;
        capacityEl.className = `extras-row__value num ${capCls}`;
      } else if (capacityRow) {
        capacityRow.hidden = true;
      }

      mathBody!.innerHTML = `
        <table class="math-table" role="presentation">
          <tr><td>Fixed costs</td><td class="num">${fmtUSDFull(fixed)}</td></tr>
          <tr><td>Variable cost</td><td class="num">${variable.toFixed(1)}%</td></tr>
          <tr class="math-table__step"><td>Contribution margin (1 − var%)</td><td class="num">${(contributionMargin * 100).toFixed(1)}%</td></tr>
          <tr class="math-table__step"><td>Fixed ÷ contribution margin</td><td class="num">${fmtUSDFull(breakEven)}</td></tr>
          <tr class="math-table__final"><td>Break-even revenue / month</td><td class="num"><strong>${fmtUSD(breakEven)}</strong></td></tr>
        </table>
        <p class="t-caption math-note">
          Hit ${fmtUSD(revPerDay)}/day across ${days} operating days to cover all costs.
          ${avgticket > 0 ? ` At a ${fmtUSDFull(avgticket)} average ticket, that's ${Math.round(coversDay)} covers/day, ${Math.round(coversMonth).toLocaleString('en-US')} covers/month.` : ''}
        </p>
      `;

      if (mathWrap && !mathWrap.open) mathWrap.open = true;
    }

    function debouncedCalc() {
      if (calcDebounce !== null) clearTimeout(calcDebounce);
      calcDebounce = window.setTimeout(calc, 250);
    }

    form.addEventListener('input', debouncedCalc);
    form.addEventListener('change', debouncedCalc);
    form.addEventListener('submit', (e) => { e.preventDefault(); if (calcDebounce !== null) clearTimeout(calcDebounce); calc(); });

    function loadExample() {
      (document.querySelector('#fixed') as HTMLInputElement).value = '40000';
      (document.querySelector('#variable') as HTMLInputElement).value = '60';
      (document.querySelector('#avgticket') as HTMLInputElement).value = '35';
      (document.querySelector('#days') as HTMLSelectElement).value = '26';
      calc();
    }
    const loadExBtn = document.querySelector('[data-load-example]');
    if (loadExBtn) loadExBtn.addEventListener('click', loadExample);
    loadExample();
  }
</script>

