---
import Layout from '../../layouts/Layout.astro';

const title = 'Employee Turnover Cost Calculator — Free | RestaurantCalcs';
const description = 'Restaurant employee turnover cost calculator. Annual replacement cost across hourly + salaried headcount. Industry benchmarks (NRA, Cornell SHA). Math shown.';

const faq = [
  {
    q: 'What is restaurant employee turnover rate?',
    a: 'Annual turnover events divided by average headcount. If you ran 25 employees through the year and replaced 19 of them, that is 76% turnover. The NRA puts full-service annual turnover in the 75–130% band. QSR runs higher. Fine dining runs lower.',
  },
  {
    q: 'How do I calculate turnover cost per employee?',
    a: 'Recruiting + onboarding + training + the productivity gap during ramp. Cornell SHA Center for Hospitality Research puts hourly replacement at $3,000–$7,000. Manager replacement runs $10,000–$25,000+. Most operators only count posted job-board fees and miss the ramp gap, which is the biggest line item.',
  },
  {
    q: 'What is a typical restaurant turnover rate?',
    a: 'Concept-specific. QSR runs 130–150% (NRA). Fast casual 80–110%. Casual dining 75–100%. Fine dining 50–80%. Pizza 100–130%. Coffee and cafe 90–120% (7shifts). The full-service industry midpoint sits around 75–130% (NRA). Anything above that is the silent margin killer most operators do not model.',
  },
  {
    q: 'What is included in replacement cost?',
    a: 'Job board fees, applicant tracking, manager interview hours, paperwork and background checks, uniform and onboarding kit, weeks of paid training before full productivity, and the productivity gap while the new hire is on a half-pace ramp. Cornell SHA bundles all of it. The ramp gap is usually 50–60% of the total.',
  },
  {
    q: 'How do I lower turnover?',
    a: 'Stay interviews at 30, 60, 90 days. Real schedule predictability (posted two weeks out, not changed). Pay above local median for your concept band. Career-path conversations with hourly staff. Most of the meaningful turnover at year one is fixable. Most at year three is structural.',
  },
  {
    q: 'Does paying more reduce turnover?',
    a: 'Yes, but compounding matters more than the single raise. An 8% wage bump funded by saving on turnover cost is the play. The TouchBistro 2026 State of Restaurants Report has 96% of operators reporting higher labor costs YoY — meaning competitors are also raising. Standing still on wages is going backwards on retention.',
  },
  {
    q: 'What about salaried manager turnover?',
    a: 'Higher dollar cost per event, lower frequency, more damaging. Cornell SHA pegs manager replacement at $10,000–$25,000+. Lose two AGMs in a year and you are looking at $30K–$50K alone. Audit your salaried compensation against market every 18 months. The ladder needs to be visible to keep them.',
  },
  {
    q: 'How does turnover affect food and labor cost?',
    a: 'Through the training overhead. New BOH hires miss portion specs. New FOH hires under-sell or over-comp. Both inflate prime cost during the ramp. The first 90 days of every new hire run roughly 10–15% above the trained-staff cost line. Multiply that by your annual turnover events. That is your hidden labor inflation.',
  },
  {
    q: "What's the difference between voluntary and involuntary turnover?",
    a: 'Voluntary is the employee leaving (better job, schedule, pay, life event). Involuntary is the operator letting them go (performance, attendance, fit). Both cost the same to replace. Involuntary turnover spikes mean the hiring filter needs work. Voluntary spikes mean the schedule, pay, or culture needs work.',
  },
  {
    q: 'Does this calculator save my data?',
    a: 'No. Nothing is stored, transmitted, or tracked. The math runs in your browser and disappears the moment you close the tab. No signup, no email, no account.',
  },
];

const benchmarks = [
  { name: 'Quick service', low: 130, high: 150 },
  { name: 'Fast casual', low: 80, high: 110 },
  { name: 'Casual dining', low: 75, high: 100 },
  { name: 'Fine dining', low: 50, high: 80 },
  { name: 'Pizza', low: 100, high: 130 },
  { name: 'Coffee / cafe', low: 90, high: 120 },
];

const scenarios = [
  {
    title: 'The 130% turnover trap',
    setup: '28-employee casual concept. Replacing 36 people a year at $5,500 each. Owner treated it as cost of doing business. Never modeled the annual line item.',
    diagnosis: 'Annual turnover cost was $198K. The schedule was changing every Sunday for the next week. Pay was at local median, not above. No 30/60/90 check-ins. Year-one staff were the most likely to leave, exactly the band where stay interviews work.',
    fix: 'Stay interviews at 30, 60, 90 days. Schedule posted two weeks out and held. One pay-band review. The owner started showing up Saturday nights for the first time in three years.',
    outcome: 'Turnover dropped to 85% in nine months. About $65K/year recovered (NRA range). Funded a wage bump for the staff who stayed. Compounding from there.',
  },
  {
    title: 'The QSR retention paradox',
    setup: 'QSR owner thought labor was cheap and churn was normal. 145% turnover, well within QSR norms (NRA). Never ran the math on what the churn was costing him.',
    diagnosis: 'Real cost (recruiting + training + productivity gap during ramp) was 12% of revenue. Bigger than his rent line. He was running the business above what break-even would have been if turnover had been at the lower end of his concept band.',
    fix: 'Cut turnover from 145% to 95% by simplifying scheduling and adding a $0.75 attendance bonus for showing up to every scheduled shift in a pay period. Used the savings to raise base wages 8% across the board.',
    outcome: 'Turnover dropped further to 70%. The wage bump paid for itself out of recovered training costs. He now models turnover as a P&L line, not background noise.',
  },
  {
    title: 'The salaried-manager bleed',
    setup: 'Hourly turnover under control at 60%. Hourly side healthy. Then he lost both AGMs and one sous chef in 14 months. Felt random. Was not random.',
    diagnosis: 'Salaried churn cost $48K alone (Cornell SHA range). Compensation had not been audited against market in three years. Local competitors were paying 12–15% more. The ladder above the AGM role was unclear. They left for clarity as much as for the money.',
    fix: 'Audited compensation. Raised salaried bands 10%. Documented the GM career path with a written timeline. Built a quarterly 1:1 cadence with the salaried team that did not exist before.',
    outcome: 'Stable salaried team for 26 months running. The hourly side stayed at 60%. The salaried discipline pulled the whole operation up.',
  },
];

const relatedCalcs = [
  { slug: 'labor-cost', title: 'Labor Cost Percentage', desc: 'Turnover inflates labor through training overhead.' },
  { slug: 'prime-cost', title: 'Prime Cost', desc: 'Where turnover cost ultimately shows up.' },
  { slug: 'break-even', title: 'Break-Even Revenue', desc: 'Turnover cost is operational expense above break-even.' },
];

const schema = [
  { '@context': 'https://schema.org', '@type': 'WebPage', '@id': 'https://restaurantcalcs.com/calculators/turnover-cost/#webpage', url: 'https://restaurantcalcs.com/calculators/turnover-cost/', name: title, description, isPartOf: { '@id': 'https://restaurantcalcs.com/#website' }, breadcrumb: { '@id': 'https://restaurantcalcs.com/calculators/turnover-cost/#breadcrumb' }, inLanguage: 'en-US' },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', '@id': 'https://restaurantcalcs.com/calculators/turnover-cost/#breadcrumb', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://restaurantcalcs.com/' },
    { '@type': 'ListItem', position: 2, name: 'Calculators', item: 'https://restaurantcalcs.com/calculators/' },
    { '@type': 'ListItem', position: 3, name: 'Employee Turnover Cost', item: 'https://restaurantcalcs.com/calculators/turnover-cost/' },
  ] },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    '@id': 'https://restaurantcalcs.com/calculators/turnover-cost/#tool',
    name: 'Restaurant Employee Turnover Cost Calculator',
    description: 'Free web-based employee turnover cost calculator. Models annual replacement cost across hourly and salaried headcount. Concept-aware benchmarks from NRA and Cornell SHA.',
    applicationCategory: 'BusinessApplication',
    applicationSubCategory: 'Restaurant Management',
    operatingSystem: 'Web',
    browserRequirements: 'Requires JavaScript',
    url: 'https://restaurantcalcs.com/calculators/turnover-cost/',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    creator: { '@id': 'https://restaurantcalcs.com/#organization' },
    author: { '@id': 'https://restaurantcalcs.com/#founder' },
    isAccessibleForFree: true,
  },
  { '@context': 'https://schema.org', '@type': 'HowTo', name: 'How to calculate restaurant employee turnover cost', totalTime: 'PT3M', supply: [
    { '@type': 'HowToSupply', name: 'Total hourly headcount (FOH + BOH)' },
    { '@type': 'HowToSupply', name: 'Annual hourly turnover rate (%)' },
    { '@type': 'HowToSupply', name: 'Cost per hourly replacement (in dollars)' },
    { '@type': 'HowToSupply', name: 'Salaried / manager headcount (optional)' },
  ], step: [
    { '@type': 'HowToStep', position: 1, name: 'Count hourly headcount', text: 'Add up FOH and BOH hourly employees. Active payroll heads, not seats budgeted.' },
    { '@type': 'HowToStep', position: 2, name: 'Estimate annual turnover rate', text: 'Annual replacements divided by average headcount. NRA full-service midpoint is 75–130%.' },
    { '@type': 'HowToStep', position: 3, name: 'Set replacement cost per hire', text: 'Cornell SHA pegs hourly replacement at $3,000–$7,000. Default $5,500 for the midpoint.' },
    { '@type': 'HowToStep', position: 4, name: 'Add salaried separately', text: 'Manager replacement is $10,000–$25,000 (Cornell SHA). Lower frequency but higher impact per event.' },
  ] },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
];
---

<Layout {title} {description} {schema}>
  <article class="calc-page">
    <header class="calc-page__header">
      <nav class="breadcrumb" aria-label="Breadcrumb"><a href="/">Home</a><span aria-hidden="true">/</span><a href="/calculators/">Calculators</a><span aria-hidden="true">/</span><span>Employee Turnover Cost</span></nav>
      <p class="t-micro t-micro--saffron calc-page__eyebrow">Turnover cost calculator · <strong>100% free · no signup</strong></p>
      <h1 class="calc-page__title">Employee Turnover Cost Calculator</h1>
      <p class="calc-page__intro">
        The silent margin killer most operators do not model. Restaurant industry runs <strong>75–130% annual turnover</strong> on the full-service side (NRA). Hourly replacement cost is <strong>$3,000–$7,000 per hire</strong> (Cornell SHA). Multiply by your headcount and the number gets uncomfortable fast. That is the point.
      </p>
    </header>

    <section class="calc-grid">
      <form class="calc-form" data-form>
        <div class="form-intro">
          <p class="form-intro__what"><strong>What this does:</strong> Models annual turnover cost across hourly and salaried headcount. Returns total annual cost, monthly and weekly equivalents, and cost as a percentage of typical $1M revenue.</p>
          <button type="button" class="form-intro__example" data-load-example>Try with example numbers</button>
        </div>

        <div class="form-row">
          <label class="form-row__label" for="hourly-count">Total hourly employees (FOH + BOH)</label>
          <div class="input-shell">
            <input id="hourly-count" name="hourly-count" type="number" inputmode="numeric" min="0" step="1" placeholder="25" autocomplete="off" required />
            <span class="input-shell__suffix">people</span>
          </div>
          <p class="form-row__hint">Active hourly payroll heads. Not seats budgeted, not contractors.</p>
        </div>

        <div class="form-row">
          <label class="form-row__label" for="hourly-rate">Annual hourly turnover rate</label>
          <div class="input-shell">
            <input id="hourly-rate" name="hourly-rate" type="number" inputmode="decimal" min="0" max="300" step="1" placeholder="75" autocomplete="off" required />
            <span class="input-shell__suffix">%</span>
          </div>
          <p class="form-row__hint">Industry full-service midpoint 75–130% (NRA). QSR runs 130–150%. Fine dining 50–80%.</p>
        </div>

        <div class="form-row">
          <label class="form-row__label" for="hourly-cost">Cost per hourly replacement</label>
          <div class="input-shell">
            <span class="input-shell__prefix">$</span>
            <input id="hourly-cost" name="hourly-cost" type="number" inputmode="decimal" min="0" step="100" placeholder="5500" autocomplete="off" required />
          </div>
          <p class="form-row__hint">Cornell SHA range $3,000–$7,000. Default is the midpoint. Includes recruiting, onboarding, training, and the productivity gap during ramp.</p>
        </div>

        <div class="form-row">
          <label class="form-row__label" for="salaried-count">Salaried / manager headcount <span style="color:var(--color-muted);font-weight:400">(optional)</span></label>
          <div class="input-shell">
            <input id="salaried-count" name="salaried-count" type="number" inputmode="numeric" min="0" step="1" placeholder="3" autocomplete="off" />
            <span class="input-shell__suffix">people</span>
          </div>
          <p class="form-row__hint">GM, AGMs, sous chefs, kitchen managers. Skip if you do not run salaried roles.</p>
        </div>

        <div class="form-row">
          <label class="form-row__label" for="salaried-rate">Annual salaried turnover rate <span style="color:var(--color-muted);font-weight:400">(optional)</span></label>
          <div class="input-shell">
            <input id="salaried-rate" name="salaried-rate" type="number" inputmode="decimal" min="0" max="200" step="1" placeholder="25" autocomplete="off" />
            <span class="input-shell__suffix">%</span>
          </div>
          <p class="form-row__hint">Lower frequency than hourly. Industry healthy is under 25%. Above 40% is structural.</p>
        </div>

        <div class="form-row">
          <label class="form-row__label" for="salaried-cost">Cost per salaried replacement <span style="color:var(--color-muted);font-weight:400">(optional)</span></label>
          <div class="input-shell">
            <span class="input-shell__prefix">$</span>
            <input id="salaried-cost" name="salaried-cost" type="number" inputmode="decimal" min="0" step="500" placeholder="15000" autocomplete="off" />
          </div>
          <p class="form-row__hint">Cornell SHA range $10,000–$25,000+. Default is the midpoint. Manager loss runs higher than line-staff loss.</p>
        </div>

        <button type="submit" class="btn btn-primary btn-large calc-form__submit">
          Calculate annual turnover cost
          <span class="btn__arrow" aria-hidden="true">&rarr;</span>
        </button>

        <p class="calc-form__privacy t-caption"><strong>Nothing is saved or sent.</strong> All math runs in your browser.</p>
      </form>

      <aside class="calc-result">
        <div class="calc-result__card" aria-live="polite" aria-atomic="true">
          <div class="calc-result__head">
            <span class="t-micro calc-result__label">Annual turnover cost</span>
            <span class="status-pill" data-status="empty">
              <span class="status-pill__dot"></span><span data-status-label>Enter values</span>
            </span>
          </div>

          <div class="calc-result__big">
            <span class="result-num__pct" aria-hidden="true">$</span>
            <span class="result-num" data-counter>0</span>
            <span class="visually-hidden">dollars annual turnover cost</span>
          </div>

          <div class="calc-result__benchmark">
            <span class="t-caption">Industry full-service turnover</span>
            <span class="t-caption num" data-bench>75–130%</span>
          </div>

          <div class="calc-result__bar">
            <div class="bar-track">
              <div class="bar-zone bar-zone--lean"></div>
              <div class="bar-zone bar-zone--good"></div>
              <div class="bar-zone bar-zone--watch"></div>
              <div class="bar-zone bar-zone--bad"></div>
              <div class="bar-marker" data-marker style="left: 0%"></div>
            </div>
            <div class="bar-labels">
              <span class="t-caption num">0%</span>
              <span class="t-caption num">75%</span>
              <span class="t-caption num">150%+</span>
            </div>
          </div>

          <div class="calc-result__extras">
            <div class="extras-row">
              <span class="extras-row__label">Annual turnover events</span>
              <span class="extras-row__value num" data-events>&mdash;</span>
            </div>
            <div class="extras-row">
              <span class="extras-row__label">Annual hourly cost</span>
              <span class="extras-row__value num" data-hourly-cost>&mdash;</span>
            </div>
            <div class="extras-row" data-salaried-row hidden>
              <span class="extras-row__label">Annual salaried cost</span>
              <span class="extras-row__value num" data-salaried-cost>&mdash;</span>
            </div>
            <div class="extras-row">
              <span class="extras-row__label">Monthly equivalent</span>
              <span class="extras-row__value num" data-monthly>&mdash;</span>
            </div>
            <div class="extras-row">
              <span class="extras-row__label">Weekly equivalent</span>
              <span class="extras-row__value num" data-weekly>&mdash;</span>
            </div>
            <div class="extras-row">
              <span class="extras-row__label">% of typical $1M revenue</span>
              <span class="extras-row__value num" data-revpct>&mdash;</span>
            </div>
          </div>
        </div>

        <details class="show-math" data-math-wrap>
          <summary class="show-math__trigger">
            <span class="show-math__icon" aria-hidden="true">+</span>
            Show your math
          </summary>
          <div class="show-math__body" data-math>
            <p class="t-caption">Enter values above to see the calculation.</p>
          </div>
        </details>
      </aside>
    </section>

    <section class="essay">
      <img src="/illustrations/turnover-cost.webp" alt="Editorial illustration of a restaurant back office at end of shift, an open binder of staff schedules, time-clock punch cards in a stack, an empty name tag and apron folded on the desk, a half-finished cup of coffee, dim warm overhead light." class="operator-story__hero" width="1264" height="848" loading="lazy" />
      <p class="essay__eyebrow t-micro t-micro--saffron">Why this matters</p>
      <h2 class="essay__headline">Turnover is the line item operators <em>treat as weather</em>.</h2>
      <div class="essay__body">
        <p>
          Food cost gets a weekly meeting. Labor cost gets a daily POS report. Turnover gets shrugged at as the cost of running a restaurant. Then the year ends and nobody runs the multiplication. Twenty-five hourly staff at 100% turnover and $5,500 a head is $137,500. That is a second rent. Most operators do not have it on a P&L line at all.
        </p>
        <p>
          The math compounds in both directions. A stay interview at 30/60/90 days costs the GM about an hour per hire. A wage bump funded by saving on training overhead is the play that funds itself. The TouchBistro 2026 State of Restaurants Report has 96% of operators reporting higher labor costs YoY. Standing still on wages while everyone else moves is a retention problem dressed up as a labor problem.
        </p>
        <p class="essay__pull">
          Turnover is a math problem operators treat as a culture problem. The math drives the culture, not the other way around.
        </p>
        <p>
          The industry-norm number is the trap. The NRA puts full-service at 75–130%. Read that as "everyone is hemorrhaging cash on training, so it is fine." It is not fine. It is normalized failure. The operators I have watched run stable teams for years had two things in common: they ran the math, and they made a small wage bump every twelve to eighteen months. Compounding is the entire move. In five years on the bar at Cosmos, the years we kept staff were the years the schedule was posted on time, and the years we lost staff were the years the schedule was a Sunday afternoon scramble. Different machine. Same lesson.
        </p>
      </div>
    </section>

    <hr class="rule" aria-hidden="true" />

    <div class="container ad-wrap">
      <aside class="ad-inline">
        <span class="ad-inline__label">Advertisement</span>
        <div class="ad-inline__inner">
          <ins class="adsbygoogle"
               style="display:block"
               data-ad-client="ca-pub-6332696231897305"
               data-ad-slot="0000000000"
               data-ad-format="auto"
               data-full-width-responsive="true"
               data-adtest="on"></ins>
          <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
        </div>
      </aside>
    </div>

    <section class="benchmarks">
      <h2 class="benchmarks__headline">Turnover benchmarks <em>by concept type</em></h2>
      <p class="t-body-large benchmarks__intro">
        Turnover is concept-specific. QSR runs the highest because the labor pool is younger and more transient. Fine dining runs the lowest because more of the staff treat it as a career. Use these as a target band, not a hard line (NRA, 7shifts).
      </p>
      <div class="benchmarks__chart">
        {benchmarks.map((b) => (
          <div class="bench-bar">
            <div class="bench-bar__name">{b.name}</div>
            <div class="bench-bar__track">
              <div class="bench-bar__zone" style={`left: ${b.low / 2}%; width: ${(b.high - b.low) / 2}%`}></div>
              <div class="bench-bar__tick" style={`left: ${b.low / 2}%`}></div>
              <div class="bench-bar__tick" style={`left: ${b.high / 2}%`}></div>
            </div>
            <div class="bench-bar__range num">{b.low}&ndash;{b.high}%</div>
          </div>
        ))}
        <div class="bench-axis">
          <div class="bench-axis__track">
            <span class="bench-axis__tick num" style="left: 0%">0%</span>
            <span class="bench-axis__tick num" style="left: 25%">50%</span>
            <span class="bench-axis__tick num" style="left: 50%">100%</span>
            <span class="bench-axis__tick num" style="left: 75%">150%</span>
            <span class="bench-axis__tick num" style="left: 100%">200%</span>
          </div>
        </div>
      </div>
    </section>

    <hr class="rule" aria-hidden="true" />

    <section class="scenarios">
      <p class="t-micro t-micro--saffron">Real scenarios</p>
      <h2 class="scenarios__headline">Three operators, three different turnover stories</h2>
      <p class="t-body-large scenarios__intro">
        Same metric, different fixes. Hourly bleed, salaried bleed, and the operator who never modeled either until the math hit the page.
      </p>
      <div class="scenarios__grid">
        {scenarios.map((s, i) => (
          <article class="scenario-card">
            <span class="scenario-card__num num">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="scenario-card__title">{s.title}</h3>
            <p class="scenario-card__setup">{s.setup}</p>
            <div class="scenario-card__row"><span class="scenario-card__label">Diagnosis</span><p class="scenario-card__text">{s.diagnosis}</p></div>
            <div class="scenario-card__row"><span class="scenario-card__label">Fix</span><p class="scenario-card__text">{s.fix}</p></div>
            <div class="scenario-card__row scenario-card__row--outcome"><span class="scenario-card__label">Outcome</span><p class="scenario-card__text"><strong>{s.outcome}</strong></p></div>
          </article>
        ))}
      </div>
    </section>

    <hr class="rule" aria-hidden="true" />

    <section class="calc-faq">
      <p class="t-micro t-micro--saffron">FAQ</p>
      <h2 class="calc-faq__headline">Common questions</h2>
      {faq.map((f, i) => (
        <details class="calc-faq__item">
          <summary class="calc-faq__q">
            <span class="calc-faq__num">{String(i + 1).padStart(2, '0')}</span>
            <span class="calc-faq__qtext">{f.q}</span>
            <span class="calc-faq__plus" aria-hidden="true">+</span>
          </summary>
          <p class="calc-faq__a">{f.a}</p>
        </details>
      ))}
    </section>

    <section class="cited-sources">
      <p class="t-micro t-micro--saffron">Cited sources</p>
      <ul>
        <li><a href="https://restaurant.org/research-and-media/research/economists-notebook/" target="_blank" rel="noopener">National Restaurant Association &mdash; Industry Turnover Statistics</a></li>
        <li><a href="https://sha.cornell.edu/faculty-research/centers-institutes/chr/" target="_blank" rel="noopener">Cornell School of Hotel Administration &mdash; Center for Hospitality Research turnover cost studies</a></li>
        <li><a href="https://www.touchbistro.com/restaurant-report/" target="_blank" rel="noopener">TouchBistro 2026 State of Restaurants Report</a></li>
        <li><a href="https://www.7shifts.com/blog/restaurant-turnover/" target="_blank" rel="noopener">7shifts &mdash; Restaurant Turnover Trends</a></li>
      </ul>
    </section>

    <section class="related">
      <h2 class="related__headline">Related calculators</h2>
      <div class="related__grid">
        {relatedCalcs.map((c, i) => (
          <a href={`/calculators/${c.slug}/`} class="related-card">
            <div class="related-card__top">
              <span class="related-card__num num">{String(i + 1).padStart(2, '0')}</span>
              <span class="t-micro"><strong style="color:var(--color-saffron-text)">Free</strong> &middot; 2 min</span>
            </div>
            <h3 class="related-card__title">{c.title}</h3>
            <p class="t-body related-card__desc">{c.desc}</p>
            <span class="related-card__arrow" aria-hidden="true">&rarr;</span>
          </a>
        ))}
      </div>
    </section>
  </article>
</Layout>

<script>
  const form = document.querySelector('[data-form]') as HTMLFormElement | null;
  const counter = document.querySelector('[data-counter]') as HTMLElement | null;
  const marker = document.querySelector('[data-marker]') as HTMLElement | null;
  const statusPill = document.querySelector('.status-pill') as HTMLElement | null;
  const statusLabel = document.querySelector('[data-status-label]') as HTMLElement | null;
  const benchEl = document.querySelector('[data-bench]') as HTMLElement | null;
  const eventsEl = document.querySelector('[data-events]') as HTMLElement | null;
  const hourlyCostEl = document.querySelector('[data-hourly-cost]') as HTMLElement | null;
  const salariedCostEl = document.querySelector('[data-salaried-cost]') as HTMLElement | null;
  const salariedRow = document.querySelector('[data-salaried-row]') as HTMLElement | null;
  const monthlyEl = document.querySelector('[data-monthly]') as HTMLElement | null;
  const weeklyEl = document.querySelector('[data-weekly]') as HTMLElement | null;
  const revPctEl = document.querySelector('[data-revpct]') as HTMLElement | null;
  const mathBody = document.querySelector('[data-math]') as HTMLElement | null;
  const mathWrap = document.querySelector('[data-math-wrap]') as HTMLDetailsElement | null;

  if (form && counter && marker && statusPill && statusLabel && mathBody) {
    let lastValue = 0;
    let calcDebounce: number | null = null;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function fmtUSD(n: number) { return '$' + Math.round(n).toLocaleString('en-US'); }
    function fmtInt(n: number) { return Math.round(n).toLocaleString('en-US'); }

    function animateCounter(el: HTMLElement, from: number, to: number, duration = 800) {
      if (reduced) { el.textContent = Math.round(to).toLocaleString('en-US'); return; }
      const start = performance.now();
      const ease = (t: number) => 1 - Math.pow(1 - t, 3);
      function frame(now: number) {
        const t = Math.min((now - start) / duration, 1);
        const v = from + (to - from) * ease(t);
        el.textContent = Math.round(v).toLocaleString('en-US');
        if (t < 1) requestAnimationFrame(frame);
        else { el.classList.add('result-num--pulse'); setTimeout(() => el.classList.remove('result-num--pulse'), 320); }
      }
      requestAnimationFrame(frame);
    }

    function statusFor(rate: number) {
      if (rate < 60) return { key: 'healthy', label: 'Healthy' };
      if (rate <= 100) return { key: 'watch', label: 'Watch' };
      return { key: 'critical', label: 'Critical' };
    }

    function reset() {
      statusPill!.dataset.status = 'empty';
      statusLabel!.textContent = 'Enter values';
      marker!.style.left = '0%';
      animateCounter(counter!, lastValue, 0, 400);
      lastValue = 0;
      mathBody!.innerHTML = '<p class="t-caption">Enter values above to see the calculation.</p>';
      [eventsEl, hourlyCostEl, salariedCostEl, monthlyEl, weeklyEl, revPctEl].forEach(e => { if (e) e.textContent = '—'; });
      if (salariedRow) salariedRow.hidden = true;
    }

    function calc() {
      const data = new FormData(form!);
      const hourlyCount = parseFloat(String(data.get('hourly-count') || '0')) || 0;
      const hourlyRate = parseFloat(String(data.get('hourly-rate') || '0')) || 0;
      const hourlyCost = parseFloat(String(data.get('hourly-cost') || '0')) || 0;
      const salariedCount = parseFloat(String(data.get('salaried-count') || '0')) || 0;
      const salariedRate = parseFloat(String(data.get('salaried-rate') || '0')) || 0;
      const salariedCostPer = parseFloat(String(data.get('salaried-cost') || '0')) || 0;

      if (hourlyCount <= 0 || hourlyRate <= 0 || hourlyCost <= 0) { reset(); return; }

      const hourlyEvents = hourlyCount * (hourlyRate / 100);
      const hourlyAnnual = hourlyEvents * hourlyCost;

      const hasSalaried = salariedCount > 0 && salariedRate > 0 && salariedCostPer > 0;
      const salariedEvents = hasSalaried ? salariedCount * (salariedRate / 100) : 0;
      const salariedAnnual = hasSalaried ? salariedEvents * salariedCostPer : 0;

      const totalAnnual = hourlyAnnual + salariedAnnual;
      const totalEvents = hourlyEvents + salariedEvents;
      const monthly = totalAnnual / 12;
      const weekly = totalAnnual / 52;
      const revPct = (totalAnnual / 1000000) * 100;

      if (benchEl) benchEl.textContent = '75–130%';

      // bar marker scaled to 0-150% (rate axis), clamped
      const clamped = Math.min(150, Math.max(0, hourlyRate));
      const markerPct = (clamped / 150) * 100;
      animateCounter(counter!, lastValue, totalAnnual, 800);
      lastValue = totalAnnual;
      const s = statusFor(hourlyRate);
      statusPill!.dataset.status = s.key;
      statusLabel!.textContent = s.label;
      marker!.style.left = `${markerPct}%`;

      if (eventsEl) eventsEl.textContent = `${fmtInt(totalEvents)} people`;
      if (hourlyCostEl) hourlyCostEl.textContent = fmtUSD(hourlyAnnual);
      if (salariedCostEl) salariedCostEl.textContent = fmtUSD(salariedAnnual);
      if (salariedRow) salariedRow.hidden = !hasSalaried;
      if (monthlyEl) monthlyEl.textContent = fmtUSD(monthly);
      if (weeklyEl) weeklyEl.textContent = fmtUSD(weekly);
      if (revPctEl) revPctEl.textContent = `${revPct.toFixed(1)}%`;

      let note = '';
      if (s.label === 'Healthy') note = `Hourly turnover under 60% is below the full-service midpoint (NRA 75–130%). Holding it there is the compounding move. Stay interviews at 30/60/90 days, schedule predictability, and a small annual wage bump usually keep you in this band.`;
      if (s.label === 'Watch') note = `Hourly turnover ${hourlyRate.toFixed(0)}% sits in the industry-norm band. Most operators treat that as fine. The math says it is costing you ${fmtUSD(hourlyAnnual)}/year just on the hourly side. Worth modeling against a wage bump (Cornell SHA).`;
      if (s.label === 'Critical') note = `Hourly turnover above 100% is the silent margin killer. ${fmtUSD(totalAnnual)}/year, or roughly ${revPct.toFixed(1)}% of a typical $1M revenue. Cut 30 points off the rate and the savings usually fund a meaningful wage increase. Compounding from there.`;

      mathBody!.innerHTML = `
        <table class="math-table" role="presentation">
          <tr><td>Hourly headcount</td><td class="num">${fmtInt(hourlyCount)} people</td></tr>
          <tr><td>&times; Annual turnover rate</td><td class="num">${hourlyRate.toFixed(1)}%</td></tr>
          <tr class="math-table__step"><td>= Annual turnover events</td><td class="num">${hourlyEvents.toFixed(1)} people</td></tr>
          <tr><td>&times; Cost per replacement</td><td class="num">${fmtUSD(hourlyCost)}</td></tr>
          <tr class="math-table__step"><td>= Annual hourly cost</td><td class="num"><strong>${fmtUSD(hourlyAnnual)}</strong></td></tr>
          ${hasSalaried ? `
          <tr><td>+ Salaried events (${fmtInt(salariedCount)} &times; ${salariedRate.toFixed(1)}%)</td><td class="num">${salariedEvents.toFixed(1)} people</td></tr>
          <tr><td>&times; Salaried replacement cost</td><td class="num">${fmtUSD(salariedCostPer)}</td></tr>
          <tr class="math-table__step"><td>= Annual salaried cost</td><td class="num">${fmtUSD(salariedAnnual)}</td></tr>
          ` : ''}
          <tr class="math-table__final"><td>Total annual turnover cost</td><td class="num"><strong>${fmtUSD(totalAnnual)}</strong></td></tr>
          <tr><td>&divide; 12 months</td><td class="num">${fmtUSD(monthly)}/month</td></tr>
          <tr><td>&divide; 52 weeks</td><td class="num">${fmtUSD(weekly)}/week</td></tr>
          <tr><td>As % of $1M revenue</td><td class="num">${revPct.toFixed(1)}%</td></tr>
        </table>
        ${note ? `<p class="t-caption math-note">${note}</p>` : ''}
      `;

      if (mathWrap && !mathWrap.open) mathWrap.open = true;
    }

    function debouncedCalc() {
      if (calcDebounce !== null) clearTimeout(calcDebounce);
      calcDebounce = window.setTimeout(calc, 250);
    }

    form.addEventListener('input', debouncedCalc);
    form.addEventListener('change', debouncedCalc);
    form.addEventListener('submit', (e) => { e.preventDefault(); if (calcDebounce !== null) clearTimeout(calcDebounce); calc(); });

    function loadExample() {
      (document.querySelector('#hourly-count') as HTMLInputElement).value = '25';
      (document.querySelector('#hourly-rate') as HTMLInputElement).value = '75';
      (document.querySelector('#hourly-cost') as HTMLInputElement).value = '5500';
      (document.querySelector('#salaried-count') as HTMLInputElement).value = '3';
      (document.querySelector('#salaried-rate') as HTMLInputElement).value = '25';
      (document.querySelector('#salaried-cost') as HTMLInputElement).value = '15000';
      calc();
    }
    const loadExBtn = document.querySelector('[data-load-example]');
    if (loadExBtn) loadExBtn.addEventListener('click', loadExample);
    loadExample();
  }
</script>

<style>
  .calc-page { padding: var(--space-12) var(--space-6) var(--space-24); max-width: 1180px; margin: 0 auto; }
  .breadcrumb { display: flex; align-items: center; gap: var(--space-2); font-family: var(--font-body); font-size: 0.8125rem; color: var(--color-muted); margin-bottom: var(--space-8); }
