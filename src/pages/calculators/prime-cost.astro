---
import Layout from '../../layouts/Layout.astro';

const title = 'Restaurant Prime Cost Calculator, Free | RestaurantCalcs';
const description = 'Restaurant prime cost calculator. Food, beverage, and labor as % of revenue. Concept-aware benchmarks (QSR 55–60%, full-service 60–65%). Math shown.';

const faq = [
  {
    q: 'What is prime cost?',
    a: 'Food + beverage + fully-loaded labor, divided by revenue. That is it. The two biggest variable costs on the P&L rolled into one ratio. Healthy is 55–60% for QSR, 60–65% for casual full-service (NRA Uniform System of Accounts).',
  },
  {
    q: 'What is the formula?',
    a: 'Prime Cost = Food + Beverage + Total Labor. Prime Cost % = Prime Cost ÷ Revenue × 100. Food + bev $9,000, labor $9,000, revenue $30,000: prime cost is 60%. The math is the easy part.',
  },
  {
    q: 'What is a healthy prime cost?',
    a: 'It depends on concept (Toast, R365, NRA). QSR and fast-casual: 55–60%. Casual full-service: 60–65%. Fine dining: 60–70%, higher labor against higher menu prices. Pizza and cafe: 55–60%. Sustained above 65% for full-service is structural: pricing, food cost discipline, or schedule design.',
  },
  {
    q: 'Why is prime cost the metric?',
    a: 'Because food and labor are the only two costs you can move this week. Rent is locked. Insurance is annual. Utilities are baseline. But you can re-portion a recipe by Tuesday and you can cut a Saturday closer at 9pm. Prime cost rolls both into one number you can act on tonight.',
  },
  {
    q: 'How do food cost and labor cost trade off?',
    a: 'Negatively. Scratch kitchens push food cost up but build the kind of plates that hold higher menu prices. QSR runs the opposite way: cheap pre-portioned food, low-skilled fast labor. Both can hit the same prime cost target. Different stories, same total.',
  },
  {
    q: 'How often should I track it?',
    a: 'Weekly. Monthly is too late to fix anything (R365). Top operators track daily prime cost off POS reports. The variance between scheduled and actual is where the money lives, not the absolute number.',
  },
  {
    q: 'My prime cost is over 65%. Where do I cut first?',
    a: 'Labor. Almost always labor. Slow-shift overstaffing, schedule built for old volume, mid-shift overlap nobody pruned. Food cost moves with portion control, vendor renegotiation, recipe re-cost, those are 2–4 week fixes. Labor moves tonight at 9pm.',
  },
  {
    q: 'Do I include my own salary?',
    a: 'Yes. Owner-operators leave themselves out and report a falsely low prime cost. If you are working 50 hours a week, pay yourself a market manager salary on paper before calculating. I have watched operators run 54% prime on paper while subsidizing the business with their own unpaid 70-hour weeks. The number lies otherwise.',
  },
  {
    q: 'What about delivery commissions and credit card fees?',
    a: 'Outside prime cost. Those are variable but not COGS or labor. Track them separately as operating costs. Lumping third-party delivery into prime cost inflates the ratio against benchmarks calculated without them.',
  },
  {
    q: 'Does this calculator save my data?',
    a: 'No. Nothing is stored, transmitted, or tracked. The math runs in your browser and disappears the moment you close the tab. No signup, no email, no account.',
  },
];

const benchmarks = [
  { name: 'Quick service', low: 55, high: 60 },
  { name: 'Fast casual', low: 55, high: 60 },
  { name: 'Casual dining', low: 60, high: 65 },
  { name: 'Fine dining', low: 60, high: 70 },
  { name: 'Pizza concepts', low: 55, high: 60 },
  { name: 'Coffee / cafe', low: 55, high: 60 },
];

const scenarios = [
  {
    title: 'The 72% casual that blamed food inflation',
    setup: 'Casual dining, 72% prime cost for two months running. Owner had already raised prices twice and was talking about a third. Convinced it was beef and chicken.',
    diagnosis: 'Food cost was 31%. Healthy band for the concept (Toast). Labor was 41%, schedule still sized for pre-2023 covers that never came back. Three FOH overlapped on Tuesday lunch for a 12-table service.',
    fix: 'Cut Tuesday lunch staff from 4 to 2. Eliminated the overlapping mid-shift. Set an SPLH target by daypart and held the GM to it.',
    outcome: 'Prime cost dropped to 63% in five weeks. About $11K/month recovered. No vendor switch. No third price increase. The food was never the problem.',
  },
  {
    title: 'The 58% fast-casual nobody had to fix',
    setup: 'Fast-casual bowl concept. Hitting 58% prime cost every week (target band 55–60% per Toast). Owner pulled the report on Monday morning, every week, for two years.',
    diagnosis: 'Food 28%. Labor 30%. Variance under one point most weeks. POS-integrated reporting through Toast. The discipline was the operating system, not the dashboard.',
    fix: 'No fix. The owner used the same weekly cadence to open unit #2. Same target on day one. Hit it month two.',
    outcome: 'Both stores running 57–59% prime cost two years in. Deviations trigger a same-week investigation. The number is not a goal. It is the standard the rest of the operation reports to.',
  },
  {
    title: 'The 54% pizza shop that was actually 63%',
    setup: 'Pizza shop, owner reporting 54% prime cost. Thought he was crushing it (NRA pizza target 55–60%). He was working 70 hours a week and not paying himself.',
    diagnosis: 'Add a market manager wage to the books and prime cost moves to 63%. He was subsidizing the business with his own unpaid time. The 54% was a story he was telling the bank, not a number he could hand to a buyer.',
    fix: 'Pay himself a $52K manager salary on the books. Hire one shift lead. Reset the target to 60% with realistic labor.',
    outcome: 'On-paper prime cost moved to 61%. Real economics unchanged but now visible. He slept on Sundays for the first time in three years.',
  },
];

const relatedCalcs = [
  { slug: 'food-cost', title: 'Food Cost Percentage', desc: 'Component of prime cost.' },
  { slug: 'labor-cost', title: 'Labor Cost Percentage', desc: 'Other component of prime cost.' },
  { slug: 'break-even', title: 'Break-Even Revenue', desc: 'Prime cost feeds break-even.' },
];

const schema = [
  { '@context': 'https://schema.org', '@type': 'WebPage', '@id': 'https://restaurantcalcs.com/calculators/prime-cost/#webpage', url: 'https://restaurantcalcs.com/calculators/prime-cost/', name: title, description, isPartOf: { '@id': 'https://restaurantcalcs.com/#website' }, breadcrumb: { '@id': 'https://restaurantcalcs.com/calculators/prime-cost/#breadcrumb' }, inLanguage: 'en-US' },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', '@id': 'https://restaurantcalcs.com/calculators/prime-cost/#breadcrumb', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://restaurantcalcs.com/' },
    { '@type': 'ListItem', position: 2, name: 'Calculators', item: 'https://restaurantcalcs.com/calculators/' },
    { '@type': 'ListItem', position: 3, name: 'Restaurant Prime Cost', item: 'https://restaurantcalcs.com/calculators/prime-cost/' },
  ] },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    '@id': 'https://restaurantcalcs.com/calculators/prime-cost/#tool',
    name: 'Restaurant Prime Cost Calculator',
    description: 'Free web-based prime cost calculator. (Food cost + beverage + labor) ÷ revenue. Concept-aware benchmarks for QSR through fine dining.',
    applicationCategory: 'BusinessApplication',
    applicationSubCategory: 'Restaurant Management',
    operatingSystem: 'Web',
    browserRequirements: 'Requires JavaScript',
    url: 'https://restaurantcalcs.com/calculators/prime-cost/',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    creator: { '@id': 'https://restaurantcalcs.com/#organization' },
    author: { '@id': 'https://restaurantcalcs.com/#founder' },
    isAccessibleForFree: true,
  },
  { '@context': 'https://schema.org', '@type': 'HowTo', name: 'How to calculate restaurant prime cost', totalTime: 'PT3M', supply: [
    { '@type': 'HowToSupply', name: 'Total food cost (in dollars)' },
    { '@type': 'HowToSupply', name: 'Total beverage cost (in dollars)' },
    { '@type': 'HowToSupply', name: 'Total labor cost including burden (in dollars)' },
    { '@type': 'HowToSupply', name: 'Total revenue (in dollars)' },
  ], step: [
    { '@type': 'HowToStep', position: 1, name: 'Sum food and beverage cost', text: 'Add food cost (COGS) and beverage cost for the period.' },
    { '@type': 'HowToStep', position: 2, name: 'Add total labor', text: 'Sum hourly wages, salaries, payroll taxes, benefits, and workers comp. Most operators undercount by 15–25% by tracking only wages.' },
    { '@type': 'HowToStep', position: 3, name: 'Divide by revenue', text: 'Prime Cost ÷ Total Revenue × 100 = Prime Cost %.' },
    { '@type': 'HowToStep', position: 4, name: 'Compare to concept benchmark', text: 'QSR/fast-casual healthy at 55–60%. Casual full-service 60–65%. Fine dining 60–70%.' },
  ] },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
];
---

<Layout {title} {description} {schema}>
  <article class="calc-page">
    <header class="calc-page__header">
      <nav class="breadcrumb" aria-label="Breadcrumb"><a href="/">Home</a><span aria-hidden="true">/</span><a href="/calculators/">Calculators</a><span aria-hidden="true">/</span><span>Prime Cost</span></nav>
      <p class="t-micro t-micro--saffron calc-page__eyebrow">Prime cost calculator · <strong>100% free · no signup</strong></p>
      <h1 class="calc-page__title">Restaurant Prime Cost Calculator</h1>
      <p class="calc-page__intro">
        Food, beverage, and fully-loaded labor as a percentage of revenue. One ratio. The two biggest variable costs on the P&L in a single number you can act on. Healthy is <strong>55–65%</strong> depending on concept (NRA). Track it weekly. Monthly is too late to fix anything.
      </p>
    </header>

    <section class="calc-grid">
      <form class="calc-form" data-form>
        <div class="form-intro">
          <p class="form-intro__what"><strong>What this does:</strong> Adds up what your food, drinks, and staff cost you, then divides by what you sold. That percent is your prime cost, the two biggest costs you can actually change this week. It tells you if the whole operation is healthy for your type of restaurant.</p>
          <button type="button" class="form-intro__example" data-load-example>Try with example numbers</button>
        </div>

        <div class="form-row">
          <label class="form-row__label" for="concept">What kind of restaurant is this?</label>
          <select id="concept" name="concept">
            <option value="qsr">Quick service / fast food (healthy 55–60%)</option>
            <option value="fast-casual">Fast casual, order at the counter (healthy 55–60%)</option>
            <option value="casual" selected>Sit-down restaurant with servers (healthy 60–65%)</option>
            <option value="fine">Fine dining (healthy 60–70%)</option>
            <option value="pizza">Pizza (healthy 55–60%)</option>
            <option value="cafe">Coffee shop or cafe (healthy 55–60%)</option>
          </select>
          <p class="form-row__hint">Picks the healthy range we measure you against. Different restaurant types have different normal numbers.</p>
        </div>

        <div class="form-row">
          <label class="form-row__label" for="food">What your food cost you</label>
          <div class="input-shell">
            <span class="input-shell__prefix">$</span>
            <input id="food" name="food" type="number" inputmode="decimal" min="0" step="50" placeholder="7000" autocomplete="off" required />
          </div>
          <p class="form-row__hint">The dollar cost of the food itself, no drinks. Use a weekly total so you can catch problems fast.</p>
        </div>

        <div class="form-row">
          <label class="form-row__label" for="beverage">What your drinks cost you</label>
          <div class="input-shell">
            <span class="input-shell__prefix">$</span>
            <input id="beverage" name="beverage" type="number" inputmode="decimal" min="0" step="50" placeholder="2000" autocomplete="off" />
          </div>
          <p class="form-row__hint">The dollar cost of beer, wine, liquor, soda, and coffee. Optional. Leave it blank if you do not track drinks on their own.</p>
        </div>

        <div class="form-row">
          <label class="form-row__label" for="labor">What your staff cost you (the real total)</label>
          <div class="input-shell">
            <span class="input-shell__prefix">$</span>
            <input id="labor" name="labor" type="number" inputmode="decimal" min="0" step="50" placeholder="9000" autocomplete="off" required />
          </div>
          <p class="form-row__hint">Not just paychecks. Add in payroll taxes, any benefits, and workers comp too. Paychecks alone leave out 15 to 25 percent of what staff really costs you. If you only have the paycheck total, check the box below and we add the rest for you.</p>
        </div>

        <div class="form-row">
          <label class="form-row__label" for="auto-burden">
            <input type="checkbox" id="auto-burden" name="auto-burden" style="margin-right:6px" />
            The number above is paychecks only. Add the extras for me (+25%).
          </label>
          <p class="form-row__hint">A standard rule of thumb: real staff cost is about paychecks times 1.25. The extra 25 percent covers payroll taxes (about 11%), workers comp (about 3%), and basic benefits (about 10%).</p>
        </div>

        <div class="form-row">
          <label class="form-row__label" for="revenue">How much you sold (total sales)</label>
          <div class="input-shell">
            <span class="input-shell__prefix">$</span>
            <input id="revenue" name="revenue" type="number" inputmode="decimal" min="0" step="100" placeholder="30000" autocomplete="off" required />
          </div>
          <p class="form-row__hint">Everything you took in for this period: food, drinks, and any retail. Pull the total from your POS sales report.</p>
        </div>

        <div class="form-row">
          <label class="form-row__label" for="period">Period (for reference)</label>
          <select id="period" name="period">
            <option value="week" selected>Weekly (recommended)</option>
            <option value="month">Monthly</option>
            <option value="quarter">Quarterly</option>
          </select>
        </div>

        <p class="calc-form__live">
          <span class="calc-form__live-dot" aria-hidden="true"></span>
          Updates live as you type. <strong>Nothing is saved or sent</strong>, the math runs in your browser.
        </p>
      </form>

      <aside class="calc-result">
        <div class="calc-result__card" aria-live="polite" aria-atomic="true">
          <div class="calc-result__head">
            <span class="t-micro calc-result__label">Your prime cost</span>
            <span class="status-pill" data-status="empty">
              <span class="status-pill__dot"></span><span data-status-label>Enter values</span>
            </span>
          </div>

          <div class="calc-result__big">
            <span class="result-num" data-counter>0.0</span>
            <span class="result-num__pct" aria-hidden="true">%</span>
            <span class="visually-hidden">percent prime cost</span>
          </div>

          <div class="calc-result__benchmark">
            <span class="t-caption">Industry healthy range</span>
            <span class="t-caption num" data-bench>60–65%</span>
          </div>

          <div class="calc-result__bar">
            <div class="bar-track">
              <div class="bar-zone bar-zone--lean"></div>
              <div class="bar-zone bar-zone--good"></div>
              <div class="bar-zone bar-zone--watch"></div>
              <div class="bar-zone bar-zone--bad"></div>
              <div class="bar-marker" data-marker style="left: 0%"></div>
            </div>
            <div class="bar-labels">
              <span class="t-caption num">0%</span>
              <span class="t-caption num">50%</span>
              <span class="t-caption num">100%</span>
            </div>
          </div>

          <div class="calc-result__extras">
            <div class="extras-row">
              <span class="extras-row__label">Food and drinks cost</span>
              <span class="extras-row__value num" data-cogs></span>
            </div>
            <div class="extras-row">
              <span class="extras-row__label">Staff cost (with extras added in)</span>
              <span class="extras-row__value num" data-laborv></span>
            </div>
            <div class="extras-row">
              <span class="extras-row__label">Food, drinks, and staff added up</span>
              <span class="extras-row__value num" data-prime></span>
            </div>
            <div class="extras-row">
              <span class="extras-row__label">Food and drinks as a share of sales</span>
              <span class="extras-row__value num" data-foodpct></span>
            </div>
            <div class="extras-row">
              <span class="extras-row__label">Staff as a share of sales</span>
              <span class="extras-row__value num" data-laborpct></span>
            </div>
          </div>

          <button type="button" class="result-share" data-share-open aria-haspopup="dialog">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><path d="M8.6 13.5l6.8 4M15.4 6.5l-6.8 4"/></svg>
            Share these numbers
          </button>
        </div>

        <details class="show-math" data-math-wrap>
          <summary class="show-math__trigger">
            <span class="show-math__icon" aria-hidden="true">+</span>
            Show your math
          </summary>
          <div class="show-math__body" data-math>
            <p class="t-caption">Enter values above to see the calculation.</p>
          </div>
        </details>
      </aside>
    </section>

    <section class="essay">
      <img src="/illustrations/prime-cost.webp" alt="Editorial illustration of a restaurant office desk after service, vintage adding machine with paper tape, open leather P&L ledger, chef's apron, coffee ring on the corner of the page." class="operator-story__hero" width="1264" height="848" loading="lazy" />
      <p class="essay__eyebrow t-micro t-micro--saffron">Why this matters</p>
      <h2 class="essay__headline">If you track <em>one number</em>, track this one.</h2>
      <div class="essay__body">
        <p>
          Food cost percentage tells you about kitchen discipline. Labor cost percentage tells you about the schedule. Prime cost tells you whether the whole machine is running. That is the only thing the bank cares about. That is the only thing a buyer looks at first.
        </p>
        <p>
          The two ratios hide each other. A scratch kitchen with high food cost and lean labor can run the same 62% prime as a frozen-pre-portion shop with low food cost and bloated FOH. Same total, different machines. Both can be healthy. Both can fail.
        </p>
        <p class="essay__pull">
          Prime cost tells you something is broken. Food cost % and labor cost % tell you which one. You need all three. But you only need prime cost to know if you should be looking at all.
        </p>
        <p>
          Weekly tracking catches problems in week two. Monthly tracking catches them in month two. The difference is real money. Six weeks of unfixed labor drift on a 60-cover restaurant is roughly $9,000 of margin (Toast). I have watched operators run the report monthly because that is what their accountant set up, and miss a four-point gap that started on a single mid-shift schedule mistake in week one. The accountant is not the problem. The cadence is the problem.
        </p>
        <p>
          One more thing. If the owner is not pulling this number weekly, the GM is. If neither is, the number drifts and nobody finds out until tax season. That is the recurring cause of bar and kitchen drift I have watched at multiple operations: nobody owning the weekly read. The math is the easy part. Owning Monday morning is the entire game.
        </p>
      </div>
    </section>

    <hr class="rule" aria-hidden="true" />

    <div class="container ad-wrap">
      <aside class="ad-inline">
        <span class="ad-inline__label">Advertisement</span>
        <div class="ad-inline__inner">
          <ins class="adsbygoogle"
               style="display:block"
               data-ad-client="ca-pub-6332696231897305"
               data-ad-slot="0000000000"
               data-ad-format="auto"
               data-full-width-responsive="true"
               data-adtest="on"></ins>
          <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
        </div>
      </aside>
    </div>

    <section class="benchmarks">
      <h2 class="benchmarks__headline">Prime cost benchmarks <em>by concept type</em></h2>
      <p class="t-body-large benchmarks__intro">
        Healthy prime cost is concept-specific. Fine dining can run higher labor against higher menu prices. QSR survives on tight food cost and lean labor. Use these as a starting target, not a hard rule.
      </p>
      <div class="benchmarks__chart">
        {benchmarks.map((b) => (
          <div class="bench-bar">
            <div class="bench-bar__name">{b.name}</div>
            <div class="bench-bar__track">
              <div class="bench-bar__zone" style={`left: ${b.low}%; width: ${b.high - b.low}%`}></div>
              <div class="bench-bar__tick" style={`left: ${b.low}%`}></div>
              <div class="bench-bar__tick" style={`left: ${b.high}%`}></div>
            </div>
            <div class="bench-bar__range num">{b.low}–{b.high}%</div>
          </div>
        ))}
        <div class="bench-axis">
          <div class="bench-axis__track">
            <span class="bench-axis__tick num" style="left: 0%">0%</span>
            <span class="bench-axis__tick num" style="left: 25%">25%</span>
            <span class="bench-axis__tick num" style="left: 50%">50%</span>
            <span class="bench-axis__tick num" style="left: 75%">75%</span>
            <span class="bench-axis__tick num" style="left: 100%">100%</span>
          </div>
        </div>
      </div>
    </section>

    <hr class="rule" aria-hidden="true" />

    <section class="scenarios">
      <p class="t-micro t-micro--saffron">Real scenarios</p>
      <h2 class="scenarios__headline">Three operators, three different prime cost stories</h2>
      <p class="t-body-large scenarios__intro">
        Same metric, different fixes. The lever depends on which component is broken, or hidden.
      </p>
      <div class="scenarios__grid">
        {scenarios.map((s, i) => (
          <article class="scenario-card">
            <span class="scenario-card__num num">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="scenario-card__title">{s.title}</h3>
            <p class="scenario-card__setup">{s.setup}</p>
            <div class="scenario-card__row"><span class="scenario-card__label">Diagnosis</span><p class="scenario-card__text">{s.diagnosis}</p></div>
            <div class="scenario-card__row"><span class="scenario-card__label">Fix</span><p class="scenario-card__text">{s.fix}</p></div>
            <div class="scenario-card__row scenario-card__row--outcome"><span class="scenario-card__label">Outcome</span><p class="scenario-card__text"><strong>{s.outcome}</strong></p></div>
          </article>
        ))}
      </div>
    </section>

    <hr class="rule" aria-hidden="true" />

    <section class="calc-faq">
      <p class="t-micro t-micro--saffron">FAQ</p>
      <h2 class="calc-faq__headline">Common questions</h2>
      {faq.map((f, i) => (
        <details class="calc-faq__item">
          <summary class="calc-faq__q">
            <span class="calc-faq__num">{String(i + 1).padStart(2, '0')}</span>
            <span class="calc-faq__qtext">{f.q}</span>
            <span class="calc-faq__plus" aria-hidden="true">+</span>
          </summary>
          <p class="calc-faq__a">{f.a}</p>
        </details>
      ))}
    </section>

    <section class="cited-sources">
      <p class="t-micro t-micro--saffron">Cited sources</p>
      <ul>
        <li><a href="https://pos.toasttab.com/blog/on-the-line/restaurant-prime-cost" target="_blank" rel="noopener">Toast, Restaurant Prime Cost Explained</a></li>
        <li><a href="https://www.restaurant365.com/blog/" target="_blank" rel="noopener">Restaurant365, Prime Cost Tracking Best Practices</a></li>
        <li><a href="https://restaurant.org/research-and-media/research/economists-notebook/" target="_blank" rel="noopener">National Restaurant Association, Industry Margin Research</a></li>
        <li><a href="https://www.7shifts.com/blog/labor-cost-percentage/" target="_blank" rel="noopener">7shifts, Labor Cost Component Benchmarks</a></li>
      </ul>
    </section>

    <section class="related">
      <h2 class="related__headline">Related calculators</h2>
      <div class="related__grid">
        {relatedCalcs.map((c, i) => (
          <a href={`/calculators/${c.slug}/`} class="related-card">
            <div class="related-card__top">
              <span class="related-card__num num">{String(i + 1).padStart(2, '0')}</span>
              <span class="t-micro"><strong style="color:var(--color-saffron-text)">Free</strong> · 2 min</span>
            </div>
            <h3 class="related-card__title">{c.title}</h3>
            <p class="t-body related-card__desc">{c.desc}</p>
            <span class="related-card__arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </section>
  </article>
</Layout>

<script>
  const form = document.querySelector('[data-form]') as HTMLFormElement | null;
  const counter = document.querySelector('[data-counter]') as HTMLElement | null;
  const marker = document.querySelector('[data-marker]') as HTMLElement | null;
  const statusPill = document.querySelector('.status-pill') as HTMLElement | null;
  const statusLabel = document.querySelector('[data-status-label]') as HTMLElement | null;
  const benchEl = document.querySelector('[data-bench]') as HTMLElement | null;
  const cogsEl = document.querySelector('[data-cogs]') as HTMLElement | null;
  const laborvEl = document.querySelector('[data-laborv]') as HTMLElement | null;
  const primeEl = document.querySelector('[data-prime]') as HTMLElement | null;
  const foodPctEl = document.querySelector('[data-foodpct]') as HTMLElement | null;
  const laborPctEl = document.querySelector('[data-laborpct]') as HTMLElement | null;
  const mathBody = document.querySelector('[data-math]') as HTMLElement | null;
  const mathWrap = document.querySelector('[data-math-wrap]') as HTMLDetailsElement | null;

  if (form && counter && marker && statusPill && statusLabel && mathBody) {
    let lastValue = 0;
    let calcDebounce: number | null = null;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const CONCEPTS: Record<string, { label: string; low: number; high: number }> = {
      qsr:           { label: 'QSR',         low: 55, high: 60 },
      'fast-casual': { label: 'Fast casual', low: 55, high: 60 },
      casual:        { label: 'Casual',      low: 60, high: 65 },
      fine:          { label: 'Fine dining', low: 60, high: 70 },
      pizza:         { label: 'Pizza',       low: 55, high: 60 },
      cafe:          { label: 'Cafe',        low: 55, high: 60 },
    };

    function fmtUSD(n: number) { return '$' + Math.round(n).toLocaleString('en-US'); }
    function fmtUSDFull(n: number) { return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }); }

    function animateCounter(el: HTMLElement, from: number, to: number, duration = 800) {
      if (reduced) { el.textContent = to.toFixed(1); return; }
      const start = performance.now();
      const ease = (t: number) => 1 - Math.pow(1 - t, 3);
      function frame(now: number) {
        const t = Math.min((now - start) / duration, 1);
        const v = from + (to - from) * ease(t);
        el.textContent = v.toFixed(1);
        if (t < 1) requestAnimationFrame(frame);
        else { el.classList.add('result-num--pulse'); setTimeout(() => el.classList.remove('result-num--pulse'), 320); }
      }
      requestAnimationFrame(frame);
    }

    function getConcept() {
      const key = (document.querySelector('#concept') as HTMLSelectElement)?.value || 'casual';
      return CONCEPTS[key] || CONCEPTS.casual;
    }

    function statusFor(pct: number) {
      const c = getConcept();
      if (pct < c.low - 3) return { key: 'lean', label: 'Lean' };
      if (pct <= c.high) return { key: 'healthy', label: 'Healthy' };
      if (pct <= c.high + 5) return { key: 'watch', label: 'Watch' };
      return { key: 'critical', label: 'Critical' };
    }

    function reset() {
      statusPill!.dataset.status = 'empty';
      statusLabel!.textContent = 'Enter values';
      marker!.style.left = '0%';
      animateCounter(counter!, lastValue, 0, 400);
      lastValue = 0;
      mathBody!.innerHTML = '<p class="t-caption">Enter values above to see the calculation.</p>';
      [cogsEl, laborvEl, primeEl, foodPctEl, laborPctEl].forEach(e => { if (e) e.textContent = ', '; });
    }

    function calc() {
      const data = new FormData(form!);
      const food = parseFloat(String(data.get('food') || '0')) || 0;
      const beverage = parseFloat(String(data.get('beverage') || '0')) || 0;
      const laborRaw = parseFloat(String(data.get('labor') || '0')) || 0;
      const autoBurden = (document.querySelector('#auto-burden') as HTMLInputElement)?.checked || false;
      const labor = autoBurden ? laborRaw * 1.25 : laborRaw;
      const revenue = parseFloat(String(data.get('revenue') || '0')) || 0;

      if ((food + labor) <= 0 || revenue <= 0) { reset(); return; }

      const cogs = food + beverage;
      const prime = cogs + labor;
      const pct = (prime / revenue) * 100;
      const foodPct = (food / revenue) * 100;
      const bevPct = (beverage / revenue) * 100;
      const laborPct = (labor / revenue) * 100;
      const cogsPct = foodPct + bevPct;

      const concept = getConcept();
      if (benchEl) benchEl.textContent = `${concept.low}–${concept.high}%`;

      const clamped = Math.min(100, Math.max(0, pct));
      animateCounter(counter!, lastValue, pct, 800);
      lastValue = pct;
      const s = statusFor(pct);
      statusPill!.dataset.status = s.key;
      statusLabel!.textContent = s.label;
      marker!.style.left = `${clamped}%`;

      if (cogsEl) cogsEl.textContent = fmtUSD(cogs);
      if (laborvEl) laborvEl.textContent = fmtUSD(labor);
      if (primeEl) primeEl.textContent = fmtUSD(prime);
      if (foodPctEl) foodPctEl.textContent = `${cogsPct.toFixed(1)}%`;
      if (laborPctEl) laborPctEl.textContent = `${laborPct.toFixed(1)}%`;

      let note = '';
      if (s.label === 'Healthy') note = `You are in the healthy range for a ${concept.label.toLowerCase()} spot (${concept.low}–${concept.high}%). Keep checking weekly. Food and staff costs can move in opposite directions and hide a problem, so watch both.`;
      if (s.label === 'Lean') note = `This is below the usual ${concept.label.toLowerCase()} range. Double-check your staff number includes the extras (taxes, benefits, workers comp), not just paychecks. If you work for free, put a fair manager wage on paper for yourself first, or the number looks better than it really is.`;
      if (s.label === 'Watch') note = `A little above the healthy range for a ${concept.label.toLowerCase()} spot. Look at the split: ${cogsPct.toFixed(1)}% goes to food and drinks, ${laborPct.toFixed(1)}% goes to staff. Whichever one is more out of line is the one to fix first.`;
      if (s.label === 'Critical') note = `Above the healthy range for a ${concept.label.toLowerCase()} spot. Check both parts every week. The quickest wins usually come from staff costs: too many people on slow shifts, overtime adding up, or a schedule built for busier days that did not come back.`;

      mathBody!.innerHTML = `
        <table class="math-table" role="presentation">
          <tr><td>What your food cost</td><td class="num">${fmtUSDFull(food)}</td></tr>
          ${beverage > 0 ? `<tr><td>+ What your drinks cost</td><td class="num">${fmtUSDFull(beverage)}</td></tr>` : ''}
          <tr class="math-table__step"><td>= Food and drinks cost</td><td class="num">${fmtUSDFull(cogs)}</td></tr>
          <tr><td>+ Staff cost (${autoBurden ? 'paychecks plus 25%' : 'with extras added in'})</td><td class="num">${fmtUSDFull(labor)}</td></tr>
          <tr class="math-table__step"><td>= All three added up</td><td class="num"><strong>${fmtUSDFull(prime)}</strong></td></tr>
          <tr><td>÷ What you sold</td><td class="num">${fmtUSDFull(revenue)}</td></tr>
          <tr class="math-table__final"><td>Prime cost percent</td><td class="num"><strong>${pct.toFixed(1)}%</strong></td></tr>
        </table>
        ${note ? `<p class="t-caption math-note">${note}</p>` : ''}
      `;

      if (mathWrap && !mathWrap.open) mathWrap.open = true;
    }

    function debouncedCalc() {
      if (calcDebounce !== null) clearTimeout(calcDebounce);
      calcDebounce = window.setTimeout(calc, 250);
    }

    form.addEventListener('input', debouncedCalc);
    form.addEventListener('change', debouncedCalc);
    form.addEventListener('submit', (e) => { e.preventDefault(); if (calcDebounce !== null) clearTimeout(calcDebounce); calc(); });

    function loadExample() {
      (document.querySelector('#food') as HTMLInputElement).value = '7000';
      (document.querySelector('#beverage') as HTMLInputElement).value = '2000';
      (document.querySelector('#labor') as HTMLInputElement).value = '9000';
      (document.querySelector('#revenue') as HTMLInputElement).value = '30000';
      calc();
    }
    const loadExBtn = document.querySelector('[data-load-example]');
    if (loadExBtn) loadExBtn.addEventListener('click', loadExample);
    loadExample();
  }
</script>

<style>
