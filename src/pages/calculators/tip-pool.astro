  :global(.employee-row input.num) { font-family: var(--font-mono); font-variant-numeric: tabular-nums; }
  :global(.employee-row select) { padding-right: 28px; appearance: none; cursor: pointer; background-image: url("data:image/svg+xml;charset=utf-8,%3Csvg xmlns='http://www.w3.org/2000/svg' width='10' height='6' viewBox='0 0 10 6'%3E%3Cpath d='M1 1l4 4 4-4' stroke='%237a7569' stroke-width='1.5' fill='none' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E"); background-repeat: no-repeat; background-position: right 10px center; }
  :global(.employee-row input:focus), :global(.employee-row select:focus) { border-color: #c87500; box-shadow: 0 0 0 2px rgba(200, 117, 0, 0.18); }
