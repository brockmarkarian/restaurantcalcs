  .breadcrumb a:hover { color: var(--color-saffron-text); }
  .calc-page__header { max-width: 760px; margin-bottom: var(--space-12); }
  .calc-page__eyebrow { margin-bottom: var(--space-4); }
  .calc-page__title { font-family: var(--font-display); font-variation-settings: "opsz" 96, "wdth" 95; font-size: clamp(2.25rem, 5vw + 0.5rem, 3.5rem); font-weight: 500; line-height: 1.05; letter-spacing: -0.02em; color: var(--color-heading); margin-bottom: var(--space-5); }
  .calc-page__intro { font-family: var(--font-body); font-size: 1.125rem; line-height: 1.55; color: var(--color-body); max-width: 64ch; }

  .calc-grid { display: grid; grid-template-columns: minmax(0, 5fr) minmax(0, 6fr); gap: var(--space-12); margin-bottom: var(--space-16); align-items: start; }
  @media (max-width: 880px) { .calc-grid { grid-template-columns: 1fr; gap: var(--space-8); } }

  .calc-form { display: flex; flex-direction: column; gap: var(--space-5); background: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: var(--space-7); box-shadow: var(--shadow-warm); }
  .form-row { display: flex; flex-direction: column; gap: var(--space-2); }
  .form-row__label { font-family: var(--font-body); font-size: 0.8125rem; font-weight: 500; letter-spacing: 0.02em; color: var(--color-heading); }
  .form-row__hint { font-family: var(--font-body); font-size: 0.75rem; color: var(--color-muted); line-height: 1.40; }
  .calc-form__submit { margin-top: var(--space-2); width: 100%; justify-content: center; }
  .calc-form__privacy { text-align: center; color: var(--color-muted); }

  .form-intro { background: var(--color-cream); border: 1px dashed var(--color-border); border-radius: var(--radius-md); padding: var(--space-4); display: flex; flex-direction: column; gap: var(--space-2); }
  .form-intro__what { font-family: var(--font-body); font-size: 0.8125rem; line-height: 1.5; color: var(--color-body); margin: 0; }
  .form-intro__example { background: transparent; border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 6px 12px; font-family: var(--font-body); font-size: 0.75rem; font-weight: 500; color: var(--color-saffron-text); cursor: pointer; align-self: flex-start; transition: all var(--transition-fast); }
  .form-intro__example:hover { border-color: var(--color-saffron); background: var(--color-saffron-light); }

  /* Menu items table */
  .menu { background: var(--color-cream); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-5); display: flex; flex-direction: column; gap: var(--space-4); }
  .menu__head { display: flex; flex-direction: column; gap: var(--space-2); }
  .menu__title { font-family: var(--font-display); font-variation-settings: "opsz" 28, "wdth" 100; font-size: 1.0625rem; font-weight: 600; color: var(--color-heading); margin: 0; }
  .menu__hint { font-family: var(--font-body); font-size: 0.75rem; color: var(--color-muted); line-height: 1.45; margin: 0; }

  .menu__table { display: flex; flex-direction: column; gap: var(--space-2); }
  .menu__thead { display: grid; grid-template-columns: minmax(0, 1.6fr) minmax(0, 0.9fr) minmax(0, 0.9fr) minmax(0, 0.7fr) 32px; gap: 6px; padding: 0 8px; font-family: var(--font-body); font-size: 0.6875rem; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; color: var(--color-muted); }
  @media (max-width: 720px) { .menu__thead { display: none; } }

  .menu__rows { display: flex; flex-direction: column; gap: var(--space-2); }
  .menu__rows:empty::before { content: 'No items yet. Click "Load example menu" or "+ Add item" to start.'; display: block; padding: var(--space-5) var(--space-4); text-align: center; font-family: var(--font-body); font-size: 0.8125rem; color: var(--color-muted); border: 1.5px dashed var(--color-border); border-radius: var(--radius-md); }

  .menu-row { display: grid; grid-template-columns: minmax(0, 1.6fr) minmax(0, 0.9fr) minmax(0, 0.9fr) minmax(0, 0.7fr) 32px; gap: 6px; align-items: center; background: var(--color-white); border: 1px solid var(--color-border); border-radius: 8px; padding: 6px 6px 6px 8px; transition: border-color var(--transition-fast); }
  .menu-row:focus-within { border-color: var(--color-saffron); }
  @media (max-width: 720px) { .menu-row { grid-template-columns: 1fr 1fr; gap: 6px; padding: 8px; } .menu-row__name { grid-column: 1 / -1; } .menu-row > input, .menu-row > .menu-row__money { font-size: 0.875rem !important; } .menu-row .menu-row__remove { grid-column: 2; justify-self: end; } }

  .menu-row input { background: transparent; border: none; padding: 6px 8px; font-family: var(--font-mono); font-variant-numeric: tabular-nums; font-size: 0.875rem; font-weight: 500; color: var(--color-heading); outline: none; min-width: 0; width: 100%; border-radius: 4px; }
  .menu-row input:focus { background: var(--color-cream); }
  .menu-row__name { font-family: var(--font-body) !important; }
  .menu-row__money { display: flex; align-items: center; gap: 0; background: transparent; border-radius: 4px; min-width: 0; }
  .menu-row__money input { padding-left: 2px; }
  .menu-row__prefix { font-family: var(--font-mono); font-size: 0.875rem; color: var(--color-muted); padding-left: 6px; flex-shrink: 0; }
  .menu-row__remove { background: transparent; border: none; color: var(--color-muted); cursor: pointer; padding: 0; width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1rem; line-height: 1; transition: all var(--transition-fast); }
  .menu-row__remove:hover { background: rgba(192, 57, 43, 0.1); color: #c0392b; }

  .menu__actions { display: flex; flex-wrap: wrap; gap: var(--space-3); align-items: center; }
  .menu__example, .menu__clear { background: transparent; border: 1px solid var(--color-border); padding: 6px 10px; border-radius: var(--radius-md); font-family: var(--font-body); font-size: 0.75rem; font-weight: 500; color: var(--color-body); cursor: pointer; transition: all var(--transition-fast); }
  .menu__example:hover { border-color: var(--color-saffron); color: var(--color-saffron-text); }
  .menu__clear:hover { border-color: #c0392b; color: #c0392b; }

  .menu__totals { display: flex; flex-direction: column; gap: 4px; padding: var(--space-3) 0 0; border-top: 1px dashed var(--color-border); }
  .menu__total-row { display: flex; justify-content: space-between; align-items: center; padding: 4px 0; font-family: var(--font-body); font-size: 0.8125rem; }
  .menu__total-label { color: var(--color-body); }
  .menu__total-value { font-weight: 600; color: var(--color-heading); }
  .menu__total-row--final { padding-top: 8px; margin-top: 4px; border-top: 1px solid var(--color-heading); }
  .menu__total-row--final .menu__total-label { font-weight: 600; }
  .menu__total-row--final .menu__total-value { font-size: 1rem; color: var(--color-saffron-text); }

  /* Result card */
  .calc-result { display: flex; flex-direction: column; gap: var(--space-5); position: sticky; top: 120px; }
  @media (max-width: 880px) { .calc-result { position: static; } }
  .calc-result__card { background: var(--gradient-card-warm); border: 1px solid var(--color-border); border-radius: var(--radius-xl); padding: var(--space-10) var(--space-8); box-shadow: 0 1px 2px var(--alpha-shadow-2), 0 12px 32px var(--alpha-shadow-1), 0 40px 80px -40px var(--alpha-saffron-glow-strong); position: relative; overflow: hidden; }
  .calc-result__card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, transparent, var(--color-saffron) 50%, transparent); opacity: 0.7; pointer-events: none; }
  .calc-result__card::after { content: ''; position: absolute; top: -140px; right: -140px; width: 280px; height: 280px; background: radial-gradient(circle, var(--alpha-saffron-glow-strong) 0%, transparent 70%); pointer-events: none; z-index: 0; }
  .calc-result__card > * { position: relative; z-index: 1; }
  .calc-result__head { display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-5); flex-wrap: wrap; gap: var(--space-2); }

  .calc-result__big { display: flex; align-items: baseline; justify-content: center; gap: 4px; margin-bottom: var(--space-5); }
  .result-num__pre { font-family: var(--font-mono); font-size: clamp(2rem, 5.5vw + 0.5rem, 3.75rem); color: var(--color-saffron-text); font-weight: 400; }
  .result-num { font-family: var(--font-mono); font-variant-numeric: tabular-nums; font-feature-settings: "tnum"; font-size: clamp(3.5rem, 9vw + 0.5rem, 6.5rem); font-weight: 400; line-height: 0.92; letter-spacing: -0.04em; color: var(--color-saffron-text); transition: transform 320ms cubic-bezier(0.16, 1, 0.3, 1); }
  .result-num--pulse { transform: scale(1.025); }
  .calc-result__benchmark { display: flex; justify-content: space-between; align-items: center; padding: var(--space-3) 0; border-top: 1px dashed var(--color-border); border-bottom: 1px dashed var(--color-border); margin-bottom: var(--space-5); gap: var(--space-3); }

  /* Scatter matrix in result card */
  .matrix { margin-bottom: var(--space-5); padding-left: 28px; padding-bottom: 24px; position: relative; }
  .matrix__plot { position: relative; aspect-ratio: 1; width: 100%; background:
    linear-gradient(135deg, rgba(40, 80, 130, 0.08) 0%, rgba(40, 80, 130, 0.08) 50%, transparent 50%),
    linear-gradient(225deg, rgba(74, 88, 38, 0.10) 0%, rgba(74, 88, 38, 0.10) 50%, transparent 50%),
    linear-gradient(315deg, rgba(200, 117, 0, 0.10) 0%, rgba(200, 117, 0, 0.10) 50%, transparent 50%),
    linear-gradient(45deg, rgba(192, 57, 43, 0.10) 0%, rgba(192, 57, 43, 0.10) 50%, transparent 50%);
    background-size: 50% 50%; background-position: 0 0, 100% 0, 100% 100%, 0 100%; background-repeat: no-repeat;
    border: 1px solid var(--color-border); border-radius: var(--radius-md); }
  .matrix__hline, .matrix__vline { position: absolute; background: var(--color-border); }
  .matrix__hline { left: 0; right: 0; top: 50%; height: 1px; }
  .matrix__vline { top: 0; bottom: 0; left: 50%; width: 1px; }
  .matrix__axis-y, .matrix__axis-x { position: absolute; font-family: var(--font-body); font-size: 0.6875rem; color: var(--color-muted); text-transform: uppercase; letter-spacing: 0.06em; font-weight: 500; }
  .matrix__axis-y { left: -28px; top: 50%; transform: rotate(-90deg) translateX(50%); transform-origin: right center; }
  .matrix__axis-x { left: 50%; bottom: -22px; transform: translateX(-50%); white-space: nowrap; }
  .matrix__corner { position: absolute; display: flex; flex-direction: column; gap: 2px; padding: 6px 8px; pointer-events: none; }
  .matrix__corner-label { font-family: var(--font-body); font-size: 0.625rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; }
  .matrix__corner-count { font-family: var(--font-mono); font-variant-numeric: tabular-nums; font-size: 1.25rem; font-weight: 500; line-height: 1; }
  .matrix__corner--puzzle { top: 0; left: 0; }
  .matrix__corner--puzzle .matrix__corner-label, .matrix__corner--puzzle .matrix__corner-count { color: #285082; }
  .matrix__corner--star { top: 0; right: 0; align-items: flex-end; }
  .matrix__corner--star .matrix__corner-label, .matrix__corner--star .matrix__corner-count { color: #4a5826; }
  .matrix__corner--dog { bottom: 0; left: 0; }
  .matrix__corner--dog .matrix__corner-label, .matrix__corner--dog .matrix__corner-count { color: #c0392b; }
  .matrix__corner--plowhorse { bottom: 0; right: 0; align-items: flex-end; }
  .matrix__corner--plowhorse .matrix__corner-label, .matrix__corner--plowhorse .matrix__corner-count { color: var(--color-saffron-text); }
  .matrix__dots { position: absolute; inset: 0; }
  .matrix__dot { position: absolute; width: 14px; height: 14px; border-radius: 50%; transform: translate(-50%, -50%); border: 2px solid var(--color-white); box-shadow: 0 1px 4px rgba(0,0,0,0.18); transition: transform var(--transition-fast); cursor: help; }
  .matrix__dot:hover, .matrix__dot:focus { transform: translate(-50%, -50%) scale(1.4); z-index: 10; }
  .matrix__dot--star { background: #4a5826; }
  .matrix__dot--plowhorse { background: var(--color-saffron-cta); }
  .matrix__dot--puzzle { background: #285082; }
  .matrix__dot--dog { background: #c0392b; }
  .matrix__dot-tip { position: absolute; bottom: 130%; left: 50%; transform: translateX(-50%); white-space: nowrap; background: var(--color-heading); color: var(--color-white); font-family: var(--font-body); font-size: 0.6875rem; padding: 4px 8px; border-radius: 4px; opacity: 0; pointer-events: none; transition: opacity var(--transition-fast); }
  .matrix__dot:hover .matrix__dot-tip, .matrix__dot:focus .matrix__dot-tip { opacity: 1; }

  .status-pill { display: inline-flex; align-items: center; gap: 6px; padding: 5px 11px; border-radius: 999px; font-family: var(--font-body); font-size: 0.6875rem; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; transition: background var(--transition-fast), color var(--transition-fast); }
  .status-pill__dot { width: 6px; height: 6px; border-radius: 50%; }
  .status-pill[data-status="empty"] { background: rgba(122, 117, 105, 0.10); color: var(--color-muted); }
  .status-pill[data-status="empty"] .status-pill__dot { background: var(--color-muted); box-shadow: 0 0 0 3px rgba(122, 117, 105, 0.18); }
  .status-pill[data-status="healthy"] { background: rgba(74, 88, 38, 0.12); color: #4a5826; }
  .status-pill[data-status="healthy"] .status-pill__dot { background: #4a5826; box-shadow: 0 0 0 3px rgba(74, 88, 38, 0.18); }
  .status-pill[data-status="watch"] { background: rgba(200, 117, 0, 0.14); color: var(--color-saffron-text); }
  .status-pill[data-status="watch"] .status-pill__dot { background: var(--color-saffron); box-shadow: 0 0 0 3px rgba(200, 117, 0, 0.20); }
  .status-pill[data-status="critical"] { background: rgba(192, 57, 43, 0.14); color: #c0392b; }
  .status-pill[data-status="critical"] .status-pill__dot { background: #c0392b; box-shadow: 0 0 0 3px rgba(192, 57, 43, 0.22); }

  .calc-result__extras { display: flex; flex-direction: column; gap: var(--space-2); padding-top: var(--space-4); border-top: 1px solid var(--color-border); }
  .extras-row { display: flex; justify-content: space-between; align-items: center; padding: 6px 0; font-family: var(--font-body); font-size: 0.875rem; gap: var(--space-3); }
  .extras-row__label { color: var(--color-body); flex-shrink: 0; }
  .extras-row__value { font-weight: 500; color: var(--color-heading); text-align: right; }

  .show-math { background: var(--color-cream); border: 1px solid var(--color-border); border-radius: var(--radius-md); overflow: hidden; }
  .show-math__trigger { display: flex; align-items: center; gap: var(--space-3); padding: var(--space-4) var(--space-5); cursor: pointer; font-family: var(--font-body); font-size: 0.9375rem; font-weight: 600; color: var(--color-heading); list-style: none; transition: background var(--transition-fast); }
  .show-math__trigger::-webkit-details-marker { display: none; }
  .show-math__trigger:hover { background: var(--color-border-soft); }
  .show-math__icon { font-family: var(--font-mono); font-size: 1.125rem; color: var(--color-saffron-text); transition: transform var(--transition-fast); width: 16px; text-align: center; }
  .show-math[open] .show-math__icon { transform: rotate(45deg); }
  .show-math__body { padding: var(--space-3) var(--space-5) var(--space-5); }
  .math-table { width: 100%; border-collapse: collapse; font-size: 0.9375rem; }
  .math-table td { padding: 10px 6px; border-bottom: 1px dashed var(--color-border); vertical-align: middle; line-height: 1.45; }
  .math-table td:first-child { color: var(--color-body); padding-left: 0; }
  .math-table td:last-child { text-align: right; color: var(--color-heading); padding-right: 0; white-space: nowrap; font-family: var(--font-mono); font-variant-numeric: tabular-nums; }
  .math-table__step td:first-child { padding-left: var(--space-4); color: var(--color-muted); font-size: 0.875rem; }
  .math-table__step td:last-child { color: var(--color-saffron-text); font-weight: 500; }
  .math-table__final td { padding-top: 14px; padding-bottom: 6px; border-bottom: none; border-top: 1.5px solid var(--color-heading); }
  .math-table__final td:last-child { font-size: 1.0625rem; }
  .math-table__final td strong { color: var(--color-saffron-text); }
  .math-note { margin-top: var(--space-4); padding-top: var(--space-3); border-top: 1px dashed var(--color-border); color: var(--color-body); line-height: 1.5; }

  /* Classified results table */
  .results-table { margin: var(--space-12) 0 var(--space-16); }
  .results-table[hidden] { display: none; }
  .results-table__headline { font-family: var(--font-display); font-variation-settings: "opsz" 60, "wdth" 100; font-size: clamp(1.625rem, 3vw + 0.5rem, 2.25rem); font-weight: 500; line-height: 1.18; letter-spacing: -0.012em; color: var(--color-heading); margin-bottom: var(--space-2); }
  .results-table__intro { max-width: 64ch; margin-bottom: var(--space-6); }
  .results-table__wrap { background: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--radius-lg); overflow-x: auto; box-shadow: var(--shadow-warm); }
  .results-table__table { width: 100%; border-collapse: collapse; min-width: 720px; }
  .results-table__table thead th { padding: var(--space-3) var(--space-4); text-align: left; font-family: var(--font-body); font-size: 0.6875rem; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; color: var(--color-muted); border-bottom: 1px solid var(--color-border); background: var(--color-cream); white-space: nowrap; }
  .results-table__table thead th.num { text-align: right; }
  .results-table__table tbody td { padding: var(--space-3) var(--space-4); border-bottom: 1px dashed var(--color-border); font-family: var(--font-body); font-size: 0.9375rem; color: var(--color-heading); vertical-align: middle; }
  .results-table__table tbody td.num { font-family: var(--font-mono); font-variant-numeric: tabular-nums; text-align: right; white-space: nowrap; }
  .results-table__table tbody tr:last-child td { border-bottom: none; }

  .badge { display: inline-flex; align-items: center; padding: 4px 10px; border-radius: 999px; font-family: var(--font-body); font-size: 0.6875rem; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; }
  .badge--star { background: rgba(74, 88, 38, 0.14); color: #4a5826; }
  .badge--plowhorse { background: rgba(200, 117, 0, 0.16); color: var(--color-saffron-text); }
  .badge--puzzle { background: rgba(40, 80, 130, 0.12); color: #285082; }
  .badge--dog { background: rgba(192, 57, 43, 0.14); color: #c0392b; }

  /* Quadrant guide section */
  .quadrant-guide { margin-bottom: var(--space-16); }
  .quadrant-guide__headline { font-family: var(--font-display); font-variation-settings: "opsz" 72, "wdth" 100; font-size: clamp(1.75rem, 3vw + 0.5rem, 2.5rem); font-weight: 500; line-height: 1.15; letter-spacing: -0.012em; color: var(--color-heading); margin: var(--space-3) 0 var(--space-3); }
  .quadrant-guide__headline em { font-style: italic; font-weight: 500; color: var(--color-saffron-text); }
  .quadrant-guide__intro { max-width: 64ch; margin-bottom: var(--space-8); }
  .quadrant-guide__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-5); }
  @media (max-width: 720px) { .quadrant-guide__grid { grid-template-columns: 1fr; } }
  .qg-card { display: flex; flex-direction: column; gap: var(--space-3); background: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: var(--space-7); box-shadow: var(--shadow-warm); position: relative; }
  .qg-card__badge { align-self: flex-start; padding: 4px 12px; border-radius: 999px; font-family: var(--font-body); font-size: 0.6875rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; }
  .qg-card--star .qg-card__badge { background: rgba(74, 88, 38, 0.14); color: #4a5826; }
  .qg-card--plowhorse .qg-card__badge { background: rgba(200, 117, 0, 0.16); color: var(--color-saffron-text); }
  .qg-card--puzzle .qg-card__badge { background: rgba(40, 80, 130, 0.12); color: #285082; }
  .qg-card--dog .qg-card__badge { background: rgba(192, 57, 43, 0.14); color: #c0392b; }
  .qg-card__title { font-family: var(--font-display); font-variation-settings: "opsz" 36, "wdth" 100; font-size: 1.25rem; font-weight: 500; line-height: 1.25; color: var(--color-heading); margin: 0; }
  .qg-card__list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--space-2); }
  .qg-card__list li { position: relative; padding-left: var(--space-5); font-family: var(--font-body); font-size: 0.9375rem; line-height: 1.55; color: var(--color-body); }
  .qg-card__list li::before { content: ''; position: absolute; left: 4px; top: 0.6em; width: 6px; height: 6px; border-radius: 50%; background: var(--color-saffron); }

  .essay { margin: var(--space-16) auto; max-width: 720px; }
  .essay__eyebrow { margin-bottom: var(--space-4); }
  .essay__headline { font-family: var(--font-display); font-variation-settings: "opsz" 96, "wdth" 95; font-size: clamp(2rem, 4vw + 0.5rem, 3rem); font-weight: 500; line-height: 1.10; letter-spacing: -0.018em; color: var(--color-heading); margin-bottom: var(--space-8); }
  .essay__headline em { font-style: italic; font-weight: 500; color: var(--color-saffron-text); }
  .essay__body p { font-family: var(--font-body); font-size: 1.125rem; line-height: 1.65; color: var(--color-body); margin-bottom: var(--space-5); }
  .essay__pull { position: relative; font-family: var(--font-display); font-variation-settings: "opsz" 96, "wdth" 95; font-size: clamp(1.625rem, 3.2vw + 0.5rem, 2.5rem) !important; font-weight: 500; line-height: 1.18 !important; letter-spacing: -0.018em; color: var(--color-heading) !important; padding: var(--space-8) var(--space-2) var(--space-8) var(--space-10) !important; margin: var(--space-10) 0 !important; border-left: 4px solid var(--color-saffron); background: linear-gradient(90deg, var(--alpha-saffron-tint), transparent 80%); }
  .essay__pull::before { content: '\201C'; position: absolute; left: 8px; top: -8px; font-family: var(--font-display); font-style: italic; font-size: 5rem; line-height: 1; color: var(--color-saffron); opacity: 0.40; pointer-events: none; }

  .rule { border: none; height: 24px; margin: var(--space-16) 0; background-image: linear-gradient(90deg, transparent 0%, var(--color-border) 15%, var(--color-border) 42%, transparent 48%, transparent 52%, var(--color-border) 58%, var(--color-border) 85%, transparent 100%), radial-gradient(circle 3px at center, var(--color-saffron) 55%, transparent 56%); background-position: 0 50%, center center; background-repeat: no-repeat; background-size: 100% 1px, 8px 8px; }
  .ad-wrap { margin: var(--space-12) 0; padding: 0; }
  .ad-inline { border: 1px dashed var(--color-border); border-radius: var(--radius-md); background: var(--color-cream); overflow: hidden; }
  .ad-inline__label { display: block; padding: 6px 12px; font-family: var(--font-body); font-size: 0.6875rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-muted); background: rgba(122, 117, 105, 0.06); border-bottom: 1px dashed var(--color-border); }
  .ad-inline__inner { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px; padding: var(--space-6); min-height: 280px; }

  .scenarios { margin-bottom: var(--space-16); }
  .scenarios__headline { font-family: var(--font-display); font-variation-settings: "opsz" 72, "wdth" 100; font-size: clamp(1.75rem, 3vw + 0.5rem, 2.5rem); font-weight: 500; line-height: 1.15; letter-spacing: -0.012em; color: var(--color-heading); margin: var(--space-3) 0 var(--space-4); }
  .scenarios__intro { max-width: 64ch; margin-bottom: var(--space-8); }
  .scenarios__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-5); }
  @media (max-width: 880px) { .scenarios__grid { grid-template-columns: 1fr; } }
  .scenario-card { display: flex; flex-direction: column; gap: var(--space-3); background: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: var(--space-7); box-shadow: var(--shadow-warm); position: relative; }
  .scenario-card__num { position: absolute; top: var(--space-5); right: var(--space-5); font-family: var(--font-mono); font-size: 0.8125rem; color: var(--color-saffron-text); }
  .scenario-card__title { font-family: var(--font-display); font-variation-settings: "opsz" 36, "wdth" 100; font-size: 1.25rem; font-weight: 500; line-height: 1.25; color: var(--color-heading); margin-bottom: var(--space-2); padding-right: var(--space-8); }
  .scenario-card__setup { font-family: var(--font-body); font-size: 0.9375rem; line-height: 1.55; color: var(--color-body); margin-bottom: var(--space-2); }
  .scenario-card__row { display: flex; flex-direction: column; gap: 3px; padding: var(--space-3) 0; border-top: 1px dashed var(--color-border); }
  .scenario-card__row--outcome { border-top: 1px solid var(--color-saffron); padding-top: var(--space-4); margin-top: var(--space-2); }
  .scenario-card__label { font-family: var(--font-body); font-size: 0.6875rem; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; color: var(--color-saffron-text); }
  .scenario-card__text { font-family: var(--font-body); font-size: 0.9375rem; line-height: 1.55; color: var(--color-body); }

  .calc-faq { margin-bottom: var(--space-16); max-width: 880px; }
  .calc-faq__headline { font-family: var(--font-display); font-variation-settings: "opsz" 60, "wdth" 100; font-size: clamp(1.75rem, 3vw + 0.5rem, 2.5rem); font-weight: 500; line-height: 1.20; letter-spacing: -0.012em; color: var(--color-heading); margin: var(--space-3) 0 var(--space-8); }
  .calc-faq__item { border-top: 1px solid var(--color-border); padding: var(--space-5) 0; }
  .calc-faq__item:last-child { border-bottom: 1px solid var(--color-border); }
  .calc-faq__q { display: flex; align-items: baseline; gap: var(--space-4); cursor: pointer; font-family: var(--font-display); font-variation-settings: "opsz" 28, "wdth" 100; font-size: 1.25rem; font-weight: 500; line-height: 1.3; color: var(--color-heading); list-style: none; }
  .calc-faq__q::-webkit-details-marker { display: none; }
  .calc-faq__num { font-family: var(--font-mono); font-size: 0.8125rem; font-weight: 500; color: var(--color-saffron-text); flex-shrink: 0; }
  .calc-faq__qtext { flex: 1; }
  .calc-faq__plus { font-family: var(--font-mono); font-size: 1.5rem; font-weight: 300; color: var(--color-saffron-text); transition: transform var(--transition-fast); flex-shrink: 0; }
  .calc-faq__item[open] .calc-faq__plus { transform: rotate(45deg); }
  .calc-faq__a { margin: var(--space-4) 0 var(--space-2) calc(2ch + var(--space-4)); font-family: var(--font-body); font-size: 1rem; line-height: 1.65; color: var(--color-body); max-width: 64ch; }

  .cited-sources { margin-bottom: var(--space-12); }
