<script>
  const form = document.querySelector('[data-form]') as HTMLFormElement | null;
  const counter = document.querySelector('[data-counter]') as HTMLElement | null;
  const marker = document.querySelector('[data-marker]') as HTMLElement | null;
  const statusPill = document.querySelector('.status-pill') as HTMLElement | null;
  const statusLabel = document.querySelector('[data-status-label]') as HTMLElement | null;
  const mathBody = document.querySelector('[data-math]') as HTMLElement | null;
  const mathWrap = document.querySelector('[data-math-wrap]') as HTMLDetailsElement | null;
  const extras = document.querySelector('[data-extras]') as HTMLElement | null;
  const cogsEl = document.querySelector('[data-cogs]') as HTMLElement | null;
  const targetRow = document.querySelector('[data-target-row]') as HTMLElement | null;
  const targetVarEl = document.querySelector('[data-target-variance]') as HTMLElement | null;
  const targetMoneyRow = document.querySelector('[data-target-money-row]') as HTMLElement | null;
  const targetMoneyEl = document.querySelector('[data-target-money]') as HTMLElement | null;
  const theoreticalRow = document.querySelector('[data-theoretical-row]') as HTMLElement | null;
  const theoreticalVarEl = document.querySelector('[data-theoretical-variance]') as HTMLElement | null;
  const modeBtns = document.querySelectorAll<HTMLButtonElement>('[data-mode-btn]');

  if (form && counter && marker && statusPill && statusLabel && mathBody) {
    let lastValue = 0;
    let calcDebounce: number | null = null;
    let mode: 'quick' | 'detailed' = 'quick';
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function fmtUSD(n: number): string {
      const sign = n < 0 ? '-' : '';
      const abs = Math.abs(n);
      return sign + '$' + abs.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    function fmtSignedUSD(n: number): string {
      const sign = n < 0 ? '−' : '+';
      const abs = Math.abs(n);
      return sign + '$' + abs.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    function animateCounter(el: HTMLElement, from: number, to: number, duration = 800, decimals = 1) {
      if (reduced) {
        el.textContent = to.toFixed(decimals);
        return;
      }
      const start = performance.now();
      const ease = (t: number) => 1 - Math.pow(1 - t, 3);
      function frame(now: number) {
        const t = Math.min((now - start) / duration, 1);
        const value = from + (to - from) * ease(t);
        el.textContent = value.toFixed(decimals);
        if (t < 1) requestAnimationFrame(frame);
        else {
          el.classList.add('result-num--pulse');
          setTimeout(() => el.classList.remove('result-num--pulse'), 320);
        }
      }
      requestAnimationFrame(frame);
    }

    function statusFor(pct: number): { key: string; label: string } {
      if (pct < 28) return { key: 'lean', label: 'Lean' };
      if (pct <= 32) return { key: 'healthy', label: 'Healthy' };
      if (pct <= 35) return { key: 'watch', label: 'Watch' };
      return { key: 'critical', label: 'Critical' };
    }

    function reset() {
      statusPill!.dataset.status = 'empty';
      statusLabel!.textContent = 'Enter values';
      marker!.style.left = '0%';
      animateCounter(counter!, lastValue, 0, 400, 1);
      lastValue = 0;
      mathBody!.innerHTML = '<p class="t-caption">Enter values above to see the calculation.</p>';
      if (extras) extras.hidden = true;
    }

    function calc() {
      const data = new FormData(form!);
      const revenue = parseFloat(String(data.get('revenue') || '0')) || 0;

      let cogs = 0;
      let mathRows = '';

      if (mode === 'quick') {
        cogs = parseFloat(String(data.get('cost') || '0')) || 0;
        if (cogs <= 0 || revenue <= 0) { reset(); return; }
        mathRows = `
          <tr><td>Total food cost</td><td class="num">${fmtUSD(cogs)}</td></tr>
          <tr><td>Total food sales</td><td class="num">${fmtUSD(revenue)}</td></tr>
        `;
      } else {
        const opening = parseFloat(String(data.get('opening') || '0')) || 0;
        const purchases = parseFloat(String(data.get('purchases') || '0')) || 0;
        const closing = parseFloat(String(data.get('closing') || '0')) || 0;
        const transfersIn = parseFloat(String(data.get('transfers-in') || '0')) || 0;
        const transfersOut = parseFloat(String(data.get('transfers-out') || '0')) || 0;
        const employeeMeals = parseFloat(String(data.get('employee-meals') || '0')) || 0;
        const comps = parseFloat(String(data.get('comps') || '0')) || 0;
        cogs = opening + purchases + transfersIn - transfersOut - employeeMeals - comps - closing;
        if (cogs <= 0 || revenue <= 0) { reset(); return; }
        const adjRows = (transfersIn || transfersOut || employeeMeals || comps)
          ? `
            ${transfersIn > 0 ? `<tr class="math-table__step"><td>+ Food moved in</td><td class="num">${fmtUSD(transfersIn)}</td></tr>` : ''}
            ${transfersOut > 0 ? `<tr class="math-table__step"><td>− Food moved out</td><td class="num">${fmtUSD(transfersOut)}</td></tr>` : ''}
            ${employeeMeals > 0 ? `<tr class="math-table__step"><td>− Staff meals</td><td class="num">${fmtUSD(employeeMeals)}</td></tr>` : ''}
            ${comps > 0 ? `<tr class="math-table__step"><td>− Free/comped food</td><td class="num">${fmtUSD(comps)}</td></tr>` : ''}
          `
          : '';
        mathRows = `
          <tr><td>Food at start</td><td class="num">${fmtUSD(opening)}</td></tr>
          <tr><td>+ Purchases</td><td class="num">${fmtUSD(purchases)}</td></tr>
          ${adjRows}
          <tr><td>− Food at end</td><td class="num">${fmtUSD(closing)}</td></tr>
          <tr class="math-table__step"><td>= Your food cost</td><td class="num"><strong>${fmtUSD(cogs)}</strong></td></tr>
          <tr><td>Total food sales</td><td class="num">${fmtUSD(revenue)}</td></tr>
        `;
      }

      const pct = (cogs / revenue) * 100;
      const clamped = Math.min(50, Math.max(0, pct));
      const markerPos = (clamped / 50) * 100;

      animateCounter(counter!, lastValue, pct, 800, 1);
      lastValue = pct;

      const s = statusFor(pct);
      statusPill!.dataset.status = s.key;
      statusLabel!.textContent = s.label;
      marker!.style.left = `${markerPos}%`;

      // Detailed extras
      if (mode === 'detailed' && extras && cogsEl) {
        extras.hidden = false;
        cogsEl.textContent = fmtUSD(cogs);

        const targetRaw = parseFloat(String(data.get('target') || ''));
        const target = isNaN(targetRaw) ? null : targetRaw;
        const theoreticalRaw = parseFloat(String(data.get('theoretical') || ''));
        const theoretical = isNaN(theoreticalRaw) ? null : theoreticalRaw;

        if (target !== null && targetRow && targetVarEl && targetMoneyRow && targetMoneyEl) {
          const diff = pct - target;
          targetRow.hidden = false;
          targetVarEl.textContent = `${diff >= 0 ? '+' : '−'}${Math.abs(diff).toFixed(2)}pp`;
          targetVarEl.className = `extras-row__value num ${diff > 0.5 ? 'is-bad' : diff < -0.5 ? 'is-lean' : 'is-good'}`;
          targetMoneyRow.hidden = false;
          const targetCogs = revenue * (target / 100);
          const moneyDiff = cogs - targetCogs;
          targetMoneyEl.textContent = moneyDiff >= 0
            ? `${fmtSignedUSD(moneyDiff)} over target`
            : `${fmtSignedUSD(moneyDiff)} under target`;
          targetMoneyEl.className = `extras-row__value num ${moneyDiff > 0 ? 'is-bad' : 'is-good'}`;
        } else if (targetRow && targetMoneyRow) {
          targetRow.hidden = true;
          targetMoneyRow.hidden = true;
        }

        if (theoretical !== null && theoreticalRow && theoreticalVarEl) {
          const tDiff = pct - theoretical;
          theoreticalRow.hidden = false;
          theoreticalVarEl.textContent = `${tDiff >= 0 ? '+' : '−'}${Math.abs(tDiff).toFixed(2)}pp variance`;
          theoreticalVarEl.className = `extras-row__value num ${Math.abs(tDiff) > 3 ? 'is-bad' : Math.abs(tDiff) > 1 ? 'is-watch' : 'is-good'}`;
        } else if (theoreticalRow) {
          theoreticalRow.hidden = true;
        }
      } else if (extras) {
        extras.hidden = true;
      }

      // Math breakdown
      let note = '';
      if (s.label === 'Healthy') note = 'In the healthy band. Maintain weekly tracking to catch drift.';
      if (s.label === 'Lean') note = 'Below typical range. Verify revenue and cost numbers, and check for under-portioning that could hurt guest experience.';
      if (s.label === 'Watch') note = 'Slightly elevated. Common causes: portion creep, supplier price increases without menu update, or rising waste.';
      if (s.label === 'Critical') note = 'Above industry healthy range. Investigate: menu repricing, portion audits, supplier renegotiation, theft, or waste tracking.';

      mathBody!.innerHTML = `
        <table class="math-table" role="presentation">
          ${mathRows}
          <tr class="math-table__step"><td>Food cost ÷ food sales</td><td class="num">${(cogs / revenue).toFixed(4)}</td></tr>
          <tr class="math-table__step"><td>× 100</td><td class="num">${pct.toFixed(2)}%</td></tr>
          <tr class="math-table__final"><td>Food cost percentage</td><td class="num"><strong>${pct.toFixed(1)}%</strong></td></tr>
        </table>
        ${note ? `<p class="t-caption math-note">${note}</p>` : ''}
      `;

      if (mathWrap && !mathWrap.open) mathWrap.open = true;
    }

    function debouncedCalc() {
      if (calcDebounce !== null) clearTimeout(calcDebounce);
      calcDebounce = window.setTimeout(calc, 250);
    }

    form.addEventListener('input', debouncedCalc);
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      if (calcDebounce !== null) clearTimeout(calcDebounce);
      calc();
    });

    // Mode toggle (now mode-switch links below form)
    function setMode(newMode: 'quick' | 'detailed') {
      if (newMode === mode) return;
      mode = newMode;
      form.dataset.mode = mode;
      document.querySelectorAll<HTMLElement>('[data-group]').forEach((g) => {
        g.classList.toggle('form-group--hidden', g.dataset.group !== mode);
      });
      // Toggle which mode-switch button is shown
      const quickSwitch = document.querySelector('.mode-switch[data-mode-btn="detailed"]') as HTMLElement | null;
      const detailedSwitch = document.querySelector('.mode-switch[data-mode-btn="quick"]') as HTMLElement | null;
      if (quickSwitch && detailedSwitch) {
        quickSwitch.classList.toggle('mode-switch--hidden', mode === 'detailed');
        detailedSwitch.classList.toggle('mode-switch--hidden', mode === 'quick');
      }
      // Re-trigger calc w/ existing values (which will reset if values invalid for new mode)
      calc();
    }

    document.querySelectorAll<HTMLButtonElement>('.mode-switch').forEach((btn) => {
      btn.addEventListener('click', () => {
        const newMode = btn.dataset.modeBtn as 'quick' | 'detailed';
        setMode(newMode);
      });
    });

    // Pre-fill example values on load + load-example button
    function loadExample() {
      if (mode === 'quick') {
        (document.querySelector('#cost') as HTMLInputElement).value = '7500';
      } else {
        (document.querySelector('#opening') as HTMLInputElement).value = '4200';
        (document.querySelector('#purchases') as HTMLInputElement).value = '6800';
        (document.querySelector('#closing') as HTMLInputElement).value = '3500';
      }
      (document.querySelector('#revenue') as HTMLInputElement).value = '25000';
      calc();
    }

    const loadExBtn = document.querySelector('[data-load-example]');
    if (loadExBtn) {
      loadExBtn.addEventListener('click', loadExample);
    }

    // Auto-fill example on first load so user sees a working result immediately
    loadExample();
  }
</script>

