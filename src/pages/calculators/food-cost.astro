    <hr class="rule" aria-hidden="true" />

    <!-- Visual benchmarks -->
    <section class="benchmarks">
      <h2 class="benchmarks__headline">Benchmarks <em>by concept type</em></h2>
      <p class="t-body-large benchmarks__intro">
        Healthy food cost varies by concept. Use these as a sanity check, not a hard rule, your local market, supplier mix, menu mix, and labor model all shift the target. The shaded saffron band shows the typical healthy range for each.
      </p>
      <div class="benchmarks__chart">
        {benchmarks.map((b) => (
          <div class="bench-bar">
            <div class="bench-bar__name">{b.name}</div>
            <div class="bench-bar__track">
              <div class="bench-bar__zone" style={`left: ${b.low * 2}%; width: ${(b.high - b.low) * 2}%`}></div>
              <div class="bench-bar__tick" style={`left: ${b.low * 2}%`} title={`${b.low}%`}></div>
