    cursor: pointer;
    transition: all var(--transition-fast);
    border-bottom: 1px dashed var(--color-saffron-text);
  }

  .mode-switch:hover {
    color: var(--color-heading);
    border-bottom-color: var(--color-heading);
  }

  .mode-switch--hidden { display: none; }

  /* ===== FORM ===== */
  .calc-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-7);
    box-shadow: var(--shadow-warm);
  }

  .form-group { display: flex; flex-direction: column; gap: var(--space-5); }

  .form-group--hidden { display: none; }

  .form-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .form-row__label {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-heading);
  }

  .input-shell {
    display: flex;
    align-items: center;
    background: var(--color-canvas);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
    overflow: hidden;
  }

  .input-shell:focus-within {
    border-color: var(--color-saffron);
    box-shadow: 0 0 0 3px var(--alpha-saffron-focus);
    background: var(--color-white);
  }

  .input-shell__prefix,
  .input-shell__suffix {
    padding: 0 var(--space-4);
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--color-muted);
    flex-shrink: 0;
  }

  .input-shell__prefix { padding-right: 0; }
  .input-shell__suffix { padding-left: 0; }

  .input-shell input {
    flex: 1;
    border: none;
    background: transparent;
    padding: 14px 16px;
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--color-heading);
    outline: none;
    width: 100%;
  }

  .calc-form select {
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 12px 14px;
    background: var(--color-canvas);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-heading);
    cursor: pointer;
    appearance: none;
    background-image: url("data:image/svg+xml;charset=utf-8,%3Csvg xmlns='http://www.w3.org/2000/svg' width='10' height='6' viewBox='0 0 10 6'%3E%3Cpath d='M1 1l4 4 4-4' stroke='%237a7569' stroke-width='1.5' fill='none' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 14px center;
    padding-right: 36px;
  }

  .calc-form select:focus {
    outline: none;
    border-color: var(--color-saffron);
    box-shadow: 0 0 0 3px var(--alpha-saffron-focus);
  }

  .form-row__hint {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: var(--color-muted);
    line-height: 1.40;
  }



  /* Optional fields collapse */
  .optional-fields {
    background: var(--color-cream);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .optional-fields__trigger {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    cursor: pointer;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-heading);
    list-style: none;
  }

  .optional-fields__trigger::-webkit-details-marker { display: none; }

  .optional-fields__icon {
    font-family: var(--font-mono);
    color: var(--color-saffron-text);
    transition: transform var(--transition-fast);
  }

  .optional-fields[open] .optional-fields__icon { transform: rotate(45deg); }

  .optional-fields__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-4);
    border-top: 1px dashed var(--color-border);
  }

  /* ===== RESULT ===== */
  .calc-result {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    position: sticky;
    top: 120px;
  }

  @media (max-width: 880px) {
    .calc-result { position: static; }
  }

  .calc-result__card {
    background: var(--gradient-card-warm);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-10) var(--space-8);
    box-shadow: 0 1px 2px var(--alpha-shadow-2), 0 12px 32px var(--alpha-shadow-1), 0 40px 80px -40px var(--alpha-saffron-glow-strong);
    position: relative;
    overflow: hidden;
  }
  .calc-result__card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, transparent, var(--color-saffron) 50%, transparent);
    opacity: 0.7;
    pointer-events: none;
  }
  .calc-result__card::after {
    content: '';
    position: absolute;
    top: -140px;
    right: -140px;
    width: 280px;
    height: 280px;
    background: radial-gradient(circle, var(--alpha-saffron-glow-strong) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }
  .calc-result__card > * { position: relative; z-index: 1; }

  .calc-result__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-5);
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .calc-result__big {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 4px;
    margin-bottom: var(--space-5);
  }

  .calc-result__big .result-num {
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
    font-feature-settings: "tnum";
    font-size: clamp(4rem, 11vw + 0.5rem, 7.5rem);
    font-weight: 400;
    line-height: 0.92;
    letter-spacing: -0.04em;
    color: var(--color-saffron-text);
    transition: transform 320ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .calc-result__big .result-num--pulse { transform: scale(1.025); }

  .calc-result__big .result-num__pct {
    font-family: var(--font-mono);
    font-size: clamp(2rem, 5.5vw + 0.5rem, 3.75rem);
    color: var(--color-saffron-text);
    font-weight: 400;
  }

  .calc-result__benchmark {
    display: flex;
    justify-content: space-between;
    padding: var(--space-3) 0;
    border-top: 1px dashed var(--color-border);
    border-bottom: 1px dashed var(--color-border);
    margin-bottom: var(--space-5);
  }

  .calc-result__bar {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-5);
  }

  .bar-track {
    position: relative;
    height: 8px;
    background: var(--color-cream);
    border-radius: 999px;
  }

  .bar-zone {
    position: absolute;
    top: 0;
    bottom: 0;
    border-radius: 999px;
  }

  .bar-zone--lean { left: 0%; width: 56%; background: rgba(74, 88, 38, 0.18); }
  .bar-zone--good { left: 56%; width: 8%; background: rgba(74, 88, 38, 0.40); }
  .bar-zone--watch { left: 64%; width: 6%; background: rgba(200, 117, 0, 0.32); }
  .bar-zone--bad { left: 70%; width: 30%; background: rgba(156, 79, 28, 0.28); }

  .bar-marker {
    position: absolute;
    top: -4px;
    width: 16px;
    height: 16px;
    background: var(--color-saffron);
    border: 3px solid var(--color-white);
    border-radius: 50%;
    box-shadow: 0 1px 6px var(--alpha-shadow-deep);
    transform: translateX(-50%);
    transition: left var(--transition-med);
  }

  .bar-labels { display: flex; justify-content: space-between; }

  /* Status pill variants */
  .status-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 11px;
    border-radius: 999px;
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .status-pill__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }

  .status-pill[data-status="empty"] {
    background: rgba(122, 117, 105, 0.10);
    color: var(--color-muted);
  }
  .status-pill[data-status="empty"] .status-pill__dot {
    background: var(--color-muted);
    box-shadow: 0 0 0 3px rgba(122, 117, 105, 0.18);
  }
  .status-pill[data-status="lean"],
  .status-pill[data-status="healthy"] {
    background: var(--alpha-success-tint);
    color: var(--color-result-success);
  }
  .status-pill[data-status="lean"] .status-pill__dot,
  .status-pill[data-status="healthy"] .status-pill__dot {
    background: var(--color-result-success);
    box-shadow: 0 0 0 3px var(--alpha-success-ring);
  }
  .status-pill[data-status="watch"] {
    background: rgba(200, 117, 0, 0.12);
    color: var(--color-saffron-text);
  }
  .status-pill[data-status="watch"] .status-pill__dot {
    background: var(--color-saffron);
    box-shadow: 0 0 0 3px rgba(200, 117, 0, 0.20);
  }
  .status-pill[data-status="critical"] {
    background: rgba(156, 79, 28, 0.14);
    color: #823a14;
  }
  .status-pill[data-status="critical"] .status-pill__dot {
    background: #9c4f1c;
    box-shadow: 0 0 0 3px rgba(156, 79, 28, 0.22);
  }

  /* Detailed-mode extras, [hidden] must beat display:flex */
  .calc-result__extras {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .calc-result__extras[hidden] { display: none; }

  .extras-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 6px 0;
    font-family: var(--font-body);
    font-size: 0.875rem;
  }

  .extras-row[hidden] { display: none; }

  .extras-row__label { color: var(--color-body); }
  .extras-row__value { font-weight: 500; color: var(--color-heading); }
  .extras-row__value.is-good { color: var(--color-result-success); }
  .extras-row__value.is-lean { color: var(--color-result-success); }
  .extras-row__value.is-watch { color: var(--color-saffron-text); }
  .extras-row__value.is-bad { color: #823a14; }

  /* ===== SHOW MATH ===== */
  .show-math {
    background: var(--color-cream);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .show-math__trigger {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-5);
    cursor: pointer;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-heading);
    list-style: none;
    transition: background var(--transition-fast);
  }

  .show-math__trigger::-webkit-details-marker { display: none; }
  .show-math__trigger:hover { background: var(--color-border-soft); }

  .show-math__icon {
    font-family: var(--font-mono);
    font-size: 1.125rem;
    color: var(--color-saffron-text);
    transition: transform var(--transition-fast);
    width: 16px;
    text-align: center;
  }

  .show-math[open] .show-math__icon { transform: rotate(45deg); }

  .show-math__body { padding: var(--space-3) var(--space-5) var(--space-5); }

  .math-table { width: 100%; border-collapse: collapse; font-size: 0.9375rem; }
  .math-table td { padding: 10px 6px; border-bottom: 1px dashed var(--color-border); vertical-align: middle; line-height: 1.45; }
  .math-table td:first-child { color: var(--color-body); padding-left: 0; }
  .math-table td:last-child { text-align: right; color: var(--color-heading); padding-right: 0; white-space: nowrap; font-family: var(--font-mono); font-variant-numeric: tabular-nums; }
  .math-table__step td:first-child { padding-left: var(--space-4); color: var(--color-muted); font-size: 0.875rem; }
  .math-table__step td:last-child { color: var(--color-saffron-text); font-weight: 500; }
  .math-table__final td { padding-top: 14px; padding-bottom: 6px; border-bottom: none; border-top: 1.5px solid var(--color-heading); }
  .math-table__final td:last-child { font-size: 1.0625rem; }
  .math-table__final td strong { color: var(--color-saffron-text); }
  @media (max-width: 540px) { .math-table { font-size: 0.875rem; } .math-table td { padding: 8px 4px; } }

  .math-note {
    margin-top: var(--space-4);
    padding-top: var(--space-3);
    border-top: 1px dashed var(--color-border);
    color: var(--color-body);
    line-height: 1.5;
  }

  /* ===== ESSAY ===== */
  .essay,
  .operator-story {
    margin: var(--space-16) auto;
    max-width: 720px;
  }

  .essay__eyebrow { margin-bottom: var(--space-4); }

  .essay__headline {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 96, "wdth" 95;
    font-size: clamp(2rem, 4vw + 0.5rem, 3rem);
    font-weight: 500;
    line-height: 1.10;
    letter-spacing: -0.018em;
    color: var(--color-heading);
    margin-bottom: var(--space-8);
  }

  .essay__headline em {
    font-style: italic;
    font-weight: 500;
    color: var(--color-saffron-text);
  }

  .essay__body p {
    font-family: var(--font-body);
    font-size: 1.125rem;
    line-height: 1.65;
    color: var(--color-body);
    margin-bottom: var(--space-5);
  }

  .essay__pull {
    position: relative;
    font-family: var(--font-display);
    font-variation-settings: "opsz" 96, "wdth" 95;
    font-size: clamp(1.625rem, 3.2vw + 0.5rem, 2.5rem) !important;
    font-weight: 500;
    line-height: 1.18 !important;
    letter-spacing: -0.018em;
    color: var(--color-heading) !important;
    padding: var(--space-8) var(--space-2) var(--space-8) var(--space-10) !important;
    margin: var(--space-10) 0 !important;
    border-left: 4px solid var(--color-saffron);
    background: linear-gradient(90deg, var(--alpha-saffron-tint), transparent 80%);
  }
  .essay__pull::before {
    content: '\201C';
    position: absolute;
    left: 8px;
    top: -8px;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 5rem;
    line-height: 1;
    color: var(--color-saffron);
    opacity: 0.40;
    pointer-events: none;
  }

  .rule {
    border: none;
    height: 1px;
    background: var(--color-border);
    margin: var(--space-12) 0;
  }

  /* ===== BENCHMARKS ===== */
  .benchmarks {
    margin-bottom: var(--space-16);
    max-width: 880px;
  }

  .benchmarks__headline {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 60, "wdth" 100;
    font-size: clamp(1.75rem, 3vw + 0.5rem, 2.5rem);
    font-weight: 500;
    line-height: 1.20;
    letter-spacing: -0.012em;
    color: var(--color-heading);
    margin-bottom: var(--space-3);
  }

  .benchmarks__headline em {
    font-style: italic;
    font-weight: 500;
    color: var(--color-muted);
  }

  .benchmarks__intro {
    max-width: 64ch;
    margin-bottom: var(--space-8);
  }

  .benchmarks__chart {
    display: flex;
    flex-direction: column;
    gap: 0;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }

  .bench-bar {
    display: grid;
    grid-template-columns: 220px 1fr 90px;
    gap: var(--space-5);
    align-items: center;
    padding: var(--space-3) 0;
    border-bottom: 1px dashed var(--color-border);
  }

  .bench-bar:last-of-type { border-bottom: none; }

  @media (max-width: 640px) {
    .bench-bar {
      grid-template-columns: 1fr 80px;
      grid-template-rows: auto auto;
      gap: var(--space-2);
    }
    .bench-bar__name { grid-column: 1 / -1; }
    .bench-bar__track { grid-column: 1 / 2; }
    .bench-bar__range { grid-column: 2 / 3; align-self: center; }
  }

  .bench-bar__name {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-heading);
  }

  .bench-bar__track {
    position: relative;
    height: 6px;
    background: var(--color-cream);
    border-radius: 999px;
  }

  .bench-bar__zone {
    position: absolute;
    top: 0;
    bottom: 0;
    background: var(--color-saffron);
    border-radius: 999px;
    opacity: 0.55;
  }

  .bench-bar__tick {
    position: absolute;
    top: -3px;
    width: 2px;
    height: 12px;
    background: var(--color-saffron);
    transform: translateX(-50%);
  }

  .bench-bar__range {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-saffron-text);
    text-align: right;
  }

  .bench-axis {
    display: grid;
    grid-template-columns: 220px 1fr 90px;
    gap: var(--space-5);
    align-items: center;
    padding-top: var(--space-3);
    margin-top: var(--space-2);
    border-top: 1px solid var(--color-border);
  }

  .bench-axis__track {
    grid-column: 2;
    position: relative;
    height: 14px;
  }

  .bench-axis__tick {
    position: absolute;
    top: 0;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-muted);
  }

  @media (max-width: 640px) {
    .bench-axis { display: none; }
  }

  /* ===== AD WRAP ===== */
  .ad-wrap {
    margin: var(--space-12) 0;
    padding: 0;
  }

  .ad-inline {
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-cream);
    overflow: hidden;
  }

  .ad-inline__label {
    display: block;
    padding: 6px 12px;
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-muted);
    background: rgba(122, 117, 105, 0.06);
    border-bottom: 1px dashed var(--color-border);
  }

  .ad-inline__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: var(--space-6);
    min-height: 280px;
  }

  /* ===== SCENARIOS ===== */
  .scenarios {
    margin-bottom: var(--space-16);
  }

  .scenarios__headline {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 72, "wdth" 100;
    font-size: clamp(1.75rem, 3vw + 0.5rem, 2.5rem);
    font-weight: 500;
    line-height: 1.15;
    letter-spacing: -0.012em;
    color: var(--color-heading);
    margin: var(--space-3) 0 var(--space-4);
  }

  .scenarios__intro {
    max-width: 64ch;
    margin-bottom: var(--space-8);
  }

  .scenarios__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }

  @media (max-width: 880px) {
    .scenarios__grid { grid-template-columns: 1fr; }
  }

  .scenario-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-7);
    box-shadow: var(--shadow-warm);
    position: relative;
  }

  .scenario-card__num {
    position: absolute;
    top: var(--space-5);
    right: var(--space-5);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-saffron-text);
  }

  .scenario-card__title {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 36, "wdth" 100;
    font-size: 1.25rem;
    font-weight: 500;
    line-height: 1.25;
    color: var(--color-heading);
    margin-bottom: var(--space-2);
    padding-right: var(--space-8);
  }

  .scenario-card__setup {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-body);
    margin-bottom: var(--space-2);
  }

  .scenario-card__row {
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: var(--space-3) 0;
    border-top: 1px dashed var(--color-border);
  }

  .scenario-card__row--outcome {
    border-top: 1px solid var(--color-saffron);
    padding-top: var(--space-4);
    margin-top: var(--space-2);
  }

  .scenario-card__label {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-saffron-text);
  }

  .scenario-card__text {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-body);
  }

  /* ===== FAQ ===== */
