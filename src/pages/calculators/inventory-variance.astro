---
import Layout from '../../layouts/Layout.astro';

const title = 'Inventory Variance Calculator, Free | RestaurantCalcs';
const description = 'Spot the gap between theoretical and actual food cost. Catch waste, over-portions, theft, counting errors. Sign-aware status + annualized leak.';

const faq = [
  {
    q: 'What is inventory variance?',
    a: 'Inventory variance is the difference between what your costs SHOULD have been (theoretical, based on recipes and items sold) and what they ACTUALLY were (real inventory consumed). Variance flags waste, over-portioning, theft, comping, and counting errors. Best operators target variance under 1%. Above 3% means real money is leaking.',
  },
  {
    q: 'How do you calculate inventory variance?',
    a: 'Variance % = Actual Cost % − Theoretical Cost %. Variance $ = Actual Cost − Theoretical Cost. Theoretical comes from your POS multiplied by recipe costs. Actual comes from inventory math: Opening + Purchases − Closing. The gap between them is variance.',
  },
  {
    q: 'What is a good variance?',
    a: 'Best-in-class operators target under 1% variance. 1–3% is acceptable in normal operations. 3–5% needs investigation. Above 5% is a red flag for theft, severe over-portioning, or systematic comping. Sustained variance above 8% usually means inventory counts are unreliable or POS recipe costs are outdated.',
  },
  {
    q: 'What causes high variance?',
    a: 'Ranked by frequency: (1) over-portioning, line cooks plating heavy, (2) waste, spoilage, trim, prep errors not tracked, (3) employee meals not rung in, (4) comps not tracked in POS, (5) theft, bartender pouring extra, line cook taking food home, (6) inventory counting errors, (7) outdated recipe costs in POS, (8) supplier short-shipping without invoice adjustment.',
  },
  {
    q: 'How do I lower variance?',
    a: 'Start with measurement: install scales on the line, train portion specs, log waste daily. Then process: track comps + employee meals through POS, recount inventory weekly not monthly. Then accountability: review variance with the team weekly, tie to bonus structure if appropriate. Best operators get to under 1% within 90 days of starting the discipline.',
  },
  {
    q: 'Is variance the same as shrinkage?',
    a: 'Closely related. Shrinkage is the dollar value of inventory lost to waste, theft, or counting error. Variance is the percentage measure. Both describe the same gap. "We had $1,200 in shrinkage" = "We had 2.4% variance on $50K food sales."',
  },
  {
    q: 'Should I track variance by category?',
    a: 'Yes, at minimum split protein, produce, dairy, and dry goods. Protein is usually the largest variance contributor (highest cost per unit, easiest to over-portion or steal). Tracking by category tells you where to focus. A 3% blended variance might be 1% on dry goods and 6% on protein.',
  },
  {
    q: 'How often should I run variance?',
    a: 'Weekly. Monthly hides too much, daily is too noisy. Weekly catches drift early enough to fix the next week. The discipline of physical inventory every Sunday at close is the foundation, without that, theoretical numbers don\'t mean anything.',
  },
  {
    q: 'Does this calculator save my data?',
    a: 'No. Nothing is stored, transmitted, or tracked. The calculation runs entirely in your browser and disappears the moment you close the tab. No signup, no email, no account.',
  },
];

const schema = [
  { '@context': 'https://schema.org', '@type': 'WebPage', '@id': 'https://restaurantcalcs.com/calculators/inventory-variance/#webpage', url: 'https://restaurantcalcs.com/calculators/inventory-variance/', name: title, description, isPartOf: { '@id': 'https://restaurantcalcs.com/#website' }, breadcrumb: { '@id': 'https://restaurantcalcs.com/calculators/inventory-variance/#breadcrumb' }, inLanguage: 'en-US' },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', '@id': 'https://restaurantcalcs.com/calculators/inventory-variance/#breadcrumb', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://restaurantcalcs.com/' },
    { '@type': 'ListItem', position: 2, name: 'Calculators', item: 'https://restaurantcalcs.com/' },
    { '@type': 'ListItem', position: 3, name: 'Inventory Variance', item: 'https://restaurantcalcs.com/calculators/inventory-variance/' },
  ] },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    '@id': 'https://restaurantcalcs.com/calculators/inventory-variance/#tool',
    name: 'Inventory Variance Calculator',
    description: 'Free web-based inventory variance calculator. Compare theoretical to actual food cost. Spot waste, theft, over-portioning. Sign-aware status with industry benchmarks.',
    applicationCategory: 'BusinessApplication',
    applicationSubCategory: 'Restaurant Management',
    operatingSystem: 'Web',
    browserRequirements: 'Requires JavaScript',
    url: 'https://restaurantcalcs.com/calculators/inventory-variance/',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    creator: { '@id': 'https://restaurantcalcs.com/#organization' },
    author: { '@id': 'https://restaurantcalcs.com/#founder' },
    isAccessibleForFree: true,
  },
  { '@context': 'https://schema.org', '@type': 'HowTo', name: 'How to calculate inventory variance', totalTime: 'PT5M', supply: [
    { '@type': 'HowToSupply', name: 'Theoretical food cost (in dollars)' },
    { '@type': 'HowToSupply', name: 'Actual food cost from inventory (in dollars)' },
    { '@type': 'HowToSupply', name: 'Total food sales (in dollars)' },
  ], step: [
    { '@type': 'HowToStep', position: 1, name: 'Calculate theoretical cost', text: 'Run a usage report from your POS multiplied by recipe costs. This is what you should have used.' },
    { '@type': 'HowToStep', position: 2, name: 'Calculate actual cost', text: 'Use inventory math: Opening + Purchases − Closing = Actual COGS. This is what you really used.' },
    { '@type': 'HowToStep', position: 3, name: 'Calculate variance', text: 'Variance $ = Actual − Theoretical. Variance % = (Actual − Theoretical) ÷ Sales × 100. Best operators target <1%.' },
    { '@type': 'HowToStep', position: 4, name: 'Investigate', text: 'Variance under 1% maintain. 1–3% acceptable. 3–5% investigate. Above 5% audit immediately for theft, comping, or over-portioning.' },
  ] },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
];

const scenarios = [
  {
    title: 'The 7% protein variance',
    setup: 'Steakhouse, blended variance 4%. Owner thought it was acceptable. Then split by category: protein variance 7%, dry goods 1%.',
    diagnosis: 'Investigation revealed line cook trimming steaks heavy, taking trim home in cooler bag. Plus over-portioning ribeyes (10oz vs spec 8oz) on owner-comp meals.',
    fix: 'Locked walk-in after close, installed scale on grill station, audited every comped meal weekly with management.',
    outcome: 'Protein variance to 1.5% in 6 weeks. $4,800/month margin recovered. Cook left voluntarily after lockdown.',
  },
  {
    title: 'The 9% bar variance',
    setup: 'Cocktail bar, beverage variance 9%. Manager blamed inflation.',
    diagnosis: 'Variance audit: top 3 spirits accounted for 70% of the gap. Bartender free-pouring, comping shift drinks not in POS. Theoretical was 19%, actual 28%.',
    fix: 'Installed measured pour spouts, mandated POS ring-in for every shift drink, reviewed top 5 spirits weekly with bartenders.',
    outcome: 'Variance to 2% in 8 weeks. Two bartenders left after the discipline arrived. Replacements onboarded clean from day one.',
  },
  {
    title: 'The 0.4% star',
    setup: 'Family-owned casual diner, 30 years operating. Owner ran weekly variance. Average 0.4%.',
    diagnosis: 'Not luck, habit. Sunday close: physical count. Monday morning: theoretical from POS. Tuesday: variance review with kitchen team. Every week, every year, three decades.',
    fix: 'No fix needed. Documented the practice as case study for newer operators.',
    outcome: 'Restaurant operates at 26% food cost where competitors run 32%. Six points of margin = ~$120K/year on their volume. Pure discipline, zero technology.',
  },
];

const relatedCalcs = [
  { slug: 'food-cost', title: 'Food Cost Percentage', desc: 'The denominator, actual cost.' },
  { slug: 'recipe-cost', title: 'Recipe & Plate Cost', desc: 'Build theoretical from recipes.' },
  { slug: 'keg-cost', title: 'Draft Beer / Keg Cost', desc: 'Find draft variance per keg.' },
];
---

<Layout {title} {description} {schema}>
  <article class="calc-page">
    <header class="calc-page__header">
      <nav class="breadcrumb" aria-label="Breadcrumb"><a href="/">Home</a><span aria-hidden="true">/</span><span>Inventory Variance Calculator</span></nav>
      <p class="t-micro t-micro--saffron calc-page__eyebrow">Inventory variance calculator · <strong>100% free · no signup</strong></p>
      <h1 class="calc-page__title">Inventory Variance Calculator</h1>
      <p class="calc-page__intro">
        Compare what costs <strong>should have been</strong> (theoretical, from recipes) to what they <strong>actually were</strong> (from inventory). The gap is where waste, theft, and over-portioning live. Best operators run under 1%.
      </p>
    </header>

    <section class="calc-grid">
      <form class="calc-form" data-form>
        <div class="form-intro">
          <p class="form-intro__what"><strong>What this does:</strong> Compares what your food should have cost (the recipe number from your POS) to what it actually cost (from counting your inventory). The gap is where waste, free meals, and theft hide. The best run under 1%.</p>
          <button type="button" class="form-intro__example" data-load-example>Try with example numbers</button>
        </div>

        <div class="form-row">
          <label class="form-row__label" for="theoretical">What the food should have cost (the recipe number)</label>
          <div class="input-shell">
            <span class="input-shell__prefix">$</span>
            <input id="theoretical" name="theoretical" type="number" inputmode="decimal" min="0" step="0.01" placeholder="7000" autocomplete="off" required />
          </div>
          <p class="form-row__hint">Your POS knows how many of each item sold. Multiply that by what each recipe costs to make. This is what the food should have cost if every plate was made exactly to recipe.</p>
        </div>

        <div class="form-row">
          <label class="form-row__label" for="actual">What the food actually cost</label>
          <div class="input-shell">
            <span class="input-shell__prefix">$</span>
            <input id="actual" name="actual" type="number" inputmode="decimal" min="0" step="0.01" placeholder="7500" autocomplete="off" required />
          </div>
          <p class="form-row__hint">From counting your inventory: food you had at the start, plus what you bought, minus food you had left at the end. This is what the food really cost.</p>
        </div>

        <div class="form-row">
          <label class="form-row__label" for="revenue">How much you sold in food (dollars)</label>
          <div class="input-shell">
            <span class="input-shell__prefix">$</span>
            <input id="revenue" name="revenue" type="number" inputmode="decimal" min="0" step="0.01" placeholder="25000" autocomplete="off" required />
          </div>
          <p class="form-row__hint">Total food sales for the same stretch of time. Pull it from your POS.</p>
        </div>

        <div class="form-row">
          <label class="form-row__label" for="period">Period (for reference)</label>
          <select id="period" name="period">
            <option value="week" selected>Weekly</option>
            <option value="month">Monthly</option>
            <option value="quarter">Quarterly</option>
          </select>
        </div>

        <p class="calc-form__live">
          <span class="calc-form__live-dot" aria-hidden="true"></span>
          Updates live as you type. <strong>Nothing is saved or sent</strong>, the math runs in your browser.
        </p>
      </form>

      <aside class="calc-result">
        <div class="calc-result__card" aria-live="polite" aria-atomic="true">
          <div class="calc-result__head">
            <span class="t-micro calc-result__label">The gap (variance)</span>
            <span class="status-pill" data-status="empty">
              <span class="status-pill__dot"></span><span data-status-label>Enter values</span>
            </span>
          </div>

          <div class="calc-result__big">
            <span class="result-num" data-counter>0.0</span>
            <span class="result-num__pct" aria-hidden="true">%</span>
          </div>

          <div class="calc-result__benchmark">
            <span class="t-caption">Best-in-class</span>
            <span class="t-caption num">&lt; 1%</span>
          </div>

          <div class="calc-result__bar">
            <div class="bar-track">
              <div class="bar-zone bar-zone--good" style="left: 0%; width: 20%"></div>
              <div class="bar-zone bar-zone--watch" style="left: 20%; width: 40%"></div>
              <div class="bar-zone bar-zone--bad" style="left: 60%; width: 40%"></div>
              <div class="bar-marker" data-marker style="left: 0%"></div>
            </div>
            <div class="bar-labels">
              <span class="t-caption num">0%</span>
              <span class="t-caption num">5%</span>
              <span class="t-caption num">10%</span>
            </div>
          </div>

          <div class="calc-result__extras">
            <div class="extras-row">
              <span class="extras-row__label">What it should have cost (% of sales)</span>
              <span class="extras-row__value num" data-theoretical-pct></span>
            </div>
            <div class="extras-row">
              <span class="extras-row__label">What it actually cost (% of sales)</span>
              <span class="extras-row__value num" data-actual-pct></span>
            </div>
            <div class="extras-row">
              <span class="extras-row__label">Money leaking this period</span>
              <span class="extras-row__value num" data-leak></span>
            </div>
            <div class="extras-row">
              <span class="extras-row__label">What that adds up to in a year</span>
              <span class="extras-row__value num" data-annual></span>
            </div>
          </div>

          <button type="button" class="result-share" data-share-open aria-haspopup="dialog">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><path d="M8.6 13.5l6.8 4M15.4 6.5l-6.8 4"/></svg>
            Share these numbers
          </button>
        </div>

        <details class="show-math" data-math-wrap>
          <summary class="show-math__trigger">
            <span class="show-math__icon" aria-hidden="true">+</span>
            Show your math
          </summary>
          <div class="show-math__body" data-math>
            <p class="t-caption">Enter values above to see the calculation.</p>
          </div>
        </details>
      </aside>
    </section>

    <section class="essay">
      <p class="essay__eyebrow t-micro t-micro--saffron">Why this matters</p>
      <h2 class="essay__headline">Variance is where the <em>actual money</em> is.</h2>
      <div class="essay__body">
        <p>
          Food cost percentage tells you the symptom. Variance tells you the cause. Two operators can have identical 32% food cost, one through perfect execution at a 32% theoretical target, the other through 28% theoretical plus 4% leak.
        </p>
        <p>
          Same number, completely different businesses. The first is operating at design efficiency. The second is bleeding $X,XXX a month and doesn't know it.
        </p>
        <p class="essay__pull">
          Operators who measure variance see the leak. Operators who measure only food cost % react to a number that has no actionable cause. The variance discipline is what separates well-run kitchens from lucky ones.
        </p>
        <p>
          Three habits build it: weekly physical inventory at close, POS recipe costs kept current, daily waste log. None require software. All require consistency. Once those three exist, variance falls below 1% within 90 days at most concepts.
        </p>
      </div>
    </section>

    <hr class="rule" aria-hidden="true" />

    <!-- Operator story: Cosmos bar variance -->
    <section class="operator-story">
      <img src="/illustrations/inventory-variance.webp" alt="Editorial illustration of a clipboard with handwritten count tally marks held in front of stainless steel walk-in cooler shelves stocked with restaurant supplies." class="operator-story__hero" width="1264" height="848" loading="lazy" />
      <p class="essay__eyebrow t-micro t-micro--saffron">From the inventory sheet</p>
      <h2 class="essay__headline">Variance tells you <em>something is wrong</em>. It doesn't tell you what.</h2>
      <div class="essay__body">
        <p>
          Bar inventory variance is the metric most operators learn the hard way. I learned it the hard way at Cosmos. We were running a healthy beverage program on paper. Sales were strong. Margins looked fine. Then I did a real bottle count for the first time in months, lined it up against the POS report, and found a gap I couldn't explain.
        </p>
        <p>
          Variance isn't theft. Sometimes it's theft. More often it's three or four things at once, over-pours, comps not rung in, broken bottles nobody logged, a vendor short-shipping a case and the back-of-house signing for it without checking. Each one alone is small. Together they look exactly like a bartender skimming.
        </p>
        <p>
          The first count was the worst. The second was easier. By the third weekly count, we'd built the discipline of <em>looking for the gap</em> instead of being shocked by it. That's the only thing that matters with variance, not finding zero gap, finding the gap before it gets big.
        </p>
        <p class="essay__pull">
          Best-in-class bar programs run under 1% variance. Most indie bars I've seen don't measure it at all. The gap between those two numbers is the entire moat.
        </p>
        <p>
          The lesson I'd give my younger bartender self: count weekly, not monthly. Count by category, spirits, beer, wine, separately, not as a blob. And when the number jumps, don't assume theft first. Walk through the operational stuff in order: comp records, broken-glass log, recipe specs, inventory miscount. Theft is real, but it's the last suspect, not the first. Treating every variance spike as theft poisons team trust faster than the variance itself ever costs you.
        </p>
        <p>
          I knew an operator in Florida, Joe, who runs Manolos, a hundred-year-old building that's somehow still standing through every recession. Joe was the opposite of every operator I'd seen up to that point. Nothing got wasted. Nothing got eaten by staff. No leftover plates went out as comps. If a server broke a dish, it came out of their tip-out that night. Every ounce was tracked. Every portion was weighed. Every comp was rung. The math was airtight.
        </p>
        <p>
          Manolos is still open. Joe was right about every line item. And the staff hated working there. Servers turned over every six months. The cooks called him names behind his back. Customers loved the food but felt the tension in the room. The math was clean, and the team was bleeding the whole time. That's the other half of the discipline conversation that nobody puts on paper: variance discipline without team trust is its own slow leak. Different category. Same closure if it goes on long enough.
        </p>
        <p class="essay__pull">
          Felix at Flaco's gave the business away and closed. Joe at Manolos counted every grain of rice and burned out his team. The middle path, count weekly, treat your people like adults, run the investigation in the right order, is the only one that lasts.
        </p>
        <p>
          This calculator gives you the variance number plus the dollar leak annualized. The number is your starting line. The investigation is yours. Run it weekly, and the calculator becomes a habit instead of an emergency. Run it without the human side, and the math will be perfect right up until your last server quits.
        </p>
        <div class="operator-byline">
          <span class="operator-byline__dash">Signed</span>
          <span class="operator-byline__name">Brock Markarian</span>
          <span class="operator-byline__role">Founder · 5 yrs at Cosmos Taverna (Bartender → GM)</span>
        </div>
      </div>
    </section>

    <hr class="rule" aria-hidden="true" />

    <div class="container ad-wrap">
      <aside class="ad-inline">
        <span class="ad-inline__label">Advertisement</span>
        <div class="ad-inline__inner">
          <ins class="adsbygoogle"
               style="display:block"
               data-ad-client="ca-pub-6332696231897305"
               data-ad-slot="0000000000"
               data-ad-format="auto"
               data-full-width-responsive="true"
               data-adtest="on"></ins>
          <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
        </div>
      </aside>
    </div>

    <section class="scenarios">
      <p class="t-micro t-micro--saffron">Real scenarios</p>
      <h2 class="scenarios__headline">Three variance stories</h2>
      <p class="t-body-large scenarios__intro">
        High variance hides real money. Track it, find it, fix it.
      </p>
      <div class="scenarios__grid">
        {scenarios.map((s, i) => (
          <article class="scenario-card">
            <span class="scenario-card__num num">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="scenario-card__title">{s.title}</h3>
            <p class="scenario-card__setup">{s.setup}</p>
            <div class="scenario-card__row"><span class="scenario-card__label">Diagnosis</span><p class="scenario-card__text">{s.diagnosis}</p></div>
            <div class="scenario-card__row"><span class="scenario-card__label">Fix</span><p class="scenario-card__text">{s.fix}</p></div>
            <div class="scenario-card__row scenario-card__row--outcome"><span class="scenario-card__label">Outcome</span><p class="scenario-card__text"><strong>{s.outcome}</strong></p></div>
          </article>
        ))}
      </div>
    </section>

    <hr class="rule" aria-hidden="true" />

    <section class="calc-faq">
      <p class="t-micro t-micro--saffron">FAQ</p>
      <h2 class="calc-faq__headline">Common questions</h2>
      {faq.map((f, i) => (
        <details class="calc-faq__item">
          <summary class="calc-faq__q">
            <span class="calc-faq__num">{String(i + 1).padStart(2, '0')}</span>
            <span class="calc-faq__qtext">{f.q}</span>
            <span class="calc-faq__plus" aria-hidden="true">+</span>
          </summary>
          <p class="calc-faq__a">{f.a}</p>
        </details>
      ))}
    </section>

    <section class="cited-sources">
      <p class="t-micro t-micro--saffron">Cited sources</p>
      <ul>
        <li><a href="https://www.marginedge.com/" target="_blank" rel="noopener">MarginEdge, Theoretical vs Actual Food Cost</a></li>
        <li><a href="https://home.binwise.com/blog/inventory-variance" target="_blank" rel="noopener">BinWise, Inventory Variance Guide</a></li>
        <li><a href="https://www.restaurant365.com/blog/" target="_blank" rel="noopener">Restaurant365, Inventory & Variance Best Practices</a></li>
        <li><a href="https://pos.toasttab.com/blog/on-the-line/restaurant-inventory-management" target="_blank" rel="noopener">Toast, Restaurant Inventory Management</a></li>
      </ul>
    </section>

    <section class="related">
      <h2 class="related__headline">Related calculators</h2>
      <div class="related__grid">
        {relatedCalcs.map((c, i) => (
          <a href={`/calculators/${c.slug}/`} class="related-card">
            <div class="related-card__top">
              <span class="related-card__num num">{String(i + 1).padStart(2, '0')}</span>
              <span class="t-micro"><strong style="color:var(--color-saffron-text)">Free</strong> · 2 min</span>
            </div>
            <h3 class="related-card__title">{c.title}</h3>
            <p class="t-body related-card__desc">{c.desc}</p>
            <span class="related-card__arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </section>
  </article>
</Layout>

<script>
  const form = document.querySelector('[data-form]') as HTMLFormElement | null;
  const counter = document.querySelector('[data-counter]') as HTMLElement | null;
  const marker = document.querySelector('[data-marker]') as HTMLElement | null;
  const statusPill = document.querySelector('.status-pill') as HTMLElement | null;
  const statusLabel = document.querySelector('[data-status-label]') as HTMLElement | null;
  const theoreticalPctEl = document.querySelector('[data-theoretical-pct]') as HTMLElement | null;
  const actualPctEl = document.querySelector('[data-actual-pct]') as HTMLElement | null;
  const leakEl = document.querySelector('[data-leak]') as HTMLElement | null;
  const annualEl = document.querySelector('[data-annual]') as HTMLElement | null;
  const mathBody = document.querySelector('[data-math]') as HTMLElement | null;
  const mathWrap = document.querySelector('[data-math-wrap]') as HTMLDetailsElement | null;

  if (form && counter && marker && statusPill && statusLabel && mathBody) {
    let lastValue = 0;
    let calcDebounce: number | null = null;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function fmtUSD(n: number): string {
      const abs = Math.abs(n);
      const sign = n < 0 ? '−' : '';
      return sign + '$' + abs.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    function fmtUSDInt(n: number): string {
      const abs = Math.abs(n);
      const sign = n < 0 ? '−' : '';
      return sign + '$' + Math.round(abs).toLocaleString('en-US');
    }

    function animateCounter(el: HTMLElement, from: number, to: number, duration = 800, decimals = 1) {
      if (reduced) { el.textContent = to.toFixed(decimals); return; }
      const start = performance.now();
      const ease = (t: number) => 1 - Math.pow(1 - t, 3);
      function frame(now: number) {
        const t = Math.min((now - start) / duration, 1);
        const value = from + (to - from) * ease(t);
        el.textContent = value.toFixed(decimals);
        if (t < 1) requestAnimationFrame(frame);
        else { el.classList.add('result-num--pulse'); setTimeout(() => el.classList.remove('result-num--pulse'), 320); }
      }
      requestAnimationFrame(frame);
    }

    function statusFor(variance: number, sign: number): { key: string; label: string } {
      const abs = Math.abs(variance);
      // Negative variance (actual < theoretical) is a different problem, under-portioning, recipe overstated, miscount.
      // Same threshold magnitudes apply but labels differ.
      if (sign < 0) {
        if (abs < 1) return { key: 'healthy', label: 'Excellent' };
        if (abs < 3) return { key: 'lean', label: 'Under-using' };
        if (abs < 5) return { key: 'watch', label: 'Recipe / count check' };
        return { key: 'critical', label: 'Recipe likely off' };
      }
      if (abs < 1) return { key: 'healthy', label: 'Excellent' };
      if (abs < 3) return { key: 'lean', label: 'Acceptable' };
      if (abs < 5) return { key: 'watch', label: 'Investigate' };
      return { key: 'critical', label: 'Audit now' };
    }

    function calc() {
      const data = new FormData(form!);
      const theoretical = parseFloat(String(data.get('theoretical') || '0')) || 0;
      const actual = parseFloat(String(data.get('actual') || '0')) || 0;
      const revenue = parseFloat(String(data.get('revenue') || '0')) || 0;
      const period = String(data.get('period') || 'week');

      if (theoretical <= 0 || actual <= 0 || revenue <= 0) {
        statusPill!.dataset.status = 'empty';
        statusLabel!.textContent = 'Enter values';
        marker!.style.left = '0%';
        animateCounter(counter!, lastValue, 0, 400, 1);
        lastValue = 0;
        if (theoreticalPctEl) theoreticalPctEl.textContent = ', ';
        if (actualPctEl) actualPctEl.textContent = ', ';
        if (leakEl) leakEl.textContent = ', ';
        if (annualEl) annualEl.textContent = ', ';
        mathBody!.innerHTML = '<p class="t-caption">Enter values above to see the calculation.</p>';
        return;
      }

      const theoreticalPct = (theoretical / revenue) * 100;
      const actualPct = (actual / revenue) * 100;
      const variancePct = actualPct - theoreticalPct;
      const leak = actual - theoretical;

      const periodMultiplier: Record<string, number> = { week: 52, month: 12, quarter: 4 };
      const annual = leak * (periodMultiplier[period] || 12);

      // Marker on 0-10% scale
      const clamped = Math.min(10, Math.max(0, Math.abs(variancePct)));
      const markerPos = (clamped / 10) * 100;

      animateCounter(counter!, Math.abs(lastValue), Math.abs(variancePct), 800, 2);
      lastValue = variancePct;

      const s = statusFor(variancePct, Math.sign(variancePct));
      statusPill!.dataset.status = s.key;
      statusLabel!.textContent = s.label;
      marker!.style.left = `${markerPos}%`;

      if (theoreticalPctEl) theoreticalPctEl.textContent = `${theoreticalPct.toFixed(2)}%`;
      if (actualPctEl) actualPctEl.textContent = `${actualPct.toFixed(2)}%`;
      if (leakEl) leakEl.textContent = leak >= 0 ? `+${fmtUSD(leak)}` : `−${fmtUSD(Math.abs(leak))}`;
      if (annualEl) annualEl.textContent = annual >= 0 ? `+${fmtUSDInt(annual)}/yr` : `−${fmtUSDInt(Math.abs(annual))}/yr`;

      let note = '';
      // Positive variance (actual > theoretical) = waste/theft/over-portion direction
      if (s.label === 'Excellent') note = 'About as tight as it gets. Keep counting your inventory every week and keep portions consistent.';
      if (s.label === 'Acceptable') note = 'Within the normal range. Count weekly so a small gap does not grow. Next step: break the count out by category (proteins, produce, dairy, dry goods) to see which one is leaking.';
      if (s.label === 'Investigate') note = 'Higher than it should be. Look at your biggest-cost items first (usually proteins, dairy, or drinks). Check your free-meal records and your waste log.';
      if (s.label === 'Audit now') note = 'A real leak. Dig in now: theft, portions running too heavy, or free meals not being rung up. Lock the walk-in coolers, put a scale on the line, and check every comp in your POS.';
      // Negative variance (actual < theoretical) = under-portion / recipe overstated / miscount direction
      if (s.label === 'Under-using') note = 'You used less food than the recipes say you should have. Usually that means portions are running light (guests may notice) or your recipe costs are a little out of date. Less urgent than the other direction, but worth a look.';
      if (s.label === 'Recipe / count check') note = 'A real gap in the other direction. Most likely your recipe costs are out of date (ingredient prices have dropped), you miscounted inventory, or portions are running light across the board. Recount and refresh the cost on your top items.';
      if (s.label === 'Recipe likely off') note = 'A big gap in this direction is rare and almost always a data problem: recipe costs that are a year or more out of date, a counting error, or the sales numbers not matching your POS. Double-check your numbers before you change anything in the kitchen.';

      const denominatorNote = `We figure the gap as (actual cost − should-have-cost) ÷ sales = ${variancePct >= 0 ? '+' : '−'}${Math.abs(variancePct).toFixed(2)} points. Some people divide by the should-have-cost instead, which would show ${theoretical > 0 ? `${(((actual - theoretical) / theoretical) * 100).toFixed(2)}%` : ', '} on the same gap. We divide by sales because that is the number you already pull off your POS report.`;

      mathBody!.innerHTML = `
        <table class="math-table" role="presentation">
          <tr><td>What it should have cost</td><td class="num">${fmtUSD(theoretical)}</td></tr>
          <tr><td>What it actually cost</td><td class="num">${fmtUSD(actual)}</td></tr>
          <tr><td>Total food sales</td><td class="num">${fmtUSD(revenue)}</td></tr>
          <tr class="math-table__step"><td>Should-have-cost as % of sales</td><td class="num">${theoreticalPct.toFixed(2)}%</td></tr>
          <tr class="math-table__step"><td>Actual cost as % of sales</td><td class="num">${actualPct.toFixed(2)}%</td></tr>
          <tr class="math-table__final"><td>The gap (variance)</td><td class="num"><strong>${variancePct >= 0 ? '+' : '−'}${Math.abs(variancePct).toFixed(2)}%</strong></td></tr>
        </table>
        <p class="t-caption math-note">
          ${note} Money leaking this ${period}: ${leak >= 0 ? fmtUSD(leak) : `(you are actually saving) ${fmtUSD(Math.abs(leak))}`}. Over a year: ${annual >= 0 ? fmtUSDInt(annual) : `(saving) ${fmtUSDInt(Math.abs(annual))}`}.
        </p>
        <p class="t-caption math-note" style="opacity:0.75;border-top:1px dashed var(--color-border);padding-top:var(--space-2);margin-top:var(--space-2)">
          <strong>How we do the math:</strong> ${denominatorNote}
        </p>
      `;

      if (mathWrap && !mathWrap.open) mathWrap.open = true;
    }

    function debouncedCalc() {
      if (calcDebounce !== null) clearTimeout(calcDebounce);
      calcDebounce = window.setTimeout(calc, 250);
    }

    form.addEventListener('input', debouncedCalc);
    form.addEventListener('change', debouncedCalc);
    form.addEventListener('submit', (e) => { e.preventDefault(); if (calcDebounce !== null) clearTimeout(calcDebounce); calc(); });

    function loadExample() {
      (document.querySelector('#theoretical') as HTMLInputElement).value = '7000';
      (document.querySelector('#actual') as HTMLInputElement).value = '7500';
      (document.querySelector('#revenue') as HTMLInputElement).value = '25000';
      (document.querySelector('#period') as HTMLSelectElement).value = 'week';
      calc();
    }
    const loadExBtn = document.querySelector('[data-load-example]');
    if (loadExBtn) loadExBtn.addEventListener('click', loadExample);
    loadExample();
  }
</script>

