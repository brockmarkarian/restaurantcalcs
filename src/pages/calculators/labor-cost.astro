<script>
  const form = document.querySelector('[data-form]') as HTMLFormElement | null;
  const counter = document.querySelector('[data-counter]') as HTMLElement | null;
  const marker = document.querySelector('[data-marker]') as HTMLElement | null;
  const statusPill = document.querySelector('.status-pill') as HTMLElement | null;
  const statusLabel = document.querySelector('[data-status-label]') as HTMLElement | null;
  const mathBody = document.querySelector('[data-math]') as HTMLElement | null;
  const mathWrap = document.querySelector('[data-math-wrap]') as HTMLDetailsElement | null;
  const extras = document.querySelector('[data-extras]') as HTMLElement | null;
  const cogsEl = document.querySelector('[data-cogs]') as HTMLElement | null;
  const targetRow = document.querySelector('[data-target-row]') as HTMLElement | null;
  const targetVarEl = document.querySelector('[data-target-variance]') as HTMLElement | null;
  const targetMoneyRow = document.querySelector('[data-target-money-row]') as HTMLElement | null;
  const targetMoneyEl = document.querySelector('[data-target-money]') as HTMLElement | null;
  const theoreticalRow = document.querySelector('[data-theoretical-row]') as HTMLElement | null;
  const theoreticalVarEl = document.querySelector('[data-theoretical-variance]') as HTMLElement | null;
  const modeBtns = document.querySelectorAll<HTMLButtonElement>('[data-mode-btn]');

  if (form && counter && marker && statusPill && statusLabel && mathBody) {
    let lastValue = 0;
    let calcDebounce: number | null = null;
    let mode: 'quick' | 'detailed' | 'schedule' = 'quick';
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    type ShiftRow = { id: string; name: string; role: string; hours: number; rate: number };
    let shifts: ShiftRow[] = [];
    let nextId = 1;
    const ROLES = ['Server', 'Bartender', 'Host', 'Busser', 'Runner', 'Line cook', 'Prep cook', 'Dishwasher', 'Manager', 'Other'];
    const OT_THRESHOLD = 40;
    const OT_MULTIPLIER = 0.5; // premium on top of straight time

    function uid() { return 'sh' + nextId++; }

    function renderSchedRows() {
      const wrap = document.querySelector('[data-sched-rows]') as HTMLElement | null;
      if (!wrap) return;
      wrap.innerHTML = shifts.map(s => {
        const isOT = s.hours > OT_THRESHOLD;
        const optionsHtml = ROLES.map(r => `<option value="${r}"${r === s.role ? ' selected' : ''}>${r}</option>`).join('');
        return `<div class="sched-row${isOT ? ' is-ot' : ''}" data-row-id="${s.id}">
          <input type="text" class="sched-row__name" placeholder="Name" value="${s.name.replace(/"/g, '&quot;')}" data-field="name" aria-label="Employee name" />
          <select data-field="role" aria-label="Role">${optionsHtml}</select>
          <input type="number" inputmode="decimal" min="0" step="0.5" placeholder="hrs" value="${s.hours || ''}" data-field="hours" aria-label="Weekly hours" />
          <input type="number" inputmode="decimal" min="0" step="0.25" placeholder="rate" value="${s.rate || ''}" data-field="rate" aria-label="Hourly rate" />
          <button type="button" class="sched-row__remove" data-row-remove aria-label="Remove ${s.name || 'row'}">×</button>
        </div>`;
      }).join('');
    }

    function computeSched() {
      let totalHours = 0;
      let straightWages = 0;
      let otHours = 0;
      let otPremium = 0;
      const otAlerts: { name: string; hours: number; cost: number }[] = [];

      shifts.forEach(s => {
        if (!s.hours || !s.rate) return;
        totalHours += s.hours;
        const baseHours = Math.min(s.hours, OT_THRESHOLD);
        const overHours = Math.max(0, s.hours - OT_THRESHOLD);
        straightWages += s.hours * s.rate;
        if (overHours > 0) {
          otHours += overHours;
          const premium = overHours * s.rate * OT_MULTIPLIER;
          otPremium += premium;
          otAlerts.push({ name: s.name || 'Unnamed', hours: s.hours, cost: premium });
        }
      });

      return { totalHours, straightWages, otHours, otPremium, otAlerts, wagesSubtotal: straightWages + otPremium };
    }

    function renderSchedTotals() {
      const r = computeSched();
      const hoursEl = document.querySelector('[data-sched-hours]');
      const straightEl = document.querySelector('[data-sched-straight]');
      const otRow = document.querySelector('[data-sched-ot-row]') as HTMLElement | null;
      const otCostEl = document.querySelector('[data-sched-ot-cost]');
      const wagesEl = document.querySelector('[data-sched-wages]');
      const alertsEl = document.querySelector('[data-sched-alerts]') as HTMLElement | null;

      if (hoursEl) hoursEl.textContent = r.totalHours.toFixed(1);
      if (straightEl) straightEl.textContent = fmtUSD(r.straightWages);
      if (wagesEl) wagesEl.textContent = fmtUSD(r.wagesSubtotal);
      if (otRow) otRow.hidden = r.otPremium <= 0;
      if (otCostEl) otCostEl.textContent = fmtUSD(r.otPremium);

      if (alertsEl) {
        if (r.otAlerts.length === 0) {
          alertsEl.hidden = true;
          alertsEl.innerHTML = '';
        } else {
          alertsEl.hidden = false;
          alertsEl.innerHTML = r.otAlerts.map(a =>
            `<div class="sched__alert"><strong>OT alert:</strong> ${a.name} scheduled ${a.hours.toFixed(1)} hrs (over 40). Premium cost: ${fmtUSD(a.cost)}.</div>`
          ).join('');
        }
      }
      return r;
    }

    function fmtUSD(n: number): string {
      const sign = n < 0 ? '-' : '';
      const abs = Math.abs(n);
      return sign + '$' + abs.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    function fmtSignedUSD(n: number): string {
      const sign = n < 0 ? '−' : '+';
      const abs = Math.abs(n);
      return sign + '$' + abs.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    function animateCounter(el: HTMLElement, from: number, to: number, duration = 800, decimals = 1) {
      if (reduced) {
        el.textContent = to.toFixed(decimals);
        return;
      }
      const start = performance.now();
      const ease = (t: number) => 1 - Math.pow(1 - t, 3);
      function frame(now: number) {
        const t = Math.min((now - start) / duration, 1);
        const value = from + (to - from) * ease(t);
        el.textContent = value.toFixed(decimals);
        if (t < 1) requestAnimationFrame(frame);
        else {
          el.classList.add('result-num--pulse');
          setTimeout(() => el.classList.remove('result-num--pulse'), 320);
        }
      }
      requestAnimationFrame(frame);
    }

    // Concept-aware thresholds + SPLH benchmarks (per Toast, 7shifts, Restaurant365)
    const CONCEPTS: Record<string, { label: string; low: number; high: number; splhLow: number; splhHigh: number }> = {
      qsr:           { label: 'QSR',          low: 20, high: 25, splhLow: 40, splhHigh: 60 },
      'fast-casual': { label: 'Fast casual',  low: 25, high: 30, splhLow: 55, splhHigh: 80 },
      casual:        { label: 'Casual',       low: 28, high: 35, splhLow: 60, splhHigh: 85 },
      fine:          { label: 'Fine dining',  low: 30, high: 40, splhLow: 80, splhHigh: 150 },
      pizza:         { label: 'Pizza',        low: 25, high: 30, splhLow: 50, splhHigh: 80 },
      cafe:          { label: 'Cafe',         low: 25, high: 32, splhLow: 50, splhHigh: 80 },
    };

    function getConcept() {
      const key = (document.querySelector('#concept') as HTMLSelectElement)?.value || 'casual';
      return CONCEPTS[key] || CONCEPTS.casual;
    }

    function statusFor(pct: number): { key: string; label: string } {
      const c = getConcept();
      const watchHigh = c.high + 4;
      if (pct < c.low) return { key: 'lean', label: 'Lean' };
      if (pct <= c.high) return { key: 'healthy', label: 'Healthy' };
      if (pct <= watchHigh) return { key: 'watch', label: 'Watch' };
      return { key: 'critical', label: 'Critical' };
    }

    function reset() {
      statusPill!.dataset.status = 'empty';
      statusLabel!.textContent = 'Enter values';
      marker!.style.left = '0%';
      animateCounter(counter!, lastValue, 0, 400, 1);
      lastValue = 0;
      mathBody!.innerHTML = '<p class="t-caption">Enter values above to see the calculation.</p>';
      if (extras) extras.hidden = true;
    }

    function calc() {
      const data = new FormData(form!);
      const revenue = parseFloat(String(data.get('revenue') || '0')) || 0;

      let totalLabor = 0;
      let mathRows = '';

      let scheduleHours = 0;

      if (mode === 'quick') {
        totalLabor = parseFloat(String(data.get('cost') || '0')) || 0;
        if (totalLabor <= 0 || revenue <= 0) { reset(); return; }
        mathRows = `
          <tr><td>Total labor cost</td><td class="num">${fmtUSD(totalLabor)}</td></tr>
          <tr><td>Total revenue</td><td class="num">${fmtUSD(revenue)}</td></tr>
        `;
      } else if (mode === 'schedule') {
        const r = renderSchedTotals();
        scheduleHours = r.totalHours;
        const applyBurden = (document.querySelector('#sched-burden') as HTMLInputElement)?.checked ?? true;
        const burden = applyBurden ? r.wagesSubtotal * 0.25 : 0;
        const salary = parseFloat(String(data.get('sched-salary') || '0')) || 0;
        totalLabor = r.wagesSubtotal + burden + salary;
        if (totalLabor <= 0 || revenue <= 0) { reset(); return; }
        const otNote = r.otPremium > 0 ? ` (incl. ${fmtUSD(r.otPremium)} OT premium)` : '';
        mathRows = `
          <tr><td>Scheduled hours</td><td class="num">${r.totalHours.toFixed(1)} hrs</td></tr>
          <tr><td>Straight-time wages</td><td class="num">${fmtUSD(r.straightWages)}</td></tr>
          ${r.otPremium > 0 ? `<tr><td>+ OT premium (${r.otHours.toFixed(1)} hrs × 0.5×)</td><td class="num">${fmtUSD(r.otPremium)}</td></tr>` : ''}
          <tr class="math-table__step"><td>= Wages subtotal${otNote}</td><td class="num">${fmtUSD(r.wagesSubtotal)}</td></tr>
          ${applyBurden ? `<tr><td>+ 25% burden (taxes + benefits + WC)</td><td class="num">${fmtUSD(burden)}</td></tr>` : ''}
          ${salary > 0 ? `<tr><td>+ Salaried payroll</td><td class="num">${fmtUSD(salary)}</td></tr>` : ''}
          <tr class="math-table__step"><td>= Total labor cost</td><td class="num"><strong>${fmtUSD(totalLabor)}</strong></td></tr>
          <tr><td>Total revenue</td><td class="num">${fmtUSD(revenue)}</td></tr>
        `;
      } else {
        const hourly = parseFloat(String(data.get('hourly') || '0')) || 0;
        const salary = parseFloat(String(data.get('salary') || '0')) || 0;
        const burdenRaw = parseFloat(String(data.get('burden') || '0')) || 0;
        const autoBurden = (document.querySelector('#auto-burden') as HTMLInputElement)?.checked || false;
        const burden = autoBurden ? (hourly + salary) * 0.25 : burdenRaw;
        totalLabor = hourly + salary + burden;
        if (totalLabor <= 0 || revenue <= 0) { reset(); return; }
        mathRows = `
          <tr><td>Hourly wages</td><td class="num">${fmtUSD(hourly)}</td></tr>
          <tr><td>+ Salaries</td><td class="num">${fmtUSD(salary)}</td></tr>
          <tr><td>+ Taxes, benefits, comp${autoBurden ? ' (auto: wages × 25%)' : ''}</td><td class="num">${fmtUSD(burden)}</td></tr>
          <tr class="math-table__step"><td>= Total labor cost</td><td class="num"><strong>${fmtUSD(totalLabor)}</strong></td></tr>
          <tr><td>Total revenue</td><td class="num">${fmtUSD(revenue)}</td></tr>
        `;
      }

      const pct = (totalLabor / revenue) * 100;
      const clamped = Math.min(50, Math.max(0, pct));
      const markerPos = (clamped / 50) * 100;

      animateCounter(counter!, lastValue, pct, 800, 1);
      lastValue = pct;

      const s = statusFor(pct);
      statusPill!.dataset.status = s.key;
      statusLabel!.textContent = s.label;
      marker!.style.left = `${markerPos}%`;

      // SPLH calculation, works in all modes if hours provided
      const formHours = parseFloat(String(data.get('hours') || '0')) || 0;
      const hoursWorked = mode === 'schedule' ? scheduleHours : formHours;
      const splhRow = document.querySelector('[data-splh-row]') as HTMLElement | null;
      const splhEl = document.querySelector('[data-splh]') as HTMLElement | null;
      const showExtrasForSPLH = hoursWorked > 0;

      if (mode === 'detailed' || mode === 'schedule' || showExtrasForSPLH) {
        if (extras) extras.hidden = false;
        if (cogsEl) cogsEl.textContent = fmtUSD(totalLabor);
      }

      const concept = getConcept();
      if (hoursWorked > 0 && splhRow && splhEl) {
        splhRow.hidden = false;
        const splh = revenue / hoursWorked;
        let splhClass = 'is-good';
        if (splh < concept.splhLow) splhClass = 'is-bad';
        else if (splh < concept.splhLow * 1.1) splhClass = 'is-watch';
        splhEl.textContent = `${fmtUSD(splh)}/hr (target ${concept.splhLow}–${concept.splhHigh})`;
        splhEl.className = `extras-row__value num ${splhClass}`;
      } else if (splhRow) {
        splhRow.hidden = true;
      }

      if (mode === 'detailed' && extras && cogsEl) {
        const targetRaw = parseFloat(String(data.get('target') || ''));
        const target = isNaN(targetRaw) ? null : targetRaw;
        const theoreticalRaw = parseFloat(String(data.get('theoretical') || ''));
        const theoretical = isNaN(theoreticalRaw) ? null : theoreticalRaw;

        if (target !== null && targetRow && targetVarEl && targetMoneyRow && targetMoneyEl) {
          const diff = pct - target;
          targetRow.hidden = false;
          targetVarEl.textContent = `${diff >= 0 ? '+' : '−'}${Math.abs(diff).toFixed(2)}pp`;
          targetVarEl.className = `extras-row__value num ${diff > 0.5 ? 'is-bad' : diff < -0.5 ? 'is-lean' : 'is-good'}`;
          targetMoneyRow.hidden = false;
          const targetLabor = revenue * (target / 100);
          const moneyDiff = totalLabor - targetLabor;
          targetMoneyEl.textContent = moneyDiff >= 0
            ? `${fmtSignedUSD(moneyDiff)} over target`
            : `${fmtSignedUSD(moneyDiff)} under target`;
          targetMoneyEl.className = `extras-row__value num ${moneyDiff > 0 ? 'is-bad' : 'is-good'}`;
        } else if (targetRow && targetMoneyRow) {
          targetRow.hidden = true;
          targetMoneyRow.hidden = true;
        }

        if (theoretical !== null && theoreticalRow && theoreticalVarEl) {
          const tDiff = pct - theoretical;
          theoreticalRow.hidden = false;
          theoreticalVarEl.textContent = `${tDiff >= 0 ? '+' : '−'}${Math.abs(tDiff).toFixed(2)}pp variance`;
          theoreticalVarEl.className = `extras-row__value num ${Math.abs(tDiff) > 3 ? 'is-bad' : Math.abs(tDiff) > 1 ? 'is-watch' : 'is-good'}`;
        } else if (theoreticalRow) {
          theoreticalRow.hidden = true;
        }
      } else if (extras) {
        extras.hidden = true;
      }

      let note = '';
      if (s.label === 'Healthy') note = `Within healthy band for ${concept.label} (${concept.low}–${concept.high}%). Maintain weekly tracking and watch overtime creep.`;
      if (s.label === 'Lean') note = `Below typical ${concept.label} range (${concept.low}–${concept.high}%). Verify burden, wages alone undercounts by 15–25%. Or you may be over-relying on owner labor.`;
      if (s.label === 'Watch') note = `Slightly above ${concept.label} healthy range (${concept.low}–${concept.high}%). Common causes: overtime creep, schedule built for old sales volume, slow-shift overstaffing.`;
      if (s.label === 'Critical') note = `Above ${concept.label} healthy range (${concept.low}–${concept.high}%). Investigate: overtime, scheduling vs daypart sales, productivity per labor hour, prep-vs-line ratio.`;

      mathBody!.innerHTML = `
        <table class="math-table" role="presentation">
          ${mathRows}
          <tr class="math-table__step"><td>Labor cost ÷ Revenue</td><td class="num">${(totalLabor / revenue).toFixed(4)}</td></tr>
          <tr class="math-table__step"><td>× 100</td><td class="num">${pct.toFixed(2)}%</td></tr>
          <tr class="math-table__final"><td>Labor cost percentage</td><td class="num"><strong>${pct.toFixed(1)}%</strong></td></tr>
        </table>
        ${note ? `<p class="t-caption math-note">${note}</p>` : ''}
      `;

      if (mathWrap && !mathWrap.open) mathWrap.open = true;
    }

    function debouncedCalc() {
      if (calcDebounce !== null) clearTimeout(calcDebounce);
      calcDebounce = window.setTimeout(calc, 250);
    }

    form.addEventListener('input', debouncedCalc);
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      if (calcDebounce !== null) clearTimeout(calcDebounce);
      calc();
    });

    modeBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const newMode = btn.dataset.modeBtn as 'quick' | 'detailed' | 'schedule';
        if (newMode === mode) return;
        mode = newMode;
        modeBtns.forEach((b) => {
          const isActive = b.dataset.modeBtn === mode;
          b.classList.toggle('is-active', isActive);
          b.setAttribute('aria-selected', String(isActive));
        });
        form.dataset.mode = mode;
        document.querySelectorAll<HTMLElement>('[data-group]').forEach((g) => {
          g.classList.toggle('form-group--hidden', g.dataset.group !== mode);
        });
        // Hide manual hours input in schedule mode (computed from shifts)
        const hoursRow = (document.querySelector('#hours') as HTMLElement | null)?.closest('.form-row') as HTMLElement | null;
        if (hoursRow) hoursRow.style.display = mode === 'schedule' ? 'none' : '';
        reset();
        if (mode === 'schedule') { renderSchedRows(); renderSchedTotals(); calc(); }
      });
    });

    // Schedule roster wiring
    const schedRowsWrap = document.querySelector('[data-sched-rows]') as HTMLElement | null;
    const schedAddBtn = document.querySelector('[data-sched-add]');
    const schedExBtn = document.querySelector('[data-sched-example]');
    const schedClearBtn = document.querySelector('[data-sched-clear]');

    function addShift(partial?: Partial<ShiftRow>) {
      shifts.push({
        id: uid(),
        name: partial?.name || '',
        role: partial?.role || 'Server',
        hours: partial?.hours ?? 0,
        rate: partial?.rate ?? 0,
      });
      renderSchedRows();
      renderSchedTotals();
      if (mode === 'schedule') debouncedCalc();
    }

    function clearShifts() {
      shifts = [];
      renderSchedRows();
      renderSchedTotals();
      if (mode === 'schedule') debouncedCalc();
    }

    function loadExampleCrew() {
      shifts = [];
      const example: Partial<ShiftRow>[] = [
        { name: 'Sarah',  role: 'Bartender',   hours: 38, rate: 14 },
        { name: 'Mike',   role: 'Bartender',   hours: 35, rate: 14 },
        { name: 'Anna',   role: 'Server',      hours: 32, rate: 16 },
        { name: 'Jose',   role: 'Server',      hours: 30, rate: 16 },
        { name: 'Carlos', role: 'Line cook',   hours: 45, rate: 22 },
        { name: 'Lily',   role: 'Prep cook',   hours: 30, rate: 18 },
        { name: 'Dave',   role: 'Dishwasher',  hours: 25, rate: 16 },
        { name: 'Tara',   role: 'Host',        hours: 24, rate: 17 },
      ];
      example.forEach(p => shifts.push({ id: uid(), name: p.name!, role: p.role!, hours: p.hours!, rate: p.rate! }));
      renderSchedRows();
      renderSchedTotals();
      if (mode === 'schedule') debouncedCalc();
    }

    schedAddBtn?.addEventListener('click', () => addShift());
    schedExBtn?.addEventListener('click', loadExampleCrew);
    schedClearBtn?.addEventListener('click', clearShifts);

    if (schedRowsWrap) {
      schedRowsWrap.addEventListener('input', (e) => {
        const t = e.target as HTMLInputElement | HTMLSelectElement;
        const row = (t as HTMLElement).closest('[data-row-id]') as HTMLElement | null;
        if (!row) return;
        const id = row.dataset.rowId;
        const sh = shifts.find(s => s.id === id);
        if (!sh) return;
        const field = t.dataset.field;
        if (field === 'name') sh.name = t.value;
        else if (field === 'role') sh.role = t.value;
        else if (field === 'hours') sh.hours = parseFloat(t.value) || 0;
        else if (field === 'rate') sh.rate = parseFloat(t.value) || 0;
        // Update OT highlight without re-rendering full row (preserves focus)
        if (field === 'hours') row.classList.toggle('is-ot', sh.hours > OT_THRESHOLD);
        renderSchedTotals();
        if (mode === 'schedule') debouncedCalc();
      });
      schedRowsWrap.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('[data-row-remove]') as HTMLElement | null;
        if (!btn) return;
        const row = btn.closest('[data-row-id]') as HTMLElement | null;
        if (!row) return;
        shifts = shifts.filter(s => s.id !== row.dataset.rowId);
        renderSchedRows();
        renderSchedTotals();
        if (mode === 'schedule') debouncedCalc();
      });
    }

    function loadExample() {
      if (mode === 'quick') {
        (document.querySelector('#cost') as HTMLInputElement).value = '9000';
      } else if (mode === 'detailed') {
        (document.querySelector('#hourly') as HTMLInputElement).value = '5800';
        (document.querySelector('#salary') as HTMLInputElement).value = '2500';
        (document.querySelector('#burden') as HTMLInputElement).value = '1500';
      } else if (mode === 'schedule') {
        loadExampleCrew();
        const sal = document.querySelector('#sched-salary') as HTMLInputElement | null;
        if (sal) sal.value = '1500';
      }
      (document.querySelector('#revenue') as HTMLInputElement).value = mode === 'schedule' ? '32000' : '30000';
      const hoursInput = document.querySelector('#hours') as HTMLInputElement | null;
      if (hoursInput && mode !== 'schedule') hoursInput.value = '450';
      calc();
    }

    const loadExBtn = document.querySelector('[data-load-example]');
    if (loadExBtn) loadExBtn.addEventListener('click', loadExample);
    loadExample();
  }
</script>

