  .show-math__trigger::-webkit-details-marker { display: none; }
  .show-math__trigger:hover { background: var(--color-border-soft); }
  .show-math__icon { font-family: var(--font-mono); font-size: 1.125rem; color: var(--color-saffron-text); transition: transform var(--transition-fast); width: 16px; text-align: center; }
  .show-math[open] .show-math__icon { transform: rotate(45deg); }
