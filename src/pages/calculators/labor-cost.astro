              <div class="bench-bar__tick" style={`left: ${b.low * 2}%`} title={`${b.low}%`}></div>
              <div class="bench-bar__tick" style={`left: ${b.high * 2}%`} title={`${b.high}%`}></div>
            </div>
            <div class="bench-bar__range num">{b.low}–{b.high}%</div>
