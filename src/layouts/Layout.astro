        border-top: 1px solid var(--color-border);
        background: var(--color-cream);
      }
      .embed-credit a {
        color: var(--color-saffron-text);
        font-weight: 600;
        text-decoration: none;
      }
      .embed-credit a:hover { text-decoration: underline; }

      /* ---------- "Get embed code" button (calc pages, non-embed only) ---------- */
      .embed-cta {
        position: fixed;
        right: 20px;
        bottom: 20px;
        z-index: 70;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 14px 20px;
        background: var(--color-saffron-text, #b8651a);
        color: #fff;
        font-family: var(--font-body);
        font-size: 0.9375rem;
        font-weight: 700;
        letter-spacing: 0.005em;
        border: none;
        border-radius: 999px;
        cursor: pointer;
        box-shadow: 0 6px 20px rgba(184, 101, 26, 0.35), 0 2px 6px rgba(0,0,0,0.15);
        transition: transform 120ms ease, box-shadow 120ms ease, background 120ms ease;
        animation: embed-cta-pulse 2.4s ease-in-out 1.5s 2;
      }
      .embed-cta:hover { transform: translateY(-2px); box-shadow: 0 10px 26px rgba(184, 101, 26, 0.45); }
      .embed-cta__icon { font-size: 1.05rem; line-height: 1; }
      @keyframes embed-cta-pulse {
        0%, 100% { box-shadow: 0 6px 20px rgba(184, 101, 26, 0.35), 0 2px 6px rgba(0,0,0,0.15); }
        50% { box-shadow: 0 6px 20px rgba(184, 101, 26, 0.35), 0 0 0 12px rgba(184, 101, 26, 0); }
      }
      @media (max-width: 720px) {
        .embed-cta {
          right: 12px;
          bottom: 12px;
          padding: 11px 16px;
          font-size: 0.8125rem;
        }
        .embed-cta__label-long { display: none; }
      }

      .embed-modal[hidden] { display: none; }
      .embed-modal {
        position: fixed; inset: 0; z-index: 200;
        display: flex; align-items: center; justify-content: center;
        padding: 16px;
      }
      .embed-modal__scrim { position: absolute; inset: 0; background: rgba(26,24,20,0.55); }
      .embed-modal__panel {
        position: relative;
        background: var(--color-white);
        border-radius: var(--radius-lg);
        max-width: 560px;
        width: 100%;
        padding: 24px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.3);
      }
      .embed-modal__title { font-family: var(--font-display); font-size: 1.25rem; margin: 0 0 4px; color: var(--color-heading); }
      .embed-modal__sub { font-family: var(--font-body); font-size: 0.875rem; color: var(--color-muted); margin: 0 0 14px; }
      .embed-modal__code {
        width: 100%;
