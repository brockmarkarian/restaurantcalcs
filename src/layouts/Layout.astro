      .site-footer__legal {
        padding-top: var(--space-4);
        border-top: 1px solid var(--color-border);
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: var(--space-4);
      }
      .site-footer__updated { color: var(--color-muted); }
      .site-footer__credit { color: var(--color-saffron-text); font-weight: 500; text-decoration: none; transition: color var(--transition-fast); }
      .site-footer__credit:hover { color: var(--color-heading); text-decoration: underline; }

      /* Margin ad rails — only on wide screens (above 1480px) */
      .rail {
        display: none;
      }

      @media (min-width: 1480px) {
        .rail {
          display: block;
          position: fixed;
          top: 100px;
          width: 160px;
          z-index: 5;
        }
        .rail--left { left: max(16px, calc((100vw - 1180px) / 2 - 200px)); }
        .rail--right { right: max(16px, calc((100vw - 1180px) / 2 - 200px)); }
      }

      .rail__inner {
        background: var(--color-cream);
        border: 1px dashed var(--color-border);
        border-radius: var(--radius-md);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        height: 600px;
      }

      .rail__label {
        padding: 6px 10px;
        font-family: var(--font-body);
        font-size: 0.625rem;
