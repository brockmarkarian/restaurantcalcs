        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 6px;
        color: var(--color-muted);
      }

      .rail__placeholder .num {
        font-size: 0.75rem;
      }

      /* ---------- Embed mode: strip chrome + non-essential sections ---------- */
      html.embed body {
        background: transparent !important;
      }
      html.embed .site-header,
      html.embed .site-footer,
      html.embed .rail,
      html.embed .drawer,
      html.embed .skip-link,
      html.embed .calc-page__header,
      html.embed .essay,
      html.embed .operator-story,
      html.embed .benchmarks,
      html.embed .scenarios,
      html.embed .calc-faq,
      html.embed .cited-sources,
      html.embed .related-calcs,
      html.embed .ad-slot,
      html.embed .embed-cta { display: none !important; }
      html.embed main { min-height: 0 !important; }
      html.embed .calc-page,
      html.embed .calc-grid {
        max-width: 100% !important;
        margin: 0 !important;
        padding: 16px !important;
      }
      .embed-credit { display: none; }
      html.embed .embed-credit {
        display: flex;
        align-items: center;
        justify-content: space-between;
